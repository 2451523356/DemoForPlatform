{"ast":null,"code":"export default {\n  name: 'ShareDialog',\n  props: {\n    value: {\n      type: Boolean,\n      default: false\n    },\n    shareUrl: {\n      type: String,\n      default: ''\n    },\n    shareTitle: {\n      type: String,\n      default: ''\n    },\n    shareDesc: {\n      type: String,\n      default: ''\n    }\n  },\n  data() {\n    return {\n      posterVisible: false\n    };\n  },\n  computed: {\n    visible: {\n      get() {\n        return this.value;\n      },\n      set(val) {\n        this.$emit('input', val);\n      }\n    }\n  },\n  methods: {\n    shareTo(platform) {\n      const url = encodeURIComponent(this.shareUrl || window.location.href);\n      const title = encodeURIComponent(this.shareTitle || document.title);\n      switch (platform) {\n        case 'wechat':\n        case 'moments':\n          this.$message.success('链接已准备好，请复制后打开微信粘贴发送给好友');\n          this.copyToClipboard(this.shareUrl, false);\n          break;\n        case 'qq':\n          window.open(`https://connect.qq.com/widget/shareqq/index.html?url=${url}&title=${title}`, '_blank', 'width=600,height=400');\n          break;\n        case 'weibo':\n          window.open(`https://service.weibo.com/share/share.php?url=${url}&title=${title}`, '_blank', 'width=600,height=400');\n          break;\n      }\n    },\n    async copyLink() {\n      await this.copyToClipboard(this.shareUrl, true);\n    },\n    async copyToClipboard(text, showMsg) {\n      try {\n        await navigator.clipboard.writeText(text);\n        if (showMsg) this.$message.success('链接已复制，可直接粘贴分享给研友');\n      } catch (e) {\n        const input = document.createElement('input');\n        input.value = text;\n        document.body.appendChild(input);\n        input.select();\n        document.execCommand('copy');\n        document.body.removeChild(input);\n        if (showMsg) this.$message.success('链接已复制');\n      }\n    },\n    generatePoster() {\n      this.visible = false;\n      this.$nextTick(() => {\n        this.posterVisible = true;\n        this.$nextTick(() => this.drawQRCode());\n      });\n    },\n    drawQRCode() {\n      const canvas = this.$refs.qrCanvas;\n      if (!canvas) return;\n      const ctx = canvas.getContext('2d');\n      // 生成简单的二维码占位图（灰色格子模拟）\n      ctx.fillStyle = '#fff';\n      ctx.fillRect(0, 0, 120, 120);\n      const size = 120;\n      const moduleCount = 21;\n      const moduleSize = size / moduleCount;\n      ctx.fillStyle = '#303133';\n      // 生成简单图案（后续可接入真实 QR 库）\n      const url = this.shareUrl || window.location.href;\n      let hash = 0;\n      for (let i = 0; i < url.length; i++) hash = (hash << 5) - hash + url.charCodeAt(i) | 0;\n      const seed = Math.abs(hash);\n      for (let row = 0; row < moduleCount; row++) {\n        for (let col = 0; col < moduleCount; col++) {\n          if (row < 8 && col < 8 || row < 8 && col > 12 || row > 12 && col < 8) continue;\n          if (seed * (row * moduleCount + col + 1) % 3 === 0) {\n            ctx.fillRect(col * moduleSize, row * moduleSize, moduleSize, moduleSize);\n          }\n        }\n      }\n    },\n    savePoster() {\n      const el = this.$refs.posterCanvas;\n      if (!el) return;\n      // 使用 html2canvas 简易替代：直接提示\n      this.$message.success('请使用截图工具截取海报区域保存');\n      // 也可以用 canvas API 直接绘制保存\n    }\n  }\n};","map":{"version":3,"names":["name","props","value","type","Boolean","default","shareUrl","String","shareTitle","shareDesc","data","posterVisible","computed","visible","get","set","val","$emit","methods","shareTo","platform","url","encodeURIComponent","window","location","href","title","document","$message","success","copyToClipboard","open","copyLink","text","showMsg","navigator","clipboard","writeText","e","input","createElement","body","appendChild","select","execCommand","removeChild","generatePoster","$nextTick","drawQRCode","canvas","$refs","qrCanvas","ctx","getContext","fillStyle","fillRect","size","moduleCount","moduleSize","hash","i","length","charCodeAt","seed","Math","abs","row","col","savePoster","el","posterCanvas"],"sources":["src/components/ShareDialog.vue"],"sourcesContent":["<template>\n  <el-dialog title=\"分享\" :visible.sync=\"visible\" width=\"480px\" :close-on-click-modal=\"true\" class=\"share-dialog\">\n    <div class=\"share-body\" v-if=\"visible\">\n      <!-- 分享渠道 -->\n      <div class=\"share-channels\">\n        <div class=\"channel-item\" @click=\"shareTo('wechat')\">\n          <div class=\"channel-icon wechat\"><i class=\"el-icon-chat-line-square\"></i></div>\n          <span>微信好友</span>\n        </div>\n        <div class=\"channel-item\" @click=\"shareTo('moments')\">\n          <div class=\"channel-icon moments\"><i class=\"el-icon-picture-outline\"></i></div>\n          <span>朋友圈</span>\n        </div>\n        <div class=\"channel-item\" @click=\"shareTo('qq')\">\n          <div class=\"channel-icon qq\"><i class=\"el-icon-chat-round\"></i></div>\n          <span>QQ</span>\n        </div>\n        <div class=\"channel-item\" @click=\"shareTo('weibo')\">\n          <div class=\"channel-icon weibo\"><i class=\"el-icon-share\"></i></div>\n          <span>微博</span>\n        </div>\n        <div class=\"channel-item\" @click=\"copyLink\">\n          <div class=\"channel-icon copy\"><i class=\"el-icon-link\"></i></div>\n          <span>复制链接</span>\n        </div>\n        <div class=\"channel-item\" @click=\"generatePoster\">\n          <div class=\"channel-icon poster\"><i class=\"el-icon-picture\"></i></div>\n          <span>分享海报</span>\n        </div>\n      </div>\n\n      <!-- 分享链接预览 -->\n      <div class=\"share-link-box\">\n        <span class=\"link-text\">{{ shareUrl }}</span>\n      </div>\n    </div>\n\n    <!-- 海报预览弹窗 -->\n    <el-dialog title=\"分享海报\" :visible.sync=\"posterVisible\" width=\"380px\" append-to-body class=\"poster-dialog\">\n      <div class=\"poster-preview\" v-if=\"posterVisible\">\n        <div ref=\"posterCanvas\" class=\"poster-canvas\">\n          <div class=\"poster-bg\">\n            <div class=\"poster-header\">考研学习平台</div>\n            <div class=\"poster-title\">{{ shareTitle }}</div>\n            <div class=\"poster-desc\" v-if=\"shareDesc\">{{ shareDesc }}</div>\n            <div class=\"poster-qr\">\n              <canvas ref=\"qrCanvas\" width=\"120\" height=\"120\"></canvas>\n              <span>扫码查看详情</span>\n            </div>\n            <div class=\"poster-footer\">长按保存图片 · 分享给研友</div>\n          </div>\n        </div>\n        <el-button type=\"primary\" size=\"small\" style=\"width:100%;margin-top:12px\" @click=\"savePoster\">\n          保存图片到本地\n        </el-button>\n      </div>\n    </el-dialog>\n  </el-dialog>\n</template>\n\n<script>\nexport default {\n  name: 'ShareDialog',\n  props: {\n    value: { type: Boolean, default: false },\n    shareUrl: { type: String, default: '' },\n    shareTitle: { type: String, default: '' },\n    shareDesc: { type: String, default: '' }\n  },\n  data() {\n    return { posterVisible: false }\n  },\n  computed: {\n    visible: {\n      get() { return this.value },\n      set(val) { this.$emit('input', val) }\n    }\n  },\n  methods: {\n    shareTo(platform) {\n      const url = encodeURIComponent(this.shareUrl || window.location.href)\n      const title = encodeURIComponent(this.shareTitle || document.title)\n      switch (platform) {\n        case 'wechat':\n        case 'moments':\n          this.$message.success('链接已准备好，请复制后打开微信粘贴发送给好友')\n          this.copyToClipboard(this.shareUrl, false)\n          break\n        case 'qq':\n          window.open(`https://connect.qq.com/widget/shareqq/index.html?url=${url}&title=${title}`, '_blank', 'width=600,height=400')\n          break\n        case 'weibo':\n          window.open(`https://service.weibo.com/share/share.php?url=${url}&title=${title}`, '_blank', 'width=600,height=400')\n          break\n      }\n    },\n    async copyLink() {\n      await this.copyToClipboard(this.shareUrl, true)\n    },\n    async copyToClipboard(text, showMsg) {\n      try {\n        await navigator.clipboard.writeText(text)\n        if (showMsg) this.$message.success('链接已复制，可直接粘贴分享给研友')\n      } catch (e) {\n        const input = document.createElement('input')\n        input.value = text\n        document.body.appendChild(input)\n        input.select()\n        document.execCommand('copy')\n        document.body.removeChild(input)\n        if (showMsg) this.$message.success('链接已复制')\n      }\n    },\n    generatePoster() {\n      this.visible = false\n      this.$nextTick(() => {\n        this.posterVisible = true\n        this.$nextTick(() => this.drawQRCode())\n      })\n    },\n    drawQRCode() {\n      const canvas = this.$refs.qrCanvas\n      if (!canvas) return\n      const ctx = canvas.getContext('2d')\n      // 生成简单的二维码占位图（灰色格子模拟）\n      ctx.fillStyle = '#fff'\n      ctx.fillRect(0, 0, 120, 120)\n      const size = 120\n      const moduleCount = 21\n      const moduleSize = size / moduleCount\n      ctx.fillStyle = '#303133'\n      // 生成简单图案（后续可接入真实 QR 库）\n      const url = this.shareUrl || window.location.href\n      let hash = 0\n      for (let i = 0; i < url.length; i++) hash = ((hash << 5) - hash) + url.charCodeAt(i) | 0\n      const seed = Math.abs(hash)\n      for (let row = 0; row < moduleCount; row++) {\n        for (let col = 0; col < moduleCount; col++) {\n          if ((row < 8 && col < 8) || (row < 8 && col > 12) || (row > 12 && col < 8)) continue\n          if ((seed * (row * moduleCount + col + 1)) % 3 === 0) {\n            ctx.fillRect(col * moduleSize, row * moduleSize, moduleSize, moduleSize)\n          }\n        }\n      }\n    },\n    savePoster() {\n      const el = this.$refs.posterCanvas\n      if (!el) return\n      // 使用 html2canvas 简易替代：直接提示\n      this.$message.success('请使用截图工具截取海报区域保存')\n      // 也可以用 canvas API 直接绘制保存\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.share-dialog {\n  .share-body { padding: 10px 0; }\n}\n\n.share-channels {\n  display: flex; justify-content: space-around; flex-wrap: wrap; gap: 12px; margin-bottom: 20px;\n  .channel-item {\n    display: flex; flex-direction: column; align-items: center; gap: 6px;\n    cursor: pointer; transition: all .3s; padding: 10px;\n    &:hover { transform: scale(1.08); .channel-icon { box-shadow: 0 4px 12px rgba(0,0,0,.15); } }\n    span { font-size: 12px; color: #606266; }\n    .channel-icon {\n      width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center;\n      justify-content: center; font-size: 22px; color: #fff; transition: all .3s;\n      &.wechat { background: #07c160; }\n      &.moments { background: #1aad19; }\n      &.qq { background: #12b7f5; }\n      &.weibo { background: #e6162d; }\n      &.copy { background: #909399; }\n      &.poster { background: #e6a23c; }\n    }\n  }\n}\n\n.share-link-box {\n  background: #f5f7fa; border-radius: 6px; padding: 10px 14px;\n  .link-text { font-size: 13px; color: #909399; word-break: break-all; }\n}\n\n.poster-canvas {\n  .poster-bg {\n    width: 320px; margin: 0 auto; padding: 30px 24px; background: linear-gradient(135deg, #1a3a5c, #2d6aa0);\n    border-radius: 12px; color: #fff; text-align: center;\n    .poster-header { font-size: 20px; font-weight: 700; margin-bottom: 16px; }\n    .poster-title { font-size: 16px; margin-bottom: 8px; line-height: 1.5; }\n    .poster-desc { font-size: 13px; opacity: .8; margin-bottom: 20px; }\n    .poster-qr { margin-bottom: 12px; canvas { background: #fff; border-radius: 8px; padding: 6px; } span { display: block; font-size: 12px; margin-top: 6px; opacity: .7; } }\n    .poster-footer { font-size: 12px; opacity: .6; }\n  }\n}\n</style>\n"],"mappings":"AA6DA;EACAA,IAAA;EACAC,KAAA;IACAC,KAAA;MAAAC,IAAA,EAAAC,OAAA;MAAAC,OAAA;IAAA;IACAC,QAAA;MAAAH,IAAA,EAAAI,MAAA;MAAAF,OAAA;IAAA;IACAG,UAAA;MAAAL,IAAA,EAAAI,MAAA;MAAAF,OAAA;IAAA;IACAI,SAAA;MAAAN,IAAA,EAAAI,MAAA;MAAAF,OAAA;IAAA;EACA;EACAK,KAAA;IACA;MAAAC,aAAA;IAAA;EACA;EACAC,QAAA;IACAC,OAAA;MACAC,IAAA;QAAA,YAA