{"ast":null,"code":"export default {\n  name: 'Words',\n  data() {\n    return {\n      stats: {},\n      reviewWords: [],\n      reviewing: false,\n      flipCard: false,\n      reviewIndex: 0,\n      wordList: [],\n      page: 1,\n      size: 20,\n      total: 0\n    };\n  },\n  computed: {\n    reviewProgress() {\n      return this.reviewWords.length ? Math.round(this.reviewIndex / this.reviewWords.length * 100) : 0;\n    },\n    currentWord() {\n      return this.reviewWords[this.reviewIndex] || null;\n    }\n  },\n  created() {\n    this.fetchStats();\n    this.fetchReviewWords();\n    this.fetchWordList();\n  },\n  methods: {\n    async fetchStats() {\n      try {\n        this.stats = (await this.$http.get('/word/stats')) || {};\n      } catch (e) {}\n    },\n    async fetchReviewWords() {\n      try {\n        this.reviewWords = (await this.$http.get('/word/review', {\n          params: {\n            limit: 50\n          }\n        })) || [];\n      } catch (e) {}\n    },\n    async fetchWordList() {\n      try {\n        const res = await this.$http.get('/word/list', {\n          params: {\n            page: this.page,\n            size: this.size\n          }\n        });\n        this.wordList = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (e) {}\n    },\n    handlePage(p) {\n      this.page = p;\n      this.fetchWordList();\n    },\n    startReview() {\n      this.reviewing = true;\n      this.reviewIndex = 0;\n      this.flipCard = false;\n    },\n    async answer(isCorrect, level) {\n      try {\n        await this.$http.post('/word/answer', {\n          wordId: this.currentWord.wordId,\n          isCorrect,\n          level\n        });\n        this.reviewIndex++;\n        this.flipCard = false;\n        if (this.reviewIndex >= this.reviewWords.length) {\n          this.$message.success('复习完成!');\n          this.reviewing = false;\n          this.fetchReviewWords();\n          this.fetchStats();\n        }\n      } catch (e) {\n        this.$message.error('提交失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","stats","reviewWords","reviewing","flipCard","reviewIndex","wordList","page","size","total","computed","reviewProgress","length","Math","round","currentWord","created","fetchStats","fetchReviewWords","fetchWordList","methods","$http","get","e","params","limit","res","records","handlePage","p","startReview","answer","isCorrect","level","post","wordId","$message","success","error"],"sources":["src/views/study/Words.vue"],"sourcesContent":["<template>\n  <div class=\"words-page\">\n    <div class=\"page-header\"><h1>每日单词</h1><p>基于艾宾浩斯遗忘曲线的智能化单词复习系统</p></div>\n    <div class=\"stats-row\">\n      <el-card class=\"stat-card\"><div class=\"stat-val\">{{ stats.totalWords || 0 }}</div><div class=\"stat-label\">总词汇量</div></el-card>\n      <el-card class=\"stat-card\"><div class=\"stat-val\" style=\"color:#67C23A\">{{ stats.masteredWords || 0 }}</div><div class=\"stat-label\">已掌握</div></el-card>\n      <el-card class=\"stat-card\"><div class=\"stat-val\" style=\"color:#E6A23C\">{{ stats.reviewWords || 0 }}</div><div class=\"stat-label\">待复习</div></el-card>\n      <el-card class=\"stat-card\"><div class=\"stat-val\" style=\"color:#409EFF\">{{ stats.todayReviewed || 0 }}</div><div class=\"stat-label\">今日已复习</div></el-card>\n    </div>\n    <el-card>\n      <div class=\"review-header\"><h3>今日复习单词 ({{ reviewWords.length }}个)</h3><el-button type=\"primary\" size=\"small\" @click=\"startReview\" :disabled=\"reviewWords.length===0\">开始复习</el-button></div>\n      <div v-if=\"reviewing\" class=\"review-card\">\n        <div class=\"word-flashcard\" @click=\"flipCard = !flipCard\">\n          <div class=\"card-inner\" :class=\"{ flipped: flipCard }\">\n            <div class=\"card-front\"><h2>{{ currentWord?.word }}</h2><p v-if=\"currentWord?.phonetic\" class=\"phonetic\">{{ currentWord.phonetic }}</p><p class=\"hint\">点击翻转查看释义</p></div>\n            <div class=\"card-back\"><h2>{{ currentWord?.translation }}</h2><p v-if=\"currentWord?.example\" class=\"example\">{{ currentWord.example }}</p><p v-if=\"currentWord?.exampleTrans\" class=\"example-trans\">{{ currentWord.exampleTrans }}</p></div>\n          </div>\n        </div>\n        <div class=\"review-actions\">\n          <el-button type=\"danger\" @click=\"answer(false)\">不认识</el-button>\n          <el-button type=\"primary\" @click=\"answer(true, 'hard')\">困难</el-button>\n          <el-button type=\"success\" @click=\"answer(true, 'easy')\">简单</el-button>\n        </div>\n        <div class=\"review-progress\"><el-progress :percentage=\"reviewProgress\" :format=\"()=>reviewIndex+'/'+reviewWords.length\"/></div>\n      </div>\n      <div v-if=\"!reviewing && reviewWords.length===0\" class=\"empty-state\"><i class=\"el-icon-circle-check\"></i><p>今日复习任务已完成</p></div>\n    </el-card>\n    <el-card style=\"margin-top:20px\"><h3>词汇列表</h3><el-table :data=\"wordList\" stripe><el-table-column prop=\"word\" label=\"单词\"/><el-table-column prop=\"translation\" label=\"释义\"/><el-table-column prop=\"phonetic\" label=\"音标\"/><el-table-column prop=\"frequency\" label=\"考频\" width=\"80\"><template slot-scope=\"s\"><el-rate :value=\"s.row.frequency\" disabled :max=\"5\" :colors=\"['#99A9BF','#F7BA2A','#FF9900']\"/></template></el-table-column><el-table-column prop=\"unit\" label=\"单元\" width=\"80\"/></el-table>\n      <el-pagination style=\"margin-top:16px\" @current-change=\"handlePage\" :current-page=\"page\" :page-size=\"size\" :total=\"total\" layout=\"total,prev,pager,next\"/></el-card>\n  </div>\n</template>\n<script>\nexport default {\n  name: 'Words',\n  data() { return { stats:{}, reviewWords:[], reviewing:false, flipCard:false, reviewIndex:0, wordList:[], page:1, size:20, total:0 } },\n  computed: {\n    reviewProgress() { return this.reviewWords.length ? Math.round(this.reviewIndex/this.reviewWords.length*100) : 0 },\n    currentWord() { return this.reviewWords[this.reviewIndex] || null }\n  },\n  created() { this.fetchStats(); this.fetchReviewWords(); this.fetchWordList() },\n  methods: {\n    async fetchStats() { try { this.stats = await this.$http.get('/word/stats') || {} } catch(e) {} },\n    async fetchReviewWords() { try { this.reviewWords = await this.$http.get('/word/review', { params: { limit: 50 } }) || [] } catch(e) {} },\n    async fetchWordList() { try { const res = await this.$http.get('/word/list',{params:{page:this.page,size:this.size}}); this.wordList=res?.records||[]; this.total=res?.total||0 } catch(e) {} },\n    handlePage(p) { this.page=p; this.fetchWordList() },\n    startReview() { this.reviewing=true; this.reviewIndex=0; this.flipCard=false },\n    async answer(isCorrect, level) { try { await this.$http.post('/word/answer', { wordId: this.currentWord.wordId, isCorrect, level }); this.reviewIndex++; this.flipCard=false; if(this.reviewIndex>=this.reviewWords.length) { this.$message.success('复习完成!'); this.reviewing=false; this.fetchReviewWords(); this.fetchStats() } } catch(e) { this.$message.error('提交失败') } }\n  }\n}\n</script>\n<style scoped>\n.words-page { padding:20px; max-width:1200px; margin:0 auto; }\n.page-header { margin-bottom:20px; } .page-header h1 { font-size:24px; margin-bottom:8px; } .page-header p { color:#909399; }\n.stats-row { display:flex; gap:16px; margin-bottom:20px; } .stat-card { flex:1; text-align:center; } .stat-val { font-size:32px; font-weight:700; } .stat-label { color:#909399; margin-top:8px; }\n.review-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }\n.word-flashcard { perspective:1000px; width:100%; max-width:500px; height:280px; margin:0 auto 24px; cursor:pointer; }\n.card-inner { position:relative; width:100%; height:100%; transition:transform 0.6s; transform-style:preserve-3d; }\n.card-inner.flipped { transform:rotateY(180deg); }\n.card-front, .card-back { position:absolute; width:100%; height:100%; backface-visibility:hidden; border-radius:12px; display:flex; flex-direction:column; justify-content:center; align-items:center; padding:24px; box-shadow:0 4px 16px rgba(0,0,0,0.1); }\n.card-front { background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; }\n.card-back { background:#fff; border:2px solid #667eea; transform:rotateY(180deg); } .card-back h2 { color:#333; }\n.card-front h2 { font-size:36px; } .phonetic { opacity:0.8; margin-top:8px; } .hint { font-size:12px; opacity:0.6; margin-top:16px; }\n.example { color:#666; margin-top:12px; font-size:14px; text-align:center; } .example-trans { color:#999; font-size:13px; margin-top:4px; }\n.review-actions { display:flex; justify-content:center; gap:16px; margin-bottom:16px; }\n.review-progress { max-width:500px; margin:0 auto; }\n.empty-state { text-align:center; padding:60px 0; color:#909399; } .empty-state i { font-size:48px; display:block; margin-bottom:12px; }\n</style>\n"],"mappings":"AAgCA;EACAA,IAAA;EACAC,KAAA;IAAA;MAAAC,KAAA;MAAAC,WAAA;MAAAC,SAAA;MAAAC,QAAA;MAAAC,WAAA;MAAAC,QAAA;MAAAC,IAAA;MAAAC,IAAA;MAAAC,KAAA;IAAA;EAAA;EACAC,QAAA;IACAC,eAAA;MAAA,YAAAT,WAAA,CAAAU,MAAA,GAAAC,IAAA,CAAAC,KAAA,MAAAT,WAAA,QAAAH,WAAA,CAAAU,MAAA;IAAA;IACAG,YAAA;MAAA,YAAAb,WAAA,MAAAG,WAAA;IAAA;EACA;EACAW,QAAA;IAAA,KAAAC,UAAA;IAAA,KAAAC,gBAAA;IAAA,KAAAC,aAAA;EAAA;EACAC,OAAA;IACA,MAAAH,WAAA;MAAA;QAAA,KAAAhB,KAAA,eAAAoB,KAAA,CAAAC,GAAA;MAAA,SAAAC,CAAA;IAAA;IACA,MAAAL,iBAAA;MAAA;QAAA,KAAAhB,WAAA,eAAAmB,KAAA,CAAAC,GAAA;UAAAE,MAAA;YAAAC,KAAA;UAAA;QAAA;MAAA,SAAAF,CAAA;IAAA;IACA,MAAAJ,cAAA;MAAA;QAAA,MAAAO,GAAA,cAAAL,KAAA,CAAAC,GAAA;UAAAE,MAAA;YAAAjB,IAAA,OAAAA,IAAA;YAAAC,IAAA,OAAAA;UAAA;QAAA;QAAA,KAAAF,QAAA,GAAAoB,GAAA,EAAAC,OAAA;QAAA,KAAAlB,KAAA,GAAAiB,GAAA,EAAAjB,KAAA;MAAA,SAAAc,CAAA;IAAA;IACAK,WAAAC,CAAA;MAAA,KAAAtB,IAAA,GAAAsB,CAAA;MAAA,KAAAV,aAAA;IAAA;IACAW,YAAA;MAAA,KAAA3B,SAAA;MAAA,KAAAE,WAAA;MAAA,KAAAD,QAAA;IAAA;IACA,MAAA2B,OAAAC,SAAA,EAAAC,KAAA;MAAA;QAAA,WAAAZ,KAAA,CAAAa,IAAA;UAAAC,MAAA,OAAApB,WAAA,CAAAoB,MAAA;UAAAH,SAAA;UAAAC;QAAA;QAAA,KAAA5B,WAAA;QAAA,KAAAD,QAAA;QA