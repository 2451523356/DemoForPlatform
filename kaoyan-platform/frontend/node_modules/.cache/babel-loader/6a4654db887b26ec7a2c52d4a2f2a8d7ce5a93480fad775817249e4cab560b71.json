{"ast":null,"code":"export default {\n  name: 'OrdersManage',\n  data() {\n    return {\n      searchOrderNo: '',\n      filterStatus: null,\n      orderList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0\n    };\n  },\n  created() {\n    this.getOrderList();\n  },\n  methods: {\n    getStatusName(status) {\n      const statusMap = {\n        0: '未支付',\n        1: '已支付',\n        2: '已退款'\n      };\n      return statusMap[status] || '未知';\n    },\n    getStatusTagType(status) {\n      const typeMap = {\n        0: 'info',\n        1: 'success',\n        2: 'warning'\n      };\n      return typeMap[status] || 'info';\n    },\n    search() {\n      this.currentPage = 1;\n      this.getOrderList();\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getOrderList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getOrderList();\n    },\n    async refundOrder(order) {\n      try {\n        await this.$confirm(`确定要退款订单 ${order.orderNo} 吗？`, '提示', {\n          type: 'warning'\n        });\n        await this.$http.put(`/admin/order/${order.id}/refund`);\n        this.$message.success('退款成功');\n        this.getOrderList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          if (error.response && error.response.data && error.response.data.message) {\n            this.$message.error(error.response.data.message);\n          } else {\n            console.error(error);\n          }\n        }\n      }\n    },\n    async getOrderList() {\n      try {\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize\n        };\n        if (this.searchOrderNo) {\n          params.orderNo = this.searchOrderNo;\n        }\n        if (this.filterStatus !== null && this.filterStatus !== '') {\n          params.status = this.filterStatus;\n        }\n        const res = await this.$http.get('/admin/orders', {\n          params\n        });\n        const responseData = res.data || res;\n        this.orderList = responseData?.records || [];\n        this.total = responseData?.total || 0;\n      } catch (error) {\n        console.error('获取订单列表失败:', error);\n        this.$message.error('获取订单列表失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchOrderNo","filterStatus","orderList","currentPage","pageSize","total","created","getOrderList","methods","getStatusName","status","statusMap","getStatusTagType","typeMap","search","handleSizeChange","size","handleCurrentChange","current","refundOrder","order","$confirm","orderNo","type","$http","put","id","$message","success","error","response","message","console","params","page","res","get","responseData","records"],"sources":["src/views/admin/Orders.vue"],"sourcesContent":["<template>\n  <div class=\"orders-manage\">\n    <el-card>\n      <div class=\"toolbar\">\n        <el-input\n          v-model=\"searchOrderNo\"\n          placeholder=\"搜索订单号\"\n          style=\"width: 250px\"\n          clearable\n          @keyup.enter.native=\"search\"\n        >\n          <i slot=\"prefix\" class=\"el-icon-search\"></i>\n        </el-input>\n        <el-select v-model=\"filterStatus\" placeholder=\"订单状态\" clearable style=\"width: 150px\" @change=\"search\">\n          <el-option label=\"未支付\" :value=\"0\"></el-option>\n          <el-option label=\"已支付\" :value=\"1\"></el-option>\n          <el-option label=\"已退款\" :value=\"2\"></el-option>\n        </el-select>\n        <el-button type=\"primary\" @click=\"search\">搜索</el-button>\n      </div>\n\n      <el-table :data=\"orderList\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"orderNo\" label=\"订单号\" width=\"200\"></el-table-column>\n        <el-table-column prop=\"userName\" label=\"用户\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.userName || '用户' + scope.row.userId }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"courseTitle\" label=\"课程\" min-width=\"150\" show-overflow-tooltip>\n          <template slot-scope=\"scope\">\n            {{ scope.row.courseTitle || '课程' + scope.row.courseId }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"amount\" label=\"金额\" width=\"100\">\n          <template slot-scope=\"scope\">\n            ¥{{ scope.row.amount }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"payType\" label=\"支付方式\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <span v-if=\"scope.row.payType === 1\">支付宝</span>\n            <span v-else-if=\"scope.row.payType === 2\">微信</span>\n            <span v-else>-</span>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"getStatusTagType(scope.row.status)\">\n              {{ getStatusName(scope.row.status) }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"payTime\" label=\"支付时间\" width=\"160\">\n          <template slot-scope=\"scope\">\n            {{ scope.row.payTime || '-' }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"160\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"160\">\n          <template>\n            <span class=\"text-muted\">请前往退款审核处理</span>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'OrdersManage',\n  data() {\n    return {\n      searchOrderNo: '',\n      filterStatus: null,\n      orderList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0\n    }\n  },\n  created() {\n    this.getOrderList()\n  },\n  methods: {\n    getStatusName(status) {\n      const statusMap = {\n        0: '未支付',\n        1: '已支付',\n        2: '已退款'\n      }\n      return statusMap[status] || '未知'\n    },\n    getStatusTagType(status) {\n      const typeMap = {\n        0: 'info',\n        1: 'success',\n        2: 'warning'\n      }\n      return typeMap[status] || 'info'\n    },\n    search() {\n      this.currentPage = 1\n      this.getOrderList()\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getOrderList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getOrderList()\n    },\n    async refundOrder(order) {\n      try {\n        await this.$confirm(`确定要退款订单 ${order.orderNo} 吗？`, '提示', {\n          type: 'warning'\n        })\n        await this.$http.put(`/admin/order/${order.id}/refund`)\n        this.$message.success('退款成功')\n        this.getOrderList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          if (error.response && error.response.data && error.response.data.message) {\n            this.$message.error(error.response.data.message)\n          } else {\n            console.error(error)\n          }\n        }\n      }\n    },\n    async getOrderList() {\n      try {\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize\n        }\n        if (this.searchOrderNo) {\n          params.orderNo = this.searchOrderNo\n        }\n        if (this.filterStatus !== null && this.filterStatus !== '') {\n          params.status = this.filterStatus\n        }\n\n        const res = await this.$http.get('/admin/orders', { params })\n        const responseData = res.data || res\n        this.orderList = responseData?.records || []\n        this.total = responseData?.total || 0\n      } catch (error) {\n        console.error('获取订单列表失败:', error)\n        this.$message.error('获取订单列表失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.orders-manage {\n  .toolbar {\n    display: flex;\n    gap: 10px;\n    margin-bottom: 20px;\n  }\n\n  .pagination {\n    margin-top: 20px;\n    text-align: center;\n  }\n\n  .text-muted {\n    color: #909399;\n  }\n}\n</style>\n"],"mappings":"AAkFA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,aAAA;MACAC,YAAA;MACAC,SAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,cAAAC,MAAA;MACA,MAAAC,SAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,SAAA,CAAAD,MAAA;IACA;IACAE,iBAAAF,MAAA;MACA,MAAAG,OAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,OAAA,CAAAH,MAAA;IACA;IACAI,OAAA;MACA,KAAAX,WAAA;MACA,KAAAI,YAAA;IACA;IACAQ,iBAAAC,IAAA;MACA,KAAAZ,QAAA,GAAAY,IAAA;MACA,KAAAT,YAAA;IACA;IACAU,oBAAAC,OAAA;MACA,KAAAf,WAAA,GAAAe,OAAA;MACA,KAAAX,YAAA;IACA;IACA,MAAAY,YAAAC,KAAA;MACA;QACA,WAAAC,QAAA,YAAAD,KAAA,CAAAE,OAAA;UACAC,IAAA;QACA;QACA,WAAAC,KAAA,CAAAC,GAAA,iBAAAL,KAAA,CAAAM,EAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,KAAArB,YAAA;MACA,SAAAsB,KAAA;QACA,IAAAA,KAAA;UACA,IAAAA,KAAA,CAAAC,QAAA,IAAAD,KAAA,CAAAC,QAAA,CAAA/B,IAAA,IAAA8B,KAAA,CAAAC,QAAA,CAAA/B,IAAA,CAAAgC,OAAA;YACA,KAAAJ,QAAA,CAAAE,KAAA,CAAAA,KAAA,CAAAC,QAAA,CAAA/B,IAAA,CAAAgC,OAAA;UACA;YACAC,OAAA,CAAAH,KAAA,CAAAA,KAAA;UACA;QACA;MACA;IACA;IACA,MAAAtB,aAAA;MACA;QACA,MAAA0B,MAAA;UACAC,IAAA,OAAA/B,WAAA;UACAa,IAAA,OAAAZ;QACA;QACA,SAAAJ,aAAA;UACAiC,MAAA,CAAAX,OAAA,QAAAtB,aAAA;QACA;QACA,SAAAC,YAAA,kBAAAA,YAAA;UACAgC,MAAA,CAAAvB,MAAA,QAAAT,YAAA;QACA;QAEA,MAAAkC,GAAA,cAAAX,KAAA,CAAAY,GAAA;UAAAH;QAAA;QACA,MAAAI,YAAA,GAAAF,GAAA,CAAApC,IAAA,IAAAoC,GAAA;QACA,KAAAjC,SAAA,GAAAmC,YAAA,EAAAC,OAAA;QACA,KAAAjC,KAAA,GAAAgC,YAAA,EAAAhC,KAAA;MACA,SAAAwB,KAAA;QACAG,OAAA,CAAAH,KAAA,cAAAA,KAAA;QACA,KAAAF,QAA