{"ast":null,"code":"import { quillEditor } from 'vue-quill-editor';\nimport 'quill/dist/quill.core.css';\nimport 'quill/dist/quill.snow.css';\nimport 'quill/dist/quill.bubble.css';\nexport default {\n  name: 'NewsManage',\n  components: {\n    quillEditor\n  },\n  data() {\n    return {\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      isEdit: false,\n      newsForm: {\n        id: 0,\n        title: '',\n        category: '',\n        examStage: '',\n        cover: '',\n        summary: '',\n        content: '',\n        status: 1\n      },\n      newsRules: {\n        title: [{\n          required: true,\n          message: '请输入标题',\n          trigger: 'blur'\n        }],\n        category: [{\n          required: true,\n          message: '请选择分类',\n          trigger: 'change'\n        }],\n        content: [{\n          required: true,\n          message: '请输入内容',\n          trigger: 'blur'\n        }]\n      },\n      editorOption: {\n        // Some Quill options...\n        modules: {\n          toolbar: [['bold', 'italic', 'underline', 'strike'], ['blockquote', 'code-block'], [{\n            'header': 1\n          }, {\n            'header': 2\n          }], [{\n            'list': 'ordered'\n          }, {\n            'list': 'bullet'\n          }], [{\n            'script': 'sub'\n          }, {\n            'script': 'super'\n          }], [{\n            'indent': '-1'\n          }, {\n            'indent': '+1'\n          }], [{\n            'direction': 'rtl'\n          }], [{\n            'size': ['small', false, 'large', 'huge']\n          }], [{\n            'header': [1, 2, 3, 4, 5, 6, false]\n          }], [{\n            'color': []\n          }, {\n            'background': []\n          }], [{\n            'font': []\n          }], [{\n            'align': []\n          }], ['link', 'image', 'video'], ['clean']]\n        }\n      }\n    };\n  },\n  created() {\n    this.getNewsList();\n  },\n  methods: {\n    showAddDialog() {\n      this.isEdit = false;\n      this.newsForm = {\n        id: 0,\n        title: '',\n        category: '',\n        cover: '',\n        summary: '',\n        content: '',\n        status: 1\n      };\n      this.dialogVisible = true;\n    },\n    editNews(news) {\n      this.isEdit = true;\n      this.newsForm = {\n        ...news\n      };\n      this.dialogVisible = true;\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getNewsList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getNewsList();\n    },\n    async toggleTop(news) {\n      try {\n        await this.$http.put(`/api/admin/news/${news.id}`, {\n          ...news,\n          isTop: news.isTop ? 0 : 1\n        });\n        this.$message.success('操作成功');\n        this.getNewsList();\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    async deleteNews(news) {\n      try {\n        await this.$confirm('确定要删除该资讯吗？', '提示', {\n          type: 'warning'\n        });\n        await this.$http.delete(`/api/admin/news/${news.id}`);\n        this.$message.success('删除成功');\n        this.getNewsList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error);\n        }\n      }\n    },\n    saveNews() {\n      this.$refs.newsForm.validate(async valid => {\n        if (valid) {\n          try {\n            if (this.isEdit) {\n              await this.$http.put(`/api/admin/news/${this.newsForm.id}`, this.newsForm);\n            } else {\n              await this.$http.post('/admin/news', this.newsForm);\n            }\n            this.$message.success('保存成功');\n            this.dialogVisible = false;\n            this.getNewsList();\n          } catch (error) {\n            console.error(error);\n          }\n        }\n      });\n    },\n    async getNewsList() {\n      try {\n        const res = await this.$http.get('/admin/news', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        });\n        const responseData = res.data || res;\n        this.newsList = responseData?.records || [];\n        this.total = responseData?.total || 0;\n      } catch (error) {\n        console.error('获取资讯列表失败:', error);\n        this.$message.error('获取资讯列表失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["quillEditor","name","components","data","newsList","currentPage","pageSize","total","dialogVisible","isEdit","newsForm","id","title","category","examStage","cover","summary","content","status","newsRules","required","message","trigger","editorOption","modules","toolbar","created","getNewsList","methods","showAddDialog","editNews","news","handleSizeChange","size","handleCurrentChange","current","toggleTop","$http","put","isTop","$message","success","error","console","deleteNews","$confirm","type","delete","saveNews","$refs","validate","valid","post","res","get","params","page","responseData","records"],"sources":["src/views/admin/News.vue"],"sourcesContent":["<template>\n  <div class=\"news-manage\">\n    <el-card>\n      <div class=\"toolbar\">\n        <el-button type=\"primary\" @click=\"showAddDialog\">\n          <i class=\"el-icon-plus\"></i> 新增资讯\n        </el-button>\n      </div>\n\n      <el-table :data=\"newsList\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"title\" label=\"标题\"></el-table-column>\n        <el-table-column prop=\"category\" label=\"分类\"></el-table-column>\n        <el-table-column prop=\"viewCount\" label=\"浏览量\"></el-table-column>\n        <el-table-column prop=\"isTop\" label=\"置顶\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.isTop ? 'danger' : 'info'\">\n              {{ scope.row.isTop ? '是' : '否' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'info'\">\n              {{ scope.row.status === 1 ? '已发布' : '草稿' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"250\">\n          <template slot-scope=\"scope\">\n            <el-button size=\"mini\" @click=\"editNews(scope.row)\">编辑</el-button>\n            <el-button\n              size=\"mini\"\n              :type=\"scope.row.isTop ? 'warning' : 'success'\"\n              @click=\"toggleTop(scope.row)\"\n            >\n              {{ scope.row.isTop ? '取消置顶' : '置顶' }}\n            </el-button>\n            <el-button size=\"mini\" type=\"danger\" @click=\"deleteNews(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n\n    <el-dialog :title=\"isEdit ? '编辑资讯' : '新增资讯'\" :visible.sync=\"dialogVisible\" width=\"800px\">\n      <el-form ref=\"newsForm\" :model=\"newsForm\" :rules=\"newsRules\" label-width=\"80px\">\n        <el-form-item label=\"标题\" prop=\"title\">\n          <el-input v-model=\"newsForm.title\" placeholder=\"请输入标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"分类\" prop=\"category\">\n          <el-select v-model=\"newsForm.category\" placeholder=\"选择分类\">\n            <el-option label=\"报考信息\" value=\"报考信息\"></el-option>\n            <el-option label=\"招生简章\" value=\"招生简章\"></el-option>\n            <el-option label=\"备考指南\" value=\"备考指南\"></el-option>\n            <el-option label=\"经验分享\" value=\"经验分享\"></el-option>\n            <el-option label=\"政策解读\" value=\"政策解读\"></el-option>\n            <el-option label=\"院校动态\" value=\"院校动态\"></el-option>\n            <el-option label=\"复试调剂\" value=\"复试调剂\"></el-option>\n            <el-option label=\"大纲变化\" value=\"大纲变化\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"备考阶段\">\n          <el-select v-model=\"newsForm.examStage\" placeholder=\"选择备考阶段\" clearable>\n            <el-option label=\"择校评估\" value=\"择校评估\"></el-option>\n            <el-option label=\"基础复习\" value=\"基础复习\"></el-option>\n            <el-option label=\"强化提升\" value=\"强化提升\"></el-option>\n            <el-option label=\"报名报考\" value=\"报名报考\"></el-option>\n            <el-option label=\"冲刺模考\" value=\"冲刺模考\"></el-option>\n            <el-option label=\"复试准备\" value=\"复试准备\"></el-option>\n            <el-option label=\"调剂录取\" value=\"调剂录取\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"封面\" prop=\"cover\">\n          <el-input v-model=\"newsForm.cover\" placeholder=\"请输入封面URL\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"摘要\" prop=\"summary\">\n          <el-input v-model=\"newsForm.summary\" type=\"textarea\" :rows=\"2\" placeholder=\"请输入摘要\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"内容\" prop=\"content\">\n          <quill-editor v-model=\"newsForm.content\" :options=\"editorOption\"></quill-editor>\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-radio-group v-model=\"newsForm.status\">\n            <el-radio :label=\"1\">发布</el-radio>\n            <el-radio :label=\"0\">草稿</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveNews\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { quillEditor } from 'vue-quill-editor'\nimport 'quill/dist/quill.core.css'\nimport 'quill/dist/quill.snow.css'\nimport 'quill/dist/quill.bubble.css'\n\nexport default {\n  name: 'NewsManage',\n  components: {\n    quillEditor\n  },\n  data() {\n    return {\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      isEdit: false,\n      newsForm: {\n        id: 0,\n        title: '',\n        category: '',\n        examStage: '',\n        cover: '',\n        summary: '',\n        content: '',\n        status: 1\n      },\n      newsRules: {\n        title: [\n          { required: true, message: '请输入标题', trigger: 'blur' }\n        ],\n        category: [\n          { required: true, message: '请选择分类', trigger: 'change' }\n        ],\n        content: [\n          { required: true, message: '请输入内容', trigger: 'blur' }\n        ]\n      },\n      editorOption: {\n        // Some Quill options...\n        modules: {\n          toolbar: [\n            ['bold', 'italic', 'underline', 'strike'],\n            ['blockquote', 'code-block'],\n            [{ 'header': 1 }, { 'header': 2 }],\n            [{ 'list': 'ordered' }, { 'list': 'bullet' }],\n            [{ 'script': 'sub' }, { 'script': 'super' }],\n            [{ 'indent': '-1' }, { 'indent': '+1' }],\n            [{ 'direction': 'rtl' }],\n            [{ 'size': ['small', false, 'large', 'huge'] }],\n            [{ 'header': [1, 2, 3, 4, 5, 6, false] }],\n            [{ 'color': [] }, { 'background': [] }],\n            [{ 'font': [] }],\n            [{ 'align': [] }],\n            ['link', 'image', 'video'],\n            ['clean']\n          ]\n        }\n      }\n    }\n  },\n  created() {\n    this.getNewsList()\n  },\n  methods: {\n    showAddDialog() {\n      this.isEdit = false\n      this.newsForm = {\n        id: 0,\n        title: '',\n        category: '',\n        cover: '',\n        summary: '',\n        content: '',\n        status: 1\n      }\n      this.dialogVisible = true\n    },\n    editNews(news) {\n      this.isEdit = true\n      this.newsForm = { ...news }\n      this.dialogVisible = true\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getNewsList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getNewsList()\n    },\n    async toggleTop(news) {\n      try {\n        await this.$http.put(`/api/admin/news/${news.id}`, { ...news, isTop: news.isTop ? 0 : 1 })\n        this.$message.success('操作成功')\n        this.getNewsList()\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    async deleteNews(news) {\n      try {\n        await this.$confirm('确定要删除该资讯吗？', '提示', {\n          type: 'warning'\n        })\n        await this.$http.delete(`/api/admin/news/${news.id}`)\n        this.$message.success('删除成功')\n        this.getNewsList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error)\n        }\n      }\n    },\n    saveNews() {\n      this.$refs.newsForm.validate(async (valid) => {\n        if (valid) {\n          try {\n            if (this.isEdit) {\n              await this.$http.put(`/api/admin/news/${this.newsForm.id}`, this.newsForm)\n            } else {\n              await this.$http.post('/admin/news', this.newsForm)\n            }\n            this.$message.success('保存成功')\n            this.dialogVisible = false\n            this.getNewsList()\n          } catch (error) {\n            console.error(error)\n          }\n        }\n      })\n    },\n    async getNewsList() {\n      try {\n        const res = await this.$http.get('/admin/news', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        })\n        const responseData = res.data || res\n        this.newsList = responseData?.records || []\n        this.total = responseData?.total || 0\n      } catch (error) {\n        console.error('获取资讯列表失败:', error)\n        this.$message.error('获取资讯列表失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.news-manage {\n  .toolbar {\n    margin-bottom: 20px;\n  }\n\n  .pagination {\n    margin-top: 20px;\n    text-align: center;\n  }\n}\n</style>\n"],"mappings":"AA8GA,SAAAA,WAAA;AACA;AACA;AACA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,QAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,aAAA;MACAC,MAAA;MACAC,QAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,SAAA;QACAC,KAAA;QACAC,OAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACAC,SAAA;QACAP,KAAA,GACA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAT,QAAA,GACA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAL,OAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;MACAC,YAAA;QACA;QACAC,OAAA;UACAC,OAAA,GACA,2CACA,8BACA;YAAA;UAAA;YAAA;UAAA,IACA;YAAA;UAAA;YAAA;UAAA,IACA;YAAA;UAAA;YAAA;UAAA,IACA;YAAA;UAAA;YAAA;UAAA,IACA;YAAA;UAAA,IACA;YAAA;UAAA,IACA;YAAA;UAAA,IACA;YAAA;UAAA;YAAA;UAAA,IACA;YAAA;UAAA,IACA;YAAA;UAAA,IACA,4BACA;QAEA;MACA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAC,cAAA;MACA,KAAApB,MAAA;MACA,KAAAC,QAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAE,KAAA;QACAC,OAAA;QACAC,OAAA;QACAC,MAAA;MACA;MACA,KAAAV,aAAA;IACA;IACAsB,SAAAC,IAAA;MACA,KAAAtB,MAAA;MACA,KAAAC,QAAA;QAAA,GAAAqB;MAAA;MACA,KAAAvB,aAAA;IACA;IACAwB,iBAAAC,IAAA;MACA,KAAA3B,QAAA,GAAA2B,IAAA;MACA,KAAAN,WAAA;IACA;IACAO,oBAAAC,OAAA;MACA,KAAA9B,WAAA,GAAA8B,OAAA;MACA,KAAAR,WAAA;IACA;IACA,MAAAS,UAAAL,IAAA;MACA;QACA,WAAAM,KAAA,CAAAC,GAAA,oBAAAP,IAAA,CAAApB,EAAA;UAAA,GAAAoB,IAAA;UAAAQ,KAAA,EAAAR,IAAA,CAAAQ,KAAA;QAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA,KAAAd,WAAA;MACA,SAAAe,KAAA;QACAC,OAAA,CAAAD,KAAA,CAAAA,KAAA;MACA;IACA;IACA,MAAAE,WAAAb,IAAA;MACA;QACA,WAAAc,QAAA;UACAC,IAAA;QACA;QACA,WAAAT,KAAA,CAAAU,MAAA,oBAAAhB,IAAA,CAAApB,EAAA;QACA,KAAA6B,QAAA,CAAAC,OAAA;QACA,KAAAd,WAAA;MACA,SAAAe,