{"ast":null,"code":"export default {\n  name: 'ResourcesManage',\n  data() {\n    return {\n      resourceList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      isEdit: false,\n      resourceForm: {\n        id: 0,\n        title: '',\n        category: '',\n        subject: '',\n        fileUrl: '',\n        fileSize: 0,\n        points: 0,\n        description: ''\n      },\n      resourceRules: {\n        title: [{\n          required: true,\n          message: '请输入标题',\n          trigger: 'blur'\n        }],\n        category: [{\n          required: true,\n          message: '请选择分类',\n          trigger: 'change'\n        }],\n        subject: [{\n          required: true,\n          message: '请选择学科',\n          trigger: 'change'\n        }],\n        fileUrl: [{\n          required: true,\n          message: '请输入文件URL',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  created() {\n    this.getResourceList();\n  },\n  methods: {\n    formatFileSize(size) {\n      if (size < 1024) return size + ' B';\n      if (size < 1024 * 1024) return (size / 1024).toFixed(2) + ' KB';\n      return (size / (1024 * 1024)).toFixed(2) + ' MB';\n    },\n    showAddDialog() {\n      this.isEdit = false;\n      this.resourceForm = {\n        id: 0,\n        title: '',\n        category: '',\n        subject: '',\n        fileUrl: '',\n        fileSize: 0,\n        points: 0,\n        description: ''\n      };\n      this.dialogVisible = true;\n    },\n    editResource(resource) {\n      this.isEdit = true;\n      this.resourceForm = {\n        ...resource\n      };\n      this.dialogVisible = true;\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getResourceList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getResourceList();\n    },\n    async deleteResource(resource) {\n      try {\n        await this.$confirm('确定要删除该资源吗？', '提示', {\n          type: 'warning'\n        });\n        await this.$http.delete(`/admin/resource/${resource.id}`);\n        this.$message.success('删除成功');\n        this.getResourceList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error);\n        }\n      }\n    },\n    async approveResource(resource) {\n      try {\n        await this.$http.put(`/admin/resource/approve/${resource.id}`);\n        this.$message.success('审核通过');\n        this.getResourceList();\n      } catch (error) {\n        console.error('审核失败:', error);\n        this.$message.error('审核失败，请稍后重试');\n      }\n    },\n    saveResource() {\n      this.$refs.resourceForm.validate(async valid => {\n        if (valid) {\n          try {\n            if (this.isEdit) {\n              await this.$http.put(`/admin/resource/${this.resourceForm.id}`, this.resourceForm);\n            } else {\n              await this.$http.post('/admin/resource', this.resourceForm);\n            }\n            this.$message.success('保存成功');\n            this.dialogVisible = false;\n            this.getResourceList();\n          } catch (error) {\n            console.error(error);\n          }\n        }\n      });\n    },\n    async getResourceList() {\n      try {\n        const res = await this.$http.get('/admin/resources', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        });\n        const responseData = res.data || res;\n        this.resourceList = responseData?.records || [];\n        this.total = responseData?.total || 0;\n      } catch (error) {\n        console.error(error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","resourceList","currentPage","pageSize","total","dialogVisible","isEdit","resourceForm","id","title","category","subject","fileUrl","fileSize","points","description","resourceRules","required","message","trigger","created","getResourceList","methods","formatFileSize","size","toFixed","showAddDialog","editResource","resource","handleSizeChange","handleCurrentChange","current","deleteResource","$confirm","type","$http","delete","$message","success","error","console","approveResource","put","saveResource","$refs","validate","valid","post","res","get","params","page","responseData","records"],"sources":["src/views/admin/Resources.vue"],"sourcesContent":["<template>\n  <div class=\"resources-manage\">\n    <el-card>\n      <div class=\"toolbar\">\n        <el-button type=\"primary\" @click=\"showAddDialog\">\n          <i class=\"el-icon-plus\"></i> 新增资源\n        </el-button>\n      </div>\n\n      <el-table :data=\"resourceList\" style=\"width: 100%\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"title\" label=\"标题\"></el-table-column>\n        <el-table-column prop=\"category\" label=\"分类\"></el-table-column>\n        <el-table-column prop=\"subject\" label=\"学科\"></el-table-column>\n        <el-table-column prop=\"fileSize\" label=\"大小\">\n          <template slot-scope=\"scope\">\n            {{ formatFileSize(scope.row.fileSize) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"downloadCount\" label=\"下载量\"></el-table-column>\n        <el-table-column prop=\"points\" label=\"积分\"></el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'info'\">\n              {{ scope.row.status === 1 ? '已审核' : '待审核' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"250\">\n          <template slot-scope=\"scope\">\n            <el-button v-if=\"scope.row.status === 'pending'\" size=\"mini\" type=\"success\" @click=\"approveResource(scope.row)\">审核通过</el-button>\n            <el-button size=\"mini\" @click=\"editResource(scope.row)\">编辑</el-button>\n            <el-button size=\"mini\" type=\"danger\" @click=\"deleteResource(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n\n    <el-dialog :title=\"isEdit ? '编辑资源' : '新增资源'\" :visible.sync=\"dialogVisible\" width=\"600px\">\n      <el-form ref=\"resourceForm\" :model=\"resourceForm\" :rules=\"resourceRules\" label-width=\"80px\">\n        <el-form-item label=\"标题\" prop=\"title\">\n          <el-input v-model=\"resourceForm.title\" placeholder=\"请输入标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"资源类型\" prop=\"category\">\n          <el-select v-model=\"resourceForm.category\" placeholder=\"选择类型\">\n            <el-option-group label=\"真题资料\">\n              <el-option label=\"历年真题\" value=\"历年真题\"></el-option>\n              <el-option label=\"真题解析\" value=\"真题解析\"></el-option>\n              <el-option label=\"模拟试题\" value=\"模拟试题\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"学习笔记\">\n              <el-option label=\"复习笔记\" value=\"复习笔记\"></el-option>\n              <el-option label=\"课程讲义\" value=\"课程讲义\"></el-option>\n              <el-option label=\"学霸笔记\" value=\"学霸笔记\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"总结归纳\">\n              <el-option label=\"思维导图\" value=\"思维导图\"></el-option>\n              <el-option label=\"公式手册\" value=\"公式手册\"></el-option>\n              <el-option label=\"词汇手册\" value=\"词汇手册\"></el-option>\n              <el-option label=\"知识点总结\" value=\"知识点总结\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"备考模板\">\n              <el-option label=\"作文模板\" value=\"作文模板\"></el-option>\n              <el-option label=\"答题模板\" value=\"答题模板\"></el-option>\n              <el-option label=\"背诵提纲\" value=\"背诵提纲\"></el-option>\n            </el-option-group>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"科目\" prop=\"subject\">\n          <el-select v-model=\"resourceForm.subject\" placeholder=\"选择科目\">\n            <el-option-group label=\"公共课\">\n              <el-option label=\"数学\" value=\"数学\"></el-option>\n              <el-option label=\"英语\" value=\"英语\"></el-option>\n              <el-option label=\"政治\" value=\"政治\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"统考专业课\">\n              <el-option label=\"计算机（408）\" value=\"计算机408\"></el-option>\n              <el-option label=\"金融学（431）\" value=\"金融学431\"></el-option>\n              <el-option label=\"法学\" value=\"法学\"></el-option>\n              <el-option label=\"教育学\" value=\"教育学\"></el-option>\n              <el-option label=\"心理学\" value=\"心理学\"></el-option>\n              <el-option label=\"医学\" value=\"医学\"></el-option>\n              <el-option label=\"管理学\" value=\"管理学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"其他专业课\">\n              <el-option label=\"经济学\" value=\"经济学\"></el-option>\n              <el-option label=\"文学\" value=\"文学\"></el-option>\n              <el-option label=\"机械\" value=\"机械\"></el-option>\n              <el-option label=\"电气\" value=\"电气\"></el-option>\n              <el-option label=\"其他\" value=\"其他\"></el-option>\n            </el-option-group>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"文件URL\" prop=\"fileUrl\">\n          <el-input v-model=\"resourceForm.fileUrl\" placeholder=\"请输入文件URL\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"文件大小\" prop=\"fileSize\">\n          <el-input-number v-model=\"resourceForm.fileSize\" :min=\"0\"></el-input-number>\n          <span style=\"margin-left: 10px\">字节</span>\n        </el-form-item>\n        <el-form-item label=\"积分\" prop=\"points\">\n          <el-input-number v-model=\"resourceForm.points\" :min=\"0\"></el-input-number>\n        </el-form-item>\n        <el-form-item label=\"描述\" prop=\"description\">\n          <el-input v-model=\"resourceForm.description\" type=\"textarea\" :rows=\"3\" placeholder=\"请输入描述\"></el-input>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveResource\">保存</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ResourcesManage',\n  data() {\n    return {\n      resourceList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      dialogVisible: false,\n      isEdit: false,\n      resourceForm: {\n        id: 0,\n        title: '',\n        category: '',\n        subject: '',\n        fileUrl: '',\n        fileSize: 0,\n        points: 0,\n        description: ''\n      },\n      resourceRules: {\n        title: [\n          { required: true, message: '请输入标题', trigger: 'blur' }\n        ],\n        category: [\n          { required: true, message: '请选择分类', trigger: 'change' }\n        ],\n        subject: [\n          { required: true, message: '请选择学科', trigger: 'change' }\n        ],\n        fileUrl: [\n          { required: true, message: '请输入文件URL', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  created() {\n    this.getResourceList()\n  },\n  methods: {\n    formatFileSize(size) {\n      if (size < 1024) return size + ' B'\n      if (size < 1024 * 1024) return (size / 1024).toFixed(2) + ' KB'\n      return (size / (1024 * 1024)).toFixed(2) + ' MB'\n    },\n    showAddDialog() {\n      this.isEdit = false\n      this.resourceForm = {\n        id: 0,\n        title: '',\n        category: '',\n        subject: '',\n        fileUrl: '',\n        fileSize: 0,\n        points: 0,\n        description: ''\n      }\n      this.dialogVisible = true\n    },\n    editResource(resource) {\n      this.isEdit = true\n      this.resourceForm = { ...resource }\n      this.dialogVisible = true\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getResourceList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getResourceList()\n    },\n    async deleteResource(resource) {\n      try {\n        await this.$confirm('确定要删除该资源吗？', '提示', {\n          type: 'warning'\n        })\n        await this.$http.delete(`/admin/resource/${resource.id}`)\n        this.$message.success('删除成功')\n        this.getResourceList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error)\n        }\n      }\n    },\n    async approveResource(resource) {\n      try {\n        await this.$http.put(`/admin/resource/approve/${resource.id}`)\n        this.$message.success('审核通过')\n        this.getResourceList()\n      } catch (error) {\n        console.error('审核失败:', error)\n        this.$message.error('审核失败，请稍后重试')\n      }\n    },\n    saveResource() {\n      this.$refs.resourceForm.validate(async (valid) => {\n        if (valid) {\n          try {\n            if (this.isEdit) {\n              await this.$http.put(`/admin/resource/${this.resourceForm.id}`, this.resourceForm)\n            } else {\n              await this.$http.post('/admin/resource', this.resourceForm)\n            }\n            this.$message.success('保存成功')\n            this.dialogVisible = false\n            this.getResourceList()\n          } catch (error) {\n            console.error(error)\n          }\n        }\n      })\n    },\n    async getResourceList() {\n      try {\n        const res = await this.$http.get('/admin/resources', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        })\n        const responseData = res.data || res\n        this.resourceList = responseData?.records || []\n        this.total = responseData?.total || 0\n      } catch (error) {\n        console.error(error)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.resources-manage {\n  .toolbar {\n    margin-bottom: 20px;\n  }\n\n  .pagination {\n    margin-top: 20px;\n    text-align: center;\n  }\n}\n</style>\n"],"mappings":"AAiIA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,YAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,aAAA;MACAC,MAAA;MACAC,YAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,OAAA;QACAC,OAAA;QACAC,QAAA;QACAC,MAAA;QACAC,WAAA;MACA;MACAC,aAAA;QACAP,KAAA,GACA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAT,QAAA,GACA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAR,OAAA,GACA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAP,OAAA,GACA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,eAAA;EACA;EACAC,OAAA;IACAC,eAAAC,IAAA;MACA,IAAAA,IAAA,gBAAAA,IAAA;MACA,IAAAA,IAAA,wBAAAA,IAAA,SAAAC,OAAA;MACA,QAAAD,IAAA,kBAAAC,OAAA;IACA;IACAC,cAAA;MACA,KAAApB,MAAA;MACA,KAAAC,YAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,OAAA;QACAC,OAAA;QACAC,QAAA;QACAC,MAAA;QACAC,WAAA;MACA;MACA,KAAAV,aAAA;IACA;IACAsB,aAAAC,QAAA;MACA,KAAAtB,MAAA;MACA,KAAAC,YAAA;QAAA,GAAAqB;MAAA;MACA,KAAAvB,aAAA;IACA;IACAwB,iBAAAL,IAAA;MACA,KAAArB,QAAA,GAAAqB,IAAA;MACA,KAAAH,eAAA;IACA;IACAS,oBAAAC,OAAA;MACA,KAAA7B,WAAA,GAAA6B,OAAA;MACA,KAAAV,eAAA;IACA;IACA,MAAAW,eAAAJ,QAAA;MACA;QACA,WAAAK,QAAA;UACAC,IAAA;QACA;QACA,WAAAC,KAAA,CAAAC,MAAA,oBAAAR,QAAA,CAAApB,EAAA;QACA,KAAA6B,QAAA,CAAAC,OAAA;QACA,KAAAjB,eAAA;MACA,SAAAkB,KAAA;QACA,IAAAA,KAAA;UACAC,OAAA,CAAAD,KAAA,CAAAA,KAAA;QACA;MACA;IACA;IACA,MAAAE,gBAAAb,QAAA;MACA;QACA,WAAAO,KAAA,CAAAO,GAAA,4BAAAd,QAAA,CAAApB,EAAA;QACA,KAAA6B,QAAA,CAAAC,OAAA;QACA,KAAAjB,eAAA;MACA,SAAAkB,KAAA;QA