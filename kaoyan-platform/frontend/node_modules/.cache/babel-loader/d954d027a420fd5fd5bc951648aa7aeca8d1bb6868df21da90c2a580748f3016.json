{"ast":null,"code":"export default {\n  name: 'DailyCheckin',\n  data() {\n    return {\n      checkinLoading: false,\n      checkinStatus: {\n        checkedInToday: false,\n        streakCount: 0,\n        totalCheckins: 0,\n        totalPointsEarned: 0\n      },\n      streakInfo: {\n        currentStreak: 0,\n        longestStreak: 0,\n        nextMilestone: null,\n        checkinHistory: []\n      },\n      leaderboard: [],\n      calendar: {\n        year: new Date().getFullYear(),\n        month: new Date().getMonth() + 1,\n        days: [],\n        totalCheckinsThisMonth: 0\n      },\n      weekdayLabels: ['一', '二', '三', '四', '五', '六', '日']\n    };\n  },\n  computed: {\n    nextMilestonePercent() {\n      if (!this.streakInfo.nextMilestone) return 0;\n      const m = this.streakInfo.nextMilestone;\n      if (m.daysNeeded === 0) return 100;\n      const target = this.streakInfo.currentStreak + m.daysNeeded;\n      return Math.round(this.streakInfo.currentStreak / target * 100);\n    }\n  },\n  mounted() {\n    this.loadAll();\n  },\n  methods: {\n    async loadAll() {\n      await Promise.all([this.fetchStatus(), this.fetchStreak(), this.fetchLeaderboard(), this.fetchCalendar()]);\n    },\n    async fetchStatus() {\n      try {\n        this.checkinStatus = (await this.$http.get('/checkin/status')) || {};\n      } catch (e) {}\n    },\n    async fetchStreak() {\n      try {\n        this.streakInfo = (await this.$http.get('/checkin/streak')) || {};\n      } catch (e) {}\n    },\n    async fetchLeaderboard() {\n      try {\n        const res = await this.$http.get('/checkin/leaderboard', {\n          params: {\n            limit: 20\n          }\n        });\n        this.leaderboard = res || [];\n      } catch (e) {}\n    },\n    async fetchCalendar() {\n      try {\n        this.calendar = (await this.$http.get('/checkin/calendar', {\n          params: {\n            year: this.calendar.year,\n            month: this.calendar.month\n          }\n        })) || {};\n      } catch (e) {}\n    },\n    async doCheckin() {\n      this.checkinLoading = true;\n      try {\n        const res = await this.$http.post('/checkin');\n        if (res.alreadyCheckedIn) {\n          this.$message.info('今天已经打过卡了');\n        } else {\n          this.$message.success(`打卡成功！连续${res.streakCount}天 +${res.pointsEarned}积分${res.bonusPoints > 0 ? ` (含连续奖励+${res.bonusPoints})` : ''}`);\n        }\n        await this.loadAll();\n      } catch (e) {\n        this.$message.error('打卡失败');\n      }\n      this.checkinLoading = false;\n    },\n    prevMonth() {\n      if (this.calendar.month === 1) {\n        this.calendar.year--;\n        this.calendar.month = 12;\n      } else this.calendar.month--;\n      this.fetchCalendar();\n    },\n    nextMonth() {\n      if (this.calendar.month === 12) {\n        this.calendar.year++;\n        this.calendar.month = 1;\n      } else this.calendar.month++;\n      this.fetchCalendar();\n    }\n  }\n};","map":{"version":3,"names":["name","data","checkinLoading","checkinStatus","checkedInToday","streakCount","totalCheckins","totalPointsEarned","streakInfo","currentStreak","longestStreak","nextMilestone","checkinHistory","leaderboard","calendar","year","Date","getFullYear","month","getMonth","days","totalCheckinsThisMonth","weekdayLabels","computed","nextMilestonePercent","m","daysNeeded","target","Math","round","mounted","loadAll","methods","Promise","all","fetchStatus","fetchStreak","fetchLeaderboard","fetchCalendar","$http","get","e","res","params","limit","doCheckin","post","alreadyCheckedIn","$message","info","success","pointsEarned","bonusPoints","error","prevMonth","nextMonth"],"sources":["src/views/study/DailyCheckin.vue"],"sourcesContent":["<template>\n  <div class=\"checkin-page\">\n    <div class=\"checkin-header\">\n      <h2><i class=\"el-icon-sunny\"></i> 每日打卡</h2>\n    </div>\n\n    <div class=\"checkin-hero\">\n      <div class=\"streak-circle\">\n        <el-progress type=\"circle\" :percentage=\"nextMilestonePercent\" :width=\"180\" :stroke-width=\"10\"\n          :color=\"streakInfo.currentStreak >= 7 ? '#67C23A' : '#409EFF'\">\n          <div class=\"streak-inner\">\n            <div class=\"streak-number\">{{ streakInfo.currentStreak || 0 }}</div>\n            <div class=\"streak-label\">连续打卡</div>\n          </div>\n        </el-progress>\n      </div>\n      <div class=\"checkin-action\">\n        <el-button class=\"checkin-btn\" :type=\"checkinStatus.checkedInToday ? 'success' : 'primary'\"\n          :disabled=\"checkinStatus.checkedInToday\" size=\"large\" @click=\"doCheckin\" :loading=\"checkinLoading\">\n          <i :class=\"checkinStatus.checkedInToday ? 'el-icon-check' : 'el-icon-sunny'\"></i>\n          {{ checkinStatus.checkedInToday ? '今日已打卡' : '打卡签到' }}\n        </el-button>\n        <div class=\"streak-info\">\n          <span>最长连续: <b>{{ streakInfo.longestStreak || 0 }}</b> 天</span>\n          <span>累计打卡: <b>{{ checkinStatus.totalCheckins || 0 }}</b> 天</span>\n          <span>获得积分: <b>{{ checkinStatus.totalPointsEarned || 0 }}</b></span>\n        </div>\n        <div v-if=\"streakInfo.nextMilestone && streakInfo.nextMilestone.daysNeeded > 0\" class=\"milestone-hint\">\n          <i class=\"el-icon-trophy\"></i>\n          再坚持 <b>{{ streakInfo.nextMilestone.daysNeeded }}</b> 天解锁「{{ streakInfo.nextMilestone.name }}」奖励 (+{{ streakInfo.nextMilestone.bonus }}积分)\n        </div>\n      </div>\n    </div>\n\n    <div class=\"checkin-leaderboard\">\n      <h3><i class=\"el-icon-medal\"></i> 打卡排行榜</h3>\n      <div class=\"leaderboard-list\">\n        <div v-for=\"(user, idx) in leaderboard\" :key=\"user.userId\" class=\"leaderboard-item\">\n          <span class=\"lb-rank\" :class=\"{ 'top1': idx === 0, 'top2': idx === 1, 'top3': idx === 2 }\">{{ idx + 1 }}</span>\n          <el-avatar :size=\"32\" :src=\"user.avatar\" />\n          <span class=\"lb-name\">{{ user.nickname }}</span>\n          <span class=\"lb-streak\">{{ user.streak }}天</span>\n          <span class=\"lb-total\">{{ user.totalCheckins }}次</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- 打卡日历 -->\n    <div class=\"checkin-calendar\">\n      <h3><i class=\"el-icon-date\"></i> 打卡日历</h3>\n      <div class=\"calendar-navigation\">\n        <el-button size=\"small\" icon=\"el-icon-arrow-left\" @click=\"prevMonth\"/>\n        <span class=\"calendar-month\">{{ calendar.year }}年{{ calendar.month }}月</span>\n        <el-button size=\"small\" icon=\"el-icon-arrow-right\" @click=\"nextMonth\"/>\n      </div>\n      <div class=\"calendar-grid\">\n        <div class=\"calendar-weekday\" v-for=\"d in weekdayLabels\" :key=\"d\">{{ d }}</div>\n        <div v-for=\"(day, idx) in calendar.days\" :key=\"idx\" class=\"calendar-day\"\n          :class=\"{ 'empty': !day, 'checked': day && day.checkedIn, 'today': day && day.isToday }\">\n          <span v-if=\"day\">{{ day.day }}</span>\n        </div>\n      </div>\n      <div class=\"calendar-legend\">\n        <span class=\"legend-dot checked\"></span> 已打卡\n        <span class=\"legend-dot today\"></span> 今天\n        <span class=\"legend-dot\"></span> 未打卡\n      </div>\n    </div>\n\n    <!-- 打卡历史 -->\n    <div class=\"history-track\" v-if=\"streakInfo.checkinHistory\">\n      <h3>最近30天</h3>\n      <div class=\"track-row\">\n        <div v-for=\"d in streakInfo.checkinHistory\" :key=\"d.date\" class=\"track-cell\"\n          :class=\"{ checked: d.checkedIn }\"\n          :title=\"d.date\">\n          <i v-if=\"d.checkedIn\" class=\"el-icon-check\"></i>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'DailyCheckin',\n  data() {\n    return {\n      checkinLoading: false,\n      checkinStatus: { checkedInToday: false, streakCount: 0, totalCheckins: 0, totalPointsEarned: 0 },\n      streakInfo: { currentStreak: 0, longestStreak: 0, nextMilestone: null, checkinHistory: [] },\n      leaderboard: [],\n      calendar: { year: new Date().getFullYear(), month: new Date().getMonth() + 1, days: [], totalCheckinsThisMonth: 0 },\n      weekdayLabels: ['一', '二', '三', '四', '五', '六', '日']\n    }\n  },\n  computed: {\n    nextMilestonePercent() {\n      if (!this.streakInfo.nextMilestone) return 0\n      const m = this.streakInfo.nextMilestone\n      if (m.daysNeeded === 0) return 100\n      const target = this.streakInfo.currentStreak + m.daysNeeded\n      return Math.round(this.streakInfo.currentStreak / target * 100)\n    }\n  },\n  mounted() { this.loadAll() },\n  methods: {\n    async loadAll() {\n      await Promise.all([this.fetchStatus(), this.fetchStreak(), this.fetchLeaderboard(), this.fetchCalendar()])\n    },\n    async fetchStatus() { try { this.checkinStatus = await this.$http.get('/checkin/status') || {} } catch (e) {} },\n    async fetchStreak() { try { this.streakInfo = await this.$http.get('/checkin/streak') || {} } catch (e) {} },\n    async fetchLeaderboard() { try { const res = await this.$http.get('/checkin/leaderboard', { params: { limit: 20 } }); this.leaderboard = res || [] } catch (e) {} },\n    async fetchCalendar() {\n      try {\n        this.calendar = await this.$http.get('/checkin/calendar', { params: { year: this.calendar.year, month: this.calendar.month } }) || {}\n      } catch (e) {}\n    },\n    async doCheckin() {\n      this.checkinLoading = true\n      try {\n        const res = await this.$http.post('/checkin')\n        if (res.alreadyCheckedIn) {\n          this.$message.info('今天已经打过卡了')\n        } else {\n          this.$message.success(`打卡成功！连续${res.streakCount}天 +${res.pointsEarned}积分${res.bonusPoints > 0 ? ` (含连续奖励+${res.bonusPoints})` : ''}`)\n        }\n        await this.loadAll()\n      } catch (e) { this.$message.error('打卡失败') }\n      this.checkinLoading = false\n    },\n    prevMonth() { if (this.calendar.month === 1) { this.calendar.year--; this.calendar.month = 12 } else this.calendar.month--; this.fetchCalendar() },\n    nextMonth() { if (this.calendar.month === 12) { this.calendar.year++; this.calendar.month = 1 } else this.calendar.month++; this.fetchCalendar() }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.checkin-page { padding: 20px; max-width: 900px; margin: 0 auto; }\n.checkin-header { margin-bottom: 20px; h2 { font-size: 22px; i { margin-right: 8px; color: #E6A23C; } } }\n.checkin-hero { display: flex; align-items: center; gap: 40px; background: #fff; border-radius: 16px; padding: 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 24px;\n  .streak-circle { flex-shrink: 0; }\n  .streak-inner { .streak-number { font-size: 42px; font-weight: 700; color: #409EFF; } .streak-label { font-size: 14px; color: #909399; margin-top: 4px; } }\n  .checkin-action { flex: 1; text-align: center;\n    .checkin-btn { width: 180px; height: 52px; font-size: 18px; border-radius: 26px; i { margin-right: 6px; } }\n    .streak-info { display: flex; justify-content: center; gap: 24px; margin-top: 16px; font-size: 13px; color: #606266; b { color: #303133; } }\n    .milestone-hint { margin-top: 12px; font-size: 13px; color: #E6A23C; background: #fef3cd; padding: 8px 16px; border-radius: 8px; display: inline-block; i { margin-right: 4px; } }\n  }\n}\n.checkin-leaderboard { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 1px 8px rgba(0,0,0,0.04); margin-bottom: 24px; h3 { margin-bottom: 12px; i { margin-right: 6px; color: #E6A23C; } }\n  .leaderboard-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid #f5f5f5;\n    .lb-rank { width: 28px; text-align: center; font-weight: 600; color: #909399; &.top1 { color: #E6A23C; font-size: 18px; } &.top2 { color: #909399; font-size: 16px; } &.top3 { color: #CD853F; font-size: 14px; } }\n    .lb-name { flex: 1; font-size: 14px; }\n    .lb-streak { color: #E6A23C; font-weight: 600; font-size: 14px; }\n    .lb-total { font-size: 12px; color: #C0C4CC; }\n  }\n}\n.calendar-navigation { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 12px; .calendar-month { font-size: 16px; font-weight: 600; } }\n.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; background: #fff; padding: 16px; border-radius: 12px; box-shadow: 0 1px 8px rgba(0,0,0,0.04); margin-bottom: 12px;\n  .calendar-weekday { text-align: center; font-size: 12px; color: #909399; padding: 6px; font-weight: 600; }\n  .calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 14px; border-radius: 4px; background: #fafafa; &.empty { background: transparent; } &.checked { background: #67C23A; color: #fff; } &.today { border: 2px solid #409EFF; font-weight: 700; } }\n}\n.calendar-legend { display: flex; gap: 16px; justify-content: center; font-size: 12px; color: #909399; .legend-dot { width: 12px; height: 12px; border-radius: 2px; background: #fafafa; border: 1px solid #e0e0e0; &.checked { background: #67C23A; border-color: #67C23A; } &.today { border: 2px solid #409EFF; } } }\n.history-track { margin-top: 24px; background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 1px 8px rgba(0,0,0,0.04); h3 { margin-bottom: 12px; }\n  .track-row { display: flex; gap: 4px; flex-wrap: wrap; .track-cell { width: 28px; height: 28px; border-radius: 4px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 12px; &.checked { background: #67C23A; color: #fff; } } }\n}\n@media (max-width: 768px) { .checkin-hero { flex-direction: column; gap: 20px; text-align: center; } }\n</style>\n"],"mappings":"AAoFA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,cAAA;MACAC,aAAA;QAAAC,cAAA;QAAAC,WAAA;QAAAC,aAAA;QAAAC,iBAAA;MAAA;MACAC,UAAA;QAAAC,aAAA;QAAAC,aAAA;QAAAC,aAAA;QAAAC,cAAA;MAAA;MACAC,WAAA;MACAC,QAAA;QAAAC,IAAA,MAAAC,IAAA,GAAAC,WAAA;QAAAC,KAAA,MAAAF,IAAA,GAAAG,QAAA;QAAAC,IAAA;QAAAC,sBAAA;MAAA;MACAC,aAAA;IACA;EACA;EACAC,QAAA;IACAC,qBAAA;MACA,UAAAhB,UAAA,CAAAG,aAAA;MACA,MAAAc,CAAA,QAAAjB,UAAA,CAAAG,aAAA;MACA,IAAAc,CAAA,CAAAC,UAAA