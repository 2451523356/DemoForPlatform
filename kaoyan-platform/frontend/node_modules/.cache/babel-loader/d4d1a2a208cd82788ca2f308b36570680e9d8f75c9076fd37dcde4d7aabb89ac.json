{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.json.parse.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport { mapGetters } from 'vuex';\nexport default {\n  name: 'Community',\n  data() {\n    return {\n      postList: [],\n      topics: [{\n        id: 0,\n        name: '全部',\n        postCount: 0\n      }],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      postDialogVisible: false,\n      currentTopic: '',\n      currentCircleId: null,\n      postTypeFilter: '',\n      likedPosts: JSON.parse(localStorage.getItem('likedPosts') || '[]'),\n      followingUsers: [],\n      // 存储已关注的用户ID\n      postForm: {\n        title: '',\n        university: '',\n        major: '',\n        content: '',\n        postType: 1\n      },\n      postRules: {\n        title: [{\n          required: true,\n          message: '请输入帖子标题',\n          trigger: 'blur'\n        }],\n        university: [{\n          required: true,\n          message: '请选择院校',\n          trigger: 'change'\n        }],\n        major: [{\n          required: true,\n          message: '请选择专业',\n          trigger: 'change'\n        }],\n        content: [{\n          required: true,\n          message: '请输入帖子内容',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  computed: {\n    ...mapGetters('user', ['isLoggedIn', 'userInfo']),\n    currentUserId() {\n      return this.userInfo ? this.userInfo.id : null;\n    },\n    isAdmin() {\n      return this.userInfo && this.userInfo.role === 'ADMIN';\n    }\n  },\n  created() {\n    this.getPostList();\n    this.getFollowingList();\n    this.getCircles();\n  },\n  activated() {\n    this.getFollowingList();\n  },\n  methods: {\n    goToPost(id) {\n      console.log('跳转到帖子详情页，帖子ID:', id);\n      this.$router.push(`/community/post/${id}`);\n    },\n    goToUserProfile(userId) {\n      console.log('跳转到用户主页，用户ID:', userId);\n      this.$router.push(`/user/${userId}`);\n    },\n    isFollowing(userId) {\n      return this.followingUsers.includes(userId);\n    },\n    async toggleFollow(userId) {\n      try {\n        if (!this.$store.state.user.token) {\n          this.$message.warning('请先登录');\n          this.$router.push('/login');\n          return;\n        }\n        if (this.followingUsers.includes(userId)) {\n          // 取消关注 - 使用 POST /community/unfollow/{followUserId}\n          await this.$confirm('确定要取消关注该用户吗？', '取消关注', {\n            confirmButtonText: '确定',\n            cancelButtonText: '取消',\n            type: 'warning'\n          });\n          await this.$http.post(`/community/unfollow/${userId}`);\n          const index = this.followingUsers.indexOf(userId);\n          if (index > -1) {\n            this.followingUsers.splice(index, 1);\n          }\n          this.$message.success('已取消关注');\n        } else {\n          // 添加关注 - 使用 POST /community/follow/{followUserId}\n          await this.$http.post(`/community/follow/${userId}`);\n          this.followingUsers.push(userId);\n          this.$message.success('关注成功');\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('关注操作失败:', error);\n          this.$message.error('关注操作失败，请稍后重试');\n        }\n      }\n    },\n    async getFollowingList() {\n      try {\n        if (!this.$store.state.user.token) return;\n        const res = await this.$http.get('/community/follow/following');\n        console.log('关注列表:', res);\n        if (Array.isArray(res)) {\n          this.followingUsers = res.map(item => item.id || item.followUserId || item.userId);\n        }\n      } catch (error) {\n        console.error('获取关注列表失败:', error);\n      }\n    },\n    async likePost(post) {\n      try {\n        // 检查是否登录\n        if (!this.$store.state.user.token) {\n          this.$message.warning('请先登录');\n          this.$router.push('/login');\n          return;\n        }\n\n        // 检查是否已经点赞\n        if (this.likedPosts.includes(post.id)) {\n          this.$message.warning('您已经点过赞了');\n          return;\n        }\n\n        // 调用后端API点赞\n        await this.$http.post(`/community/post/${post.id}/like`);\n\n        // 将帖子ID添加到已点赞数组并持久化\n        this.likedPosts.push(post.id);\n        localStorage.setItem('likedPosts', JSON.stringify(this.likedPosts));\n\n        // 重新获取帖子列表，确保点赞数更新\n        await this.getPostList();\n      } catch (error) {\n        console.error('点赞失败:', error);\n        this.$message.error('点赞失败，请稍后重试');\n      }\n    },\n    async getCircles() {\n      try {\n        const res = await this.$http.get('/community/circles');\n        if (res && res.records) {\n          const circles = res.records.map(c => ({\n            id: c.id,\n            name: c.name,\n            postCount: c.postCount || 0\n          }));\n          this.topics = [{\n            id: 0,\n            name: '全部',\n            postCount: 0\n          }, ...circles];\n        }\n      } catch (error) {\n        console.error('获取圈子列表失败:', error);\n      }\n    },\n    handlePostTypeChange() {\n      this.currentPage = 1;\n      this.getPostList();\n    },\n    filterByTopic(circle) {\n      if (circle.id === 0) {\n        this.currentTopic = '';\n        this.currentCircleId = null;\n      } else {\n        this.currentTopic = circle.name;\n        this.currentCircleId = circle.id;\n      }\n      this.currentPage = 1;\n      this.getPostList();\n    },\n    formatPostTime(time) {\n      if (!time) return '';\n      try {\n        const d = new Date(time);\n        if (isNaN(d.getTime())) return time;\n        const now = new Date();\n        const diff = now - d;\n        if (diff < 60000) return '刚刚';\n        if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';\n        if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';\n        if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';\n        return d.toLocaleDateString('zh-CN');\n      } catch (e) {\n        return time;\n      }\n    },\n    showPostDialog() {\n      if (!this.$store.state.user.token) {\n        this.$message.warning('请先登录后再发布帖子');\n        this.$router.push('/login');\n        return;\n      }\n      this.postDialogVisible = true;\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getPostList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getPostList();\n    },\n    submitPost() {\n      this.$refs.postForm.validate(async valid => {\n        if (valid) {\n          try {\n            // 将院校和专业合并为话题\n            const postData = {\n              ...this.postForm,\n              topic: `${this.postForm.university}-${this.postForm.major}`,\n              postType: this.postForm.postType\n            };\n            await this.$http.post('/community/post', postData);\n            this.$message.success('发布成功');\n            this.postDialogVisible = false;\n            // 重置表单\n            this.postForm = {\n              title: '',\n              university: '',\n              major: '',\n              content: '',\n              postType: 1\n            };\n            // 重置到第一页并刷新列表\n            this.currentPage = 1;\n            this.getPostList();\n          } catch (error) {\n            console.error('发布帖子失败:', error);\n            this.$message.error('发布失败，请稍后重试');\n          }\n        }\n      });\n    },\n    async deletePost(postId) {\n      try {\n        await this.$confirm('确定要删除这个帖子吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        await this.$http.delete(`/community/post/${postId}`);\n        this.$message.success('删除成功');\n        // 重新获取帖子列表\n        await this.getPostList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除帖子失败:', error);\n          this.$message.error('删除失败，请稍后重试');\n        }\n      }\n    },\n    async getPostList() {\n      try {\n        console.log('获取帖子列表，页码:', this.currentPage, '话题:', this.currentTopic);\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize\n        };\n        if (this.currentCircleId) {\n          params.circleId = this.currentCircleId;\n        } else if (this.currentTopic) {\n          params.keyword = this.currentTopic;\n        }\n        if (this.postTypeFilter) {\n          params.postType = this.postTypeFilter;\n        }\n        const res = await this.$http.get('/community/posts', {\n          params: params\n        });\n        console.log('API 响应:', res);\n        let dataList = [];\n        let totalCount = 0;\n        if (res?.records) {\n          dataList = res.records;\n          totalCount = res.total || 0;\n        } else if (Array.isArray(res)) {\n          dataList = res;\n          totalCount = res.length;\n        }\n        console.log('帖子记录数:', dataList.length);\n        console.log('帖子数据:', dataList);\n        if (dataList.length > 0) {\n          this.postList = dataList.map(post => ({\n            id: post.id,\n            userId: post.userId || post.user_id,\n            authorAvatar: post.authorAvatar || '',\n            authorName: post.authorName || post.nickname || '用户' + (post.userId || post.user_id || ''),\n            title: post.title || '',\n            content: post.content || '',\n            topic: post.tags || post.circleName || '综合讨论',\n            likeCount: post.likeCount || post.like_count || 0,\n            commentCount: post.commentCount || post.comment_count || 0,\n            createTime: this.formatPostTime(post.createTime || post.create_time)\n          }));\n          this.total = totalCount;\n        } else {\n          this.postList = [];\n          this.total = 0;\n        }\n      } catch (error) {\n        console.error('获取帖子列表失败:', error);\n        this.postList = [];\n        this.total = 0;\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","name","data","postList","topics","id","postCount","currentPage","pageSize","total","postDialogVisible","currentTopic","currentCircleId","postTypeFilter","likedPosts","JSON","parse","localStorage","getItem","followingUsers","postForm","title","university","major","content","postType","postRules","required","message","trigger","computed","currentUserId","userInfo","isAdmin","role","created","getPostList","getFollowingList","getCircles","activated","methods","goToPost","console","log","$router","push","goToUserProfile","userId","isFollowing","includes","toggleFollow","$store","state","user","token","$message","warning","$confirm","confirmButtonText","cancelButtonText","type","$http","post","index","indexOf","splice","success","error","res","get","Array","isArray","map","item","followUserId","likePost","setItem","stringify","records","circles","c","handlePostTypeChange","filterByTopic","circle","formatPostTime","time","d","Date","isNaN","getTime","now","diff","Math","floor","toLocaleDateString","e","showPostDialog","handleSizeChange","size","handleCurrentChange","current","submitPost","$refs","validate","valid","postData","topic","deletePost","postId","delete","params","page","circleId","keyword","dataList","totalCount","length","user_id","authorAvatar","authorName","nickname","tags","circleName","likeCount","like_count","commentCount","comment_count","createTime","create_time"],"sources":["src/views/community/Community.vue"],"sourcesContent":["<template>\n  <div class=\"community\">\n    <div class=\"community-header\">\n      <h1>研友社区</h1>\n      <el-button type=\"primary\" @click=\"showPostDialog\">\n        <i class=\"el-icon-plus\"></i> 发布帖子\n      </el-button>\n    </div>\n\n    <div class=\"community-content\">\n      <el-row :gutter=\"20\">\n        <el-col :span=\"18\">\n          <div class=\"post-type-tabs\" style=\"margin-bottom:16px\">\n            <el-radio-group v-model=\"postTypeFilter\" @change=\"handlePostTypeChange\" size=\"small\">\n              <el-radio-button label=\"\">全部</el-radio-button>\n              <el-radio-button label=\"2\">经验帖</el-radio-button>\n              <el-radio-button label=\"3\">答疑</el-radio-button>\n              <el-radio-button label=\"4\">资料分享</el-radio-button>\n              <el-radio-button label=\"5\">复试经验</el-radio-button>\n            </el-radio-group>\n          </div>\n          <div class=\"post-list\">\n            <div v-if=\"postList.length === 0\" class=\"empty-posts\">\n              <el-empty description=\"暂无帖子，快来发布第一个吧！\" />\n            </div>\n            <el-card v-for=\"post in postList\" :key=\"post.id\" class=\"post-card\">\n              <div class=\"post-header\">\n                <el-avatar :size=\"40\" :src=\"post.authorAvatar\" @click=\"goToUserProfile(post.userId)\"></el-avatar>\n                <div class=\"author-info\">\n                  <span class=\"author-name\" @click=\"goToUserProfile(post.userId)\">{{ post.authorName }}</span>\n                  <span class=\"post-time\">{{ post.createTime }}</span>\n                </div>\n                <el-button\n                  v-if=\"isLoggedIn && currentUserId !== post.userId\"\n                  :type=\"isFollowing(post.userId) ? 'default' : 'primary'\"\n                  size=\"small\"\n                  @click=\"toggleFollow(post.userId)\"\n                >\n                  {{ isFollowing(post.userId) ? '已关注' : '+ 关注' }}\n                </el-button>\n              </div>\n              <h3 class=\"post-title\" @click=\"goToPost(post.id)\">{{ post.title }}</h3>\n              <p class=\"post-content\">{{ post.content }}</p>\n              <div class=\"post-footer\">\n                <span class=\"topic\">{{ post.topic }}</span>\n                <div class=\"post-actions\">\n                  <span @click=\"likePost(post)\">\n                    <i class=\"el-icon-star-off\"></i> {{ post.likeCount }}\n                  </span>\n                  <span @click=\"goToPost(post.id)\">\n                    <i class=\"el-icon-chat-dot-round\"></i> {{ post.commentCount }}\n                  </span>\n                  <span v-if=\"(isLoggedIn && post.userId === currentUserId) || isAdmin\" @click=\"deletePost(post.id)\" class=\"delete-btn\">\n                    <i class=\"el-icon-delete\"></i> 删除\n                  </span>\n                </div>\n              </div>\n            </el-card>\n          </div>\n\n          <div class=\"pagination\">\n            <el-pagination\n              @size-change=\"handleSizeChange\"\n              @current-change=\"handleCurrentChange\"\n              :current-page=\"currentPage\"\n              :page-sizes=\"[10, 20, 50]\"\n              :page-size=\"pageSize\"\n              layout=\"total, sizes, prev, pager, next, jumper\"\n              :total=\"total\"\n            />\n          </div>\n        </el-col>\n\n        <el-col :span=\"6\">\n          <el-card class=\"topic-card\">\n            <h3>热门话题</h3>\n            <div class=\"topic-list\">\n              <div\n                v-for=\"topic in topics\"\n                :key=\"topic.id\"\n                class=\"topic-item\"\n                @click=\"filterByTopic(topic)\"\n              >\n                <span class=\"topic-name\"># {{ topic.name }}</span>\n                <span class=\"topic-count\">{{ topic.postCount }}帖子</span>\n              </div>\n            </div>\n          </el-card>\n        </el-col>\n      </el-row>\n    </div>\n\n    <el-dialog title=\"发布帖子\" :visible.sync=\"postDialogVisible\" width=\"600px\">\n      <el-form ref=\"postForm\" :model=\"postForm\" :rules=\"postRules\" label-width=\"80px\">\n        <el-form-item label=\"标题\" prop=\"title\">\n          <el-input v-model=\"postForm.title\" placeholder=\"请输入帖子标题\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"院校\" prop=\"university\">\n          <el-select v-model=\"postForm.university\" placeholder=\"选择院校\" filterable>\n            <el-option-group label=\"华北地区\">\n              <el-option label=\"北京大学\" value=\"北京大学\"></el-option>\n              <el-option label=\"清华大学\" value=\"清华大学\"></el-option>\n              <el-option label=\"中国人民大学\" value=\"中国人民大学\"></el-option>\n              <el-option label=\"北京师范大学\" value=\"北京师范大学\"></el-option>\n              <el-option label=\"北京航空航天大学\" value=\"北京航空航天大学\"></el-option>\n              <el-option label=\"北京理工大学\" value=\"北京理工大学\"></el-option>\n              <el-option label=\"南开大学\" value=\"南开大学\"></el-option>\n              <el-option label=\"天津大学\" value=\"天津大学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"华东地区\">\n              <el-option label=\"复旦大学\" value=\"复旦大学\"></el-option>\n              <el-option label=\"上海交通大学\" value=\"上海交通大学\"></el-option>\n              <el-option label=\"同济大学\" value=\"同济大学\"></el-option>\n              <el-option label=\"华东师范大学\" value=\"华东师范大学\"></el-option>\n              <el-option label=\"浙江大学\" value=\"浙江大学\"></el-option>\n              <el-option label=\"南京大学\" value=\"南京大学\"></el-option>\n              <el-option label=\"东南大学\" value=\"东南大学\"></el-option>\n              <el-option label=\"中国科学技术大学\" value=\"中国科学技术大学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"华中地区\">\n              <el-option label=\"武汉大学\" value=\"武汉大学\"></el-option>\n              <el-option label=\"华中科技大学\" value=\"华中科技大学\"></el-option>\n              <el-option label=\"中南大学\" value=\"中南大学\"></el-option>\n              <el-option label=\"湖南大学\" value=\"湖南大学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"华南地区\">\n              <el-option label=\"中山大学\" value=\"中山大学\"></el-option>\n              <el-option label=\"华南理工大学\" value=\"华南理工大学\"></el-option>\n              <el-option label=\"厦门大学\" value=\"厦门大学\"></el-option>\n              <el-option label=\"暨南大学\" value=\"暨南大学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"其他地区\">\n              <el-option label=\"西安交通大学\" value=\"西安交通大学\"></el-option>\n              <el-option label=\"哈尔滨工业大学\" value=\"哈尔滨工业大学\"></el-option>\n              <el-option label=\"四川大学\" value=\"四川大学\"></el-option>\n              <el-option label=\"重庆大学\" value=\"重庆大学\"></el-option>\n              <el-option label=\"兰州大学\" value=\"兰州大学\"></el-option>\n            </el-option-group>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"专业\" prop=\"major\">\n          <el-select v-model=\"postForm.major\" placeholder=\"选择专业\" filterable>\n            <el-option-group label=\"工学\">\n              <el-option label=\"计算机科学与技术\" value=\"计算机科学与技术\"></el-option>\n              <el-option label=\"软件工程\" value=\"软件工程\"></el-option>\n              <el-option label=\"电子信息\" value=\"电子信息\"></el-option>\n              <el-option label=\"机械工程\" value=\"机械工程\"></el-option>\n              <el-option label=\"土木工程\" value=\"土木工程\"></el-option>\n              <el-option label=\"电气工程\" value=\"电气工程\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"理学\">\n              <el-option label=\"数学\" value=\"数学\"></el-option>\n              <el-option label=\"物理学\" value=\"物理学\"></el-option>\n              <el-option label=\"化学\" value=\"化学\"></el-option>\n              <el-option label=\"生物学\" value=\"生物学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"经济学/管理学\">\n              <el-option label=\"金融学\" value=\"金融学\"></el-option>\n              <el-option label=\"会计学\" value=\"会计学\"></el-option>\n              <el-option label=\"工商管理\" value=\"工商管理\"></el-option>\n              <el-option label=\"应用经济学\" value=\"应用经济学\"></el-option>\n            </el-option-group>\n            <el-option-group label=\"文学/法学/其他\">\n              <el-option label=\"英语语言文学\" value=\"英语语言文学\"></el-option>\n              <el-option label=\"法学\" value=\"法学\"></el-option>\n              <el-option label=\"新闻传播学\" value=\"新闻传播学\"></el-option>\n              <el-option label=\"教育学\" value=\"教育学\"></el-option>\n              <el-option label=\"心理学\" value=\"心理学\"></el-option>\n              <el-option label=\"医学\" value=\"医学\"></el-option>\n            </el-option-group>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"内容\" prop=\"content\">\n          <el-input\n            v-model=\"postForm.content\"\n            type=\"textarea\"\n            :rows=\"5\"\n            placeholder=\"请输入帖子内容\"\n          ></el-input>\n        </el-form-item>\n        <el-form-item label=\"类型\">\n          <el-radio-group v-model=\"postForm.postType\">\n            <el-radio :label=\"1\">普通</el-radio>\n            <el-radio :label=\"2\">经验帖</el-radio>\n            <el-radio :label=\"3\">答疑</el-radio>\n            <el-radio :label=\"4\">资料分享</el-radio>\n            <el-radio :label=\"5\">复试经验</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"postDialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"submitPost\">发布</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\n\nexport default {\n  name: 'Community',\n  data() {\n    return {\n      postList: [],\n      topics: [\n        { id: 0, name: '全部', postCount: 0 }\n      ],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      postDialogVisible: false,\n      currentTopic: '',\n      currentCircleId: null,\n      postTypeFilter: '',\n      likedPosts: JSON.parse(localStorage.getItem('likedPosts') || '[]'),\n      followingUsers: [], // 存储已关注的用户ID\n      postForm: {\n        title: '',\n        university: '',\n        major: '',\n        content: '',\n        postType: 1\n      },\n      postRules: {\n        title: [\n          { required: true, message: '请输入帖子标题', trigger: 'blur' }\n        ],\n        university: [\n          { required: true, message: '请选择院校', trigger: 'change' }\n        ],\n        major: [\n          { required: true, message: '请选择专业', trigger: 'change' }\n        ],\n        content: [\n          { required: true, message: '请输入帖子内容', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  computed: {\n    ...mapGetters('user', ['isLoggedIn', 'userInfo']),\n    currentUserId() {\n      return this.userInfo ? this.userInfo.id : null\n    },\n    isAdmin() {\n      return this.userInfo && this.userInfo.role === 'ADMIN'\n    },\n\n  },\n  created() {\n    this.getPostList()\n    this.getFollowingList()\n    this.getCircles()\n  },\n  activated() {\n    this.getFollowingList()\n  },\n  methods: {\n    goToPost(id) {\n      console.log('跳转到帖子详情页，帖子ID:', id)\n      this.$router.push(`/community/post/${id}`)\n    },\n    goToUserProfile(userId) {\n      console.log('跳转到用户主页，用户ID:', userId)\n      this.$router.push(`/user/${userId}`)\n    },\n    isFollowing(userId) {\n      return this.followingUsers.includes(userId)\n    },\n    async toggleFollow(userId) {\n      try {\n        if (!this.$store.state.user.token) {\n          this.$message.warning('请先登录')\n          this.$router.push('/login')\n          return\n        }\n\n        if (this.followingUsers.includes(userId)) {\n          // 取消关注 - 使用 POST /community/unfollow/{followUserId}\n          await this.$confirm('确定要取消关注该用户吗？', '取消关注', {\n            confirmButtonText: '确定',\n            cancelButtonText: '取消',\n            type: 'warning'\n          })\n          await this.$http.post(`/community/unfollow/${userId}`)\n          const index = this.followingUsers.indexOf(userId)\n          if (index > -1) {\n            this.followingUsers.splice(index, 1)\n          }\n          this.$message.success('已取消关注')\n        } else {\n          // 添加关注 - 使用 POST /community/follow/{followUserId}\n          await this.$http.post(`/community/follow/${userId}`)\n          this.followingUsers.push(userId)\n          this.$message.success('关注成功')\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('关注操作失败:', error)\n          this.$message.error('关注操作失败，请稍后重试')\n        }\n      }\n    },\n    async getFollowingList() {\n      try {\n        if (!this.$store.state.user.token) return\n\n        const res = await this.$http.get('/community/follow/following')\n        console.log('关注列表:', res)\n        if (Array.isArray(res)) {\n          this.followingUsers = res.map(item => item.id || item.followUserId || item.userId)\n        }\n      } catch (error) {\n        console.error('获取关注列表失败:', error)\n      }\n    },\n    async likePost(post) {\n      try {\n        // 检查是否登录\n        if (!this.$store.state.user.token) {\n          this.$message.warning('请先登录')\n          this.$router.push('/login')\n          return\n        }\n\n        // 检查是否已经点赞\n        if (this.likedPosts.includes(post.id)) {\n          this.$message.warning('您已经点过赞了')\n          return\n        }\n\n        // 调用后端API点赞\n        await this.$http.post(`/community/post/${post.id}/like`)\n\n        // 将帖子ID添加到已点赞数组并持久化\n        this.likedPosts.push(post.id)\n        localStorage.setItem('likedPosts', JSON.stringify(this.likedPosts))\n\n        // 重新获取帖子列表，确保点赞数更新\n        await this.getPostList()\n      } catch (error) {\n        console.error('点赞失败:', error)\n        this.$message.error('点赞失败，请稍后重试')\n      }\n    },\n    async getCircles() {\n      try {\n        const res = await this.$http.get('/community/circles')\n        if (res && res.records) {\n          const circles = res.records.map(c => ({\n            id: c.id,\n            name: c.name,\n            postCount: c.postCount || 0\n          }))\n          this.topics = [{ id: 0, name: '全部', postCount: 0 }, ...circles]\n        }\n      } catch (error) {\n        console.error('获取圈子列表失败:', error)\n      }\n    },\n    handlePostTypeChange() {\n      this.currentPage = 1\n      this.getPostList()\n    },\n    filterByTopic(circle) {\n      if (circle.id === 0) {\n        this.currentTopic = ''\n        this.currentCircleId = null\n      } else {\n        this.currentTopic = circle.name\n        this.currentCircleId = circle.id\n      }\n      this.currentPage = 1\n      this.getPostList()\n    },\n    formatPostTime(time) {\n      if (!time) return ''\n      try {\n        const d = new Date(time)\n        if (isNaN(d.getTime())) return time\n        const now = new Date()\n        const diff = now - d\n        if (diff < 60000) return '刚刚'\n        if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前'\n        if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前'\n        if (diff < 604800000) return Math.floor(diff / 86400000) + '天前'\n        return d.toLocaleDateString('zh-CN')\n      } catch (e) {\n        return time\n      }\n    },\n    showPostDialog() {\n      if (!this.$store.state.user.token) {\n        this.$message.warning('请先登录后再发布帖子')\n        this.$router.push('/login')\n        return\n      }\n      this.postDialogVisible = true\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getPostList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getPostList()\n    },\n    submitPost() {\n      this.$refs.postForm.validate(async (valid) => {\n        if (valid) {\n          try {\n            // 将院校和专业合并为话题\n            const postData = {\n              ...this.postForm,\n              topic: `${this.postForm.university}-${this.postForm.major}`,\n              postType: this.postForm.postType\n            }\n            await this.$http.post('/community/post', postData)\n            this.$message.success('发布成功')\n            this.postDialogVisible = false\n            // 重置表单\n            this.postForm = {\n              title: '',\n              university: '',\n              major: '',\n              content: '',\n              postType: 1\n            }\n            // 重置到第一页并刷新列表\n            this.currentPage = 1\n            this.getPostList()\n          } catch (error) {\n            console.error('发布帖子失败:', error)\n            this.$message.error('发布失败，请稍后重试')\n          }\n        }\n      })\n    },\n    async deletePost(postId) {\n      try {\n        await this.$confirm('确定要删除这个帖子吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        })\n\n        await this.$http.delete(`/community/post/${postId}`)\n        this.$message.success('删除成功')\n        // 重新获取帖子列表\n        await this.getPostList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除帖子失败:', error)\n          this.$message.error('删除失败，请稍后重试')\n        }\n      }\n    },\n    async getPostList() {\n      try {\n        console.log('获取帖子列表，页码:', this.currentPage, '话题:', this.currentTopic)\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize\n        }\n\n        if (this.currentCircleId) {\n          params.circleId = this.currentCircleId\n        } else if (this.currentTopic) {\n          params.keyword = this.currentTopic\n        }\n        if (this.postTypeFilter) {\n          params.postType = this.postTypeFilter\n        }\n\n        const res = await this.$http.get('/community/posts', {\n          params: params\n        })\n        console.log('API 响应:', res)\n        let dataList = []\n        let totalCount = 0\n\n        if (res?.records) {\n          dataList = res.records\n          totalCount = res.total || 0\n        } else if (Array.isArray(res)) {\n          dataList = res\n          totalCount = res.length\n        }\n\n        console.log('帖子记录数:', dataList.length)\n        console.log('帖子数据:', dataList)\n\n        if (dataList.length > 0) {\n          this.postList = dataList.map(post => ({\n            id: post.id,\n            userId: post.userId || post.user_id,\n            authorAvatar: post.authorAvatar || '',\n            authorName: post.authorName || post.nickname || ('用户' + (post.userId || post.user_id || '')),\n            title: post.title || '',\n            content: post.content || '',\n            topic: post.tags || post.circleName || '综合讨论',\n            likeCount: post.likeCount || post.like_count || 0,\n            commentCount: post.commentCount || post.comment_count || 0,\n            createTime: this.formatPostTime(post.createTime || post.create_time)\n          }))\n          this.total = totalCount\n        } else {\n          this.postList = []\n          this.total = 0\n        }\n      } catch (error) {\n        console.error('获取帖子列表失败:', error)\n        this.postList = []\n        this.total = 0\n      }\n    },\n\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.community {\n  padding: 20px;\n  max-width: 1200px;\n  margin: 0 auto;\n\n  .community-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 30px;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #EBEEF5;\n\n    h1 {\n      font-size: 28px;\n      color: #303133;\n      font-weight: 600;\n    }\n\n    .el-button--primary {\n      background-color: #409EFF;\n      border-color: #409EFF;\n      font-size: 14px;\n      padding: 10px 20px;\n      border-radius: 6px;\n      transition: all 0.3s ease;\n\n      &:hover {\n        background-color: #66B1FF;\n        border-color: #66B1FF;\n      }\n    }\n\n    @media (max-width: 768px) {\n      flex-direction: column;\n      align-items: flex-start;\n      gap: 15px;\n\n      h1 {\n        font-size: 22px;\n      }\n\n      .el-button--primary {\n        width: 100%;\n        text-align: center;\n      }\n    }\n  }\n\n  .post-list {\n    .post-card {\n      margin-bottom: 20px;\n      border-radius: 12px;\n      overflow: hidden;\n      transition: all 0.3s ease;\n      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);\n    