{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nexport default {\n  name: 'News',\n  data() {\n    return {\n      searchKeyword: '',\n      selectedCategory: '',\n      selectedStage: '',\n      activeTab: '',\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      notificationVisible: false,\n      notifications: [],\n      unreadCount: 0,\n      subscriptionVisible: false,\n      availableTags: ['国家政策', '教育部文件', '院校政策', '招生简章', '专业目录', '报名通知', '网报公告', '考试大纲', '初试信息', '成绩查询', '国家线/复试线', '复试通知', '复试经验', '调剂信息', '录取公示', '备考指南', '经验分享', '复习方法', '考研常识', '院校新闻', '学科排名', '招生宣讲'],\n      categoryGroups: [{\n        name: '政策公告',\n        categories: ['国家政策', '教育部文件', '院校政策']\n      }, {\n        name: '招生信息',\n        categories: ['招生简章', '专业目录', '报名通知', '网报公告']\n      }, {\n        name: '考试资讯',\n        categories: ['考试大纲', '初试信息', '成绩查询', '国家线/复试线']\n      }, {\n        name: '复试调剂',\n        categories: ['复试通知', '复试经验', '调剂信息', '录取公示']\n      }, {\n        name: '备考指导',\n        categories: ['备考指南', '经验分享', '复习方法', '考研常识']\n      }, {\n        name: '院校动态',\n        categories: ['院校新闻', '学科排名', '招生宣讲']\n      }],\n      selectedTags: []\n    };\n  },\n  created() {\n    this.getNewsList();\n    this.getUnreadCount();\n  },\n  mounted() {\n    if (this.$route.query.showNotifications === '1') {\n      this.$nextTick(() => {\n        this.showNotifications();\n      });\n    }\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return '';\n      return new Date(time).toLocaleDateString('zh-CN');\n    },\n    goToDetail(id) {\n      this.$router.push(`/news/${id}`);\n    },\n    switchTab(tabName) {\n      this.activeTab = tabName;\n      // 根据选中的 tab 过滤分类\n      if (tabName === '') {\n        this.selectedCategory = '';\n      } else {\n        const group = this.categoryGroups.find(g => g.name === tabName);\n        // 切换tab时不清空具体分类，但若当前分类不在该组内则重置\n        if (group && !group.categories.includes(this.selectedCategory)) {\n          this.selectedCategory = '';\n        }\n      }\n      this.search();\n    },\n    search() {\n      this.currentPage = 1;\n      this.getNewsList();\n    },\n    resetFilters() {\n      this.currentPage = 1;\n      this.searchKeyword = '';\n      this.selectedCategory = '';\n      this.selectedStage = '';\n      this.getNewsList();\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getNewsList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getNewsList();\n    },\n    async getNewsList() {\n      try {\n        // 确定 category 参数：优先使用具体分类，其次使用tab分组\n        let categoryParam = this.selectedCategory || undefined;\n        if (!categoryParam && this.activeTab) {\n          const group = this.categoryGroups.find(g => g.name === this.activeTab);\n          if (group) {\n            categoryParam = group.categories.join(',');\n          }\n        }\n        const res = await this.$http.get('/news/list', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize,\n            category: categoryParam,\n            examStage: this.selectedStage || undefined,\n            keyword: this.searchKeyword || undefined\n          }\n        });\n        this.newsList = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (error) {\n        console.error('获取资讯列表失败:', error);\n      }\n    },\n    async showNotifications() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token;\n      if (!token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      this.notificationVisible = true;\n      await this.getNotifications();\n    },\n    async getNotifications() {\n      try {\n        const res = await this.$http.get('/notification/list', {\n          params: {\n            page: 1,\n            size: 50\n          }\n        });\n        this.notifications = res?.records || [];\n      } catch (error) {\n        console.error(error);\n        if (error.response && error.response.status === 401) {\n          this.$message.warning('登录已过期，请重新登录');\n          this.$router.push('/login');\n        }\n      }\n    },\n    async getUnreadCount() {\n      try {\n        const res = await this.$http.get('/notification/unread-count');\n        this.unreadCount = res || 0;\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    async markAsRead(id) {\n      try {\n        await this.$http.post(`/notification/read/${id}`);\n        await this.getNotifications();\n        await this.getUnreadCount();\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    async markAllAsRead() {\n      try {\n        await this.$http.post('/notification/read-all');\n        await this.getNotifications();\n        await this.getUnreadCount();\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    showSubscriptionDialog() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token;\n      if (!token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      this.subscriptionVisible = true;\n      this.getSubscriptions();\n    },\n    async getSubscriptions() {\n      try {\n        const res = await this.$http.get('/news/subscriptions');\n        this.selectedTags = Array.isArray(res) ? res : [];\n      } catch (error) {\n        console.error('获取订阅标签失败:', error);\n      }\n    },\n    async saveSubscriptions() {\n      try {\n        // 先获取当前已订阅的标签\n        const currentSubs = await this.$http.get('/news/subscriptions');\n        const currentTags = Array.isArray(currentSubs) ? currentSubs : [];\n\n        // 取消已取消勾选的标签\n        const toUnsubscribe = currentTags.filter(tag => !this.selectedTags.includes(tag));\n        for (const tag of toUnsubscribe) {\n          await this.$http.post(`/news/unsubscribe/${encodeURIComponent(tag)}`);\n        }\n\n        // 订阅新勾选的标签\n        const toSubscribe = this.selectedTags.filter(tag => !currentTags.includes(tag));\n        for (const tag of toSubscribe) {\n          await this.$http.post(`/news/subscribe/${encodeURIComponent(tag)}`);\n        }\n        this.$message.success('订阅保存成功');\n        this.subscriptionVisible = false;\n      } catch (error) {\n        console.error('保存订阅标签失败:', error);\n        this.$message.error('保存订阅失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchKeyword","selectedCategory","selectedStage","activeTab","newsList","currentPage","pageSize","total","notificationVisible","notifications","unreadCount","subscriptionVisible","availableTags","categoryGroups","categories","selectedTags","created","getNewsList","getUnreadCount","mounted","$route","query","showNotifications","$nextTick","methods","formatTime","time","Date","toLocaleDateString","goToDetail","id","$router","push","switchTab","tabName","group","find","g","includes","search","resetFilters","handleSizeChange","size","handleCurrentChange","current","categoryParam","undefined","join","res","$http","get","params","page","category","examStage","keyword","records","error","console","token","$store","state","user","$message","warning","getNotifications","response","status","markAsRead","post","markAllAsRead","showSubscriptionDialog","getSubscriptions","Array","isArray","saveSubscriptions","currentSubs","currentTags","toUnsubscribe","filter","tag","encodeURIComponent","toSubscribe","success"],"sources":["src/views/news/News.vue"],"sourcesContent":["<template>\n  <div class=\"news\">\n    <el-card>\n      <div class=\"news-header\">\n        <h1>考研资讯</h1>\n        <div class=\"header-actions\">\n          <el-badge :value=\"unreadCount\" :hidden=\"unreadCount === 0\">\n            <el-button size=\"small\" @click=\"showNotifications\" icon=\"el-icon-bell\">通知</el-button>\n          </el-badge>\n          <el-button size=\"small\" type=\"info\" @click=\"showSubscriptionDialog\">\n            <i class=\"el-icon-star-off\"></i> 订阅\n          </el-button>\n        </div>\n      </div>\n\n      <!-- 分类标签栏 -->\n      <div class=\"category-tabs\">\n        <span\n          class=\"category-tab\"\n          :class=\"{ active: activeTab === '' }\"\n          @click=\"switchTab('')\"\n        >全部</span>\n        <span\n          v-for=\"group in categoryGroups\"\n          :key=\"group.name\"\n          class=\"category-tab\"\n          :class=\"{ active: activeTab === group.name }\"\n          @click=\"switchTab(group.name)\"\n        >{{ group.name }}</span>\n      </div>\n\n      <div class=\"news-filter\">\n        <el-input\n          v-model=\"searchKeyword\"\n          placeholder=\"搜索资讯关键词\"\n          clearable\n          prefix-icon=\"el-icon-search\"\n          style=\"width: 240px; margin-right: 10px;\"\n          @keyup.enter.native=\"search\"\n        />\n        <el-select v-model=\"selectedCategory\" placeholder=\"细分分类\" clearable @change=\"search\" style=\"width:140px; margin-right:10px\">\n          <el-option label=\"全部分类\" value=\"\"></el-option>\n          <el-option-group v-for=\"group in categoryGroups\" :key=\"group.name\" :label=\"group.name\">\n            <el-option v-for=\"cat in group.categories\" :key=\"cat\" :label=\"cat\" :value=\"cat\"></el-option>\n          </el-option-group>\n        </el-select>\n        <el-select v-model=\"selectedStage\" placeholder=\"备考阶段\" clearable @change=\"search\" style=\"width:120px\">\n          <el-option label=\"全部\" value=\"\"></el-option>\n          <el-option label=\"择校评估\" value=\"择校评估\"></el-option>\n          <el-option label=\"基础复习\" value=\"基础复习\"></el-option>\n          <el-option label=\"强化提升\" value=\"强化提升\"></el-option>\n          <el-option label=\"报名报考\" value=\"报名报考\"></el-option>\n          <el-option label=\"冲刺模考\" value=\"冲刺模考\"></el-option>\n          <el-option label=\"复试准备\" value=\"复试准备\"></el-option>\n          <el-option label=\"调剂录取\" value=\"调剂录取\"></el-option>\n        </el-select>\n        <el-button @click=\"resetFilters\">重置</el-button>\n      </div>\n\n      <!-- 置顶资讯 -->\n      <div v-if=\"topNewsList.length > 0\" class=\"top-news\">\n        <div class=\"top-news-item\" v-for=\"news in topNewsList\" :key=\"'top'+news.id\" @click=\"goToDetail(news.id)\">\n          <el-tag size=\"mini\" type=\"danger\" effect=\"dark\">置顶</el-tag>\n          <span class=\"top-news-title\">{{ news.title }}</span>\n          <span class=\"top-news-time\">{{ formatTime(news.createTime) }}</span>\n        </div>\n      </div>\n\n      <!-- 资讯列表 -->\n      <div class=\"news-list\">\n        <div class=\"news-list-item\" v-for=\"news in normalNewsList\" :key=\"news.id\" @click=\"goToDetail(news.id)\">\n          <div class=\"news-item-body\">\n            <h3 class=\"news-title\">\n              {{ news.title }}\n            </h3>\n            <p class=\"news-summary\">{{ news.summary }}</p>\n            <div class=\"news-meta\">\n              <el-tag size=\"mini\" type=\"warning\">{{ news.category }}</el-tag>\n              <el-tag size=\"mini\" v-if=\"news.examStage\">{{ news.examStage }}</el-tag>\n              <span class=\"meta-item\"><i class=\"el-icon-view\"></i> {{ news.viewCount }}</span>\n              <span class=\"meta-item\"><i class=\"el-icon-star-off\"></i> {{ news.likeCount }}</span>\n              <span class=\"meta-item time\">{{ formatTime(news.createTime) }}</span>\n            </div>\n          </div>\n          <div class=\"news-item-cover\" v-if=\"news.cover\">\n            <img :src=\"news.cover\" alt=\"封面\" />\n          </div>\n        </div>\n\n        <div v-if=\"newsList.length === 0\" class=\"empty-news\">\n          <el-empty description=\"暂无相关资讯\" />\n        </div>\n      </div>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 30]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n\n    <el-dialog title=\"通知\" :visible.sync=\"notificationVisible\" width=\"600px\">\n      <div class=\"notification-list\">\n        <el-card v-for=\"notification in notifications\" :key=\"notification.id\" class=\"notification-item\" :class=\"{ 'unread': !notification.isRead }\">\n          <div class=\"notification-header\">\n            <h4>{{ notification.title }}</h4>\n            <el-tag size=\"small\" :type=\"notification.isRead ? 'info' : 'danger'\">{{ notification.isRead ? '已读' : '未读' }}</el-tag>\n          </div>\n          <p class=\"notification-content\">{{ notification.content }}</p>\n          <div class=\"notification-footer\">\n            <span class=\"time\">{{ formatTime(notification.createTime) }}</span>\n            <el-button v-if=\"!notification.isRead\" type=\"text\" size=\"small\" @click=\"markAsRead(notification.id)\">标记为已读</el-button>\n          </div>\n        </el-card>\n        <div v-if=\"notifications.length === 0\" class=\"empty-notifications\">\n          <el-empty description=\"暂无通知\" />\n        </div>\n      </div>\n      <div slot=\"footer\">\n        <el-button @click=\"notificationVisible = false\">关闭</el-button>\n        <el-button type=\"primary\" @click=\"markAllAsRead\">全部标记为已读</el-button>\n      </div>\n    </el-dialog>\n\n    <el-dialog title=\"订阅管理\" :visible.sync=\"subscriptionVisible\" width=\"500px\">\n      <div class=\"subscription-container\">\n        <p class=\"subscription-hint\">选择你感兴趣的资讯标签，当有新资讯时会收到通知</p>\n        <el-checkbox-group v-model=\"selectedTags\">\n          <el-checkbox v-for=\"tag in availableTags\" :key=\"tag\" :label=\"tag\" class=\"subscription-tag\">\n            {{ tag }}\n          </el-checkbox>\n        </el-checkbox-group>\n      </div>\n      <div slot=\"footer\">\n        <el-button @click=\"subscriptionVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveSubscriptions\">保存订阅</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'News',\n  data() {\n    return {\n      searchKeyword: '',\n      selectedCategory: '',\n      selectedStage: '',\n      activeTab: '',\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      notificationVisible: false,\n      notifications: [],\n      unreadCount: 0,\n      subscriptionVisible: false,\n      availableTags: [\n        '国家政策', '教育部文件', '院校政策',\n        '招生简章', '专业目录', '报名通知', '网报公告',\n        '考试大纲', '初试信息', '成绩查询', '国家线/复试线',\n        '复试通知', '复试经验', '调剂信息', '录取公示',\n        '备考指南', '经验分享', '复习方法', '考研常识',\n        '院校新闻', '学科排名', '招生宣讲'\n      ],\n      categoryGroups: [\n        { name: '政策公告', categories: ['国家政策', '教育部文件', '院校政策'] },\n        { name: '招生信息', categories: ['招生简章', '专业目录', '报名通知', '网报公告'] },\n        { name: '考试资讯', categories: ['考试大纲', '初试信息', '成绩查询', '国家线/复试线'] },\n        { name: '复试调剂', categories: ['复试通知', '复试经验', '调剂信息', '录取公示'] },\n        { name: '备考指导', categories: ['备考指南', '经验分享', '复习方法', '考研常识'] },\n        { name: '院校动态', categories: ['院校新闻', '学科排名', '招生宣讲'] }\n      ],\n      selectedTags: []\n    }\n  },\n  created() {\n    this.getNewsList()\n    this.getUnreadCount()\n  },\n  mounted() {\n    if (this.$route.query.showNotifications === '1') {\n      this.$nextTick(() => { this.showNotifications() })\n    }\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return ''\n      return new Date(time).toLocaleDateString('zh-CN')\n    },\n    goToDetail(id) {\n      this.$router.push(`/news/${id}`)\n    },\n    switchTab(tabName) {\n      this.activeTab = tabName\n      // 根据选中的 tab 过滤分类\n      if (tabName === '') {\n        this.selectedCategory = ''\n      } else {\n        const group = this.categoryGroups.find(g => g.name === tabName)\n        // 切换tab时不清空具体分类，但若当前分类不在该组内则重置\n        if (group && !group.categories.includes(this.selectedCategory)) {\n          this.selectedCategory = ''\n        }\n      }\n      this.search()\n    },\n    search() {\n      this.currentPage = 1\n      this.getNewsList()\n    },\n    resetFilters() {\n      this.currentPage = 1\n      this.searchKeyword = ''\n      this.selectedCategory = ''\n      this.selectedStage = ''\n      this.getNewsList()\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getNewsList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getNewsList()\n    },\n    async getNewsList() {\n      try {\n        // 确定 category 参数：优先使用具体分类，其次使用tab分组\n        let categoryParam = this.selectedCategory || undefined\n        if (!categoryParam && this.activeTab) {\n          const group = this.categoryGroups.find(g => g.name === this.activeTab)\n          if (group) {\n            categoryParam = group.categories.join(',')\n          }\n        }\n        const res = await this.$http.get('/news/list', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize,\n            category: categoryParam,\n            examStage: this.selectedStage || undefined,\n            keyword: this.searchKeyword || undefined\n          }\n        })\n        this.newsList = res?.records || []\n        this.total = res?.total || 0\n      } catch (error) {\n        console.error('获取资讯列表失败:', error)\n      }\n    },\n    async showNotifications() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token\n      if (!token) {\n        this.$message.warning('请先登录')\n        this.$router.push('/login')\n        return\n      }\n      this.notificationVisible = true\n      await this.getNotifications()\n    },\n    async getNotifications() {\n      try {\n        const res = await this.$http.get('/notification/list', {\n          params: {\n            page: 1,\n            size: 50\n          }\n        })\n        this.notifications = res?.records || []\n      } catch (error) {\n        console.error(error)\n        if (error.response && error.response.status === 401) {\n          this.$message.warning('登录已过期，请重新登录')\n          this.$router.push('/login')\n        }\n      }\n    },\n    async getUnreadCount() {\n      try {\n        const res = await this.$http.get('/notification/unread-count')\n        this.unreadCount = res || 0\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    async markAsRead(id) {\n      try {\n        await this.$http.post(`/notification/read/${id}`)\n        await this.getNotifications()\n        await this.getUnreadCount()\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    async markAllAsRead() {\n      try {\n        await this.$http.post('/notification/read-all')\n        await this.getNotifications()\n        await this.getUnreadCount()\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    showSubscriptionDialog() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token\n      if (!token) {\n        this.$message.warning('请先登录')\n        this.$router.push('/login')\n        return\n      }\n      this.subscriptionVisible = true\n      this.getSubscriptions()\n    },\n    async getSubscriptions() {\n      try {\n        const res = await this.$http.get('/news/subscriptions')\n        this.selectedTags = Array.isArray(res) ? res : []\n      } catch (error) {\n        console.error('获取订阅标签失败:', error)\n      }\n    },\n    async saveSubscriptions() {\n      try {\n        // 先获取当前已订阅的标签\n        const currentSubs = await this.$http.get('/news/subscriptions')\n        const currentTags = Array.isArray(currentSubs) ? currentSubs : []\n\n        // 取消已取消勾选的标签\n        const toUnsubscribe = currentTags.filter(tag => !this.selectedTags.includes(tag))\n        for (const tag of toUnsubscribe) {\n          await this.$http.post(`/news/unsubscribe/${encodeURIComponent(tag)}`)\n        }\n\n        // 订阅新勾选的标签\n        const toSubscribe = this.selectedTags.filter(tag => !currentTags.includes(tag))\n        for (const tag of toSubscribe) {\n          await this.$http.post(`/news/subscribe/${encodeURIComponent(tag)}`)\n        }\n\n        this.$message.success('订阅保存成功')\n        this.subscriptionVisible = false\n      } catch (error) {\n        console.error('保存订阅标签失败:', error)\n        this.$message.error('保存订阅失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.news {\n  .news-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 16px;\n    padding-bottom: 16px;\n    border-bottom: 1px solid #ebeef5;\n\n    h1 {\n      font-size: 24px;\n      color: #303133;\n      margin: 0;\n    }\n\n    .header-actions {\n      display: flex;\n      gap: 10px;\n    }\n  }\n\n  .category-tabs {\n    display: flex;\n    gap: 0;\n    margin-bottom: 16px;\n    border-bottom: 2px solid #ebeef5;\n    overflow-x: auto;\n\n    .category-tab {\n      padding: 10px 18px;\n      cursor: pointer;\n      font-size: 14px;\n      color: #606266;\n      white-space: nowrap;\n      transition: all 0.3s;\n      border-bottom: 2px solid transparent;\n      margin-bottom: -2px;\n      user-select: none;\n\n      &:hover {\n        color: #409EFF;\n      }\n\n      &.active {\n        color: #409EFF;\n        border-bottom-color: #409EFF;\n        font-weight: 600;\n      }\n    }\n  }\n\n  .news-filter {\n    display: flex;\n    align-items: center;\n    margin-bottom: 20px;\n    padding: 12px;\n    background: #f5f7fa;\n    border-radius: 6px;\n  }\n\n  .top-news {\n    background: #fef0f0;\n    border-radius: 6px;\n    padding: 10px 16px;\n    margin-bottom: 20px;\n\n    .top-new