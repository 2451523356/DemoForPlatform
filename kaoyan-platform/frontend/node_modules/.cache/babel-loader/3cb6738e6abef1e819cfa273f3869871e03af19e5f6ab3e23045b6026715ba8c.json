{"ast":null,"code":"import \"core-js/modules/es.set.difference.v2.js\";\nimport \"core-js/modules/es.set.intersection.v2.js\";\nimport \"core-js/modules/es.set.is-disjoint-from.v2.js\";\nimport \"core-js/modules/es.set.is-subset-of.v2.js\";\nimport \"core-js/modules/es.set.is-superset-of.v2.js\";\nimport \"core-js/modules/es.set.symmetric-difference.v2.js\";\nimport \"core-js/modules/es.set.union.v2.js\";\nimport { mapGetters } from 'vuex';\nexport default {\n  name: 'PostDetail',\n  data() {\n    return {\n      post: {\n        id: 0,\n        title: '',\n        content: '',\n        authorName: '',\n        authorAvatar: '',\n        topic: '',\n        likeCount: 0,\n        commentCount: 0,\n        createTime: ''\n      },\n      comments: [],\n      commentContent: '',\n      liked: false,\n      likedComments: new Set()\n    };\n  },\n  computed: {\n    ...mapGetters('user', ['isLoggedIn', 'userInfo']),\n    currentUserId() {\n      return this.userInfo ? this.userInfo.id : null;\n    }\n  },\n  created() {\n    this.getPostDetail();\n    this.getComments();\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return '';\n      try {\n        // 处理 LocalDateTime 格式的时间\n        if (typeof time === 'string' && time.includes('T')) {\n          time = time.replace('T', ' ');\n        }\n        return new Date(time).toLocaleDateString('zh-CN');\n      } catch (error) {\n        console.error('时间格式化失败:', error);\n        return time;\n      }\n    },\n    async likePost() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了');\n        return;\n      }\n      try {\n        await this.$http.post(`/community/post/${this.post.id}/like`);\n        this.post.likeCount++;\n        this.liked = true;\n        this.$message.success('点赞成功');\n      } catch (error) {\n        console.error('点赞失败:', error);\n        this.$message.error('点赞失败，请稍后重试');\n      }\n    },\n    sharePost() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.post.title,\n          url: window.location.href\n        });\n      }\n    },\n    async likeComment(comment) {\n      if (this.likedComments.has(comment.id)) {\n        this.$message.warning('您已经点过赞了');\n        return;\n      }\n      try {\n        await this.$http.post(`/community/comment/${comment.id}/like`);\n        // 同时更新 likes 和 likeCount 字段\n        comment.likes = (comment.likes || comment.likeCount || 0) + 1;\n        comment.likeCount = comment.likes;\n        this.likedComments.add(comment.id);\n        this.$message.success('点赞成功');\n      } catch (error) {\n        console.error('点赞失败:', error);\n        this.$message.error('点赞失败，请稍后重试');\n      }\n    },\n    async submitComment() {\n      if (!this.commentContent.trim()) {\n        return;\n      }\n      try {\n        console.log('提交评论，帖子ID:', this.post.id);\n        const res = await this.$http.post('/community/comment', {\n          postId: this.post.id,\n          content: this.commentContent\n        });\n        console.log('评论提交响应:', res);\n\n        // 响应成功，添加评论到前端\n        const newComment = {\n          id: res?.id || Date.now(),\n          avatar: '',\n          username: '当前用户',\n          content: this.commentContent,\n          likes: 0,\n          likeCount: 0,\n          createTime: new Date().toISOString()\n        };\n        this.comments.unshift(newComment);\n        this.commentContent = '';\n        this.post.commentCount++;\n        this.$message.success('评论成功');\n      } catch (error) {\n        console.error('评论失败:', error);\n        this.$message.error('评论失败，请稍后重试');\n      }\n    },\n    async getPostDetail() {\n      try {\n        const id = this.$route.params.id;\n        console.log('获取帖子详情，帖子 ID:', id);\n        const res = await this.$http.get(`/community/post/${id}`);\n        console.log('帖子详情响应:', res);\n        // 拦截器已经返回 res.data，直接使用\n        this.post = res || {};\n        console.log('帖子详情数据:', this.post);\n      } catch (error) {\n        console.error('获取帖子详情失败:', error);\n        this.$message.error('获取帖子详情失败');\n      }\n    },\n    async getComments() {\n      try {\n        const id = this.$route.params.id;\n        console.log('获取评论的帖子 ID:', id);\n        const res = await this.$http.get(`/community/post/${id}/comments`);\n        console.log('获取评论的响应:', res);\n        // 确保 comments 是数组\n        if (Array.isArray(res)) {\n          this.comments = res;\n        } else {\n          this.comments = [];\n          console.error('获取评论失败：响应数据不是数组');\n        }\n        console.log('获取到的评论:', this.comments);\n      } catch (error) {\n        console.error('获取评论失败:', error);\n        this.comments = [];\n      }\n    },\n    async deleteComment(commentId) {\n      try {\n        await this.$confirm('确定要删除这条评论吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        await this.$http.delete(`/community/comment/${commentId}`);\n        this.$message.success('删除成功');\n        // 重新获取评论列表\n        await this.getComments();\n        // 更新评论数\n        this.post.commentCount--;\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除评论失败:', error);\n          this.$message.error('删除失败，请稍后重试');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapGetters","name","data","post","id","title","content","authorName","authorAvatar","topic","likeCount","commentCount","createTime","comments","commentContent","liked","likedComments","Set","computed","currentUserId","userInfo","created","getPostDetail","getComments","methods","formatTime","time","includes","replace","Date","toLocaleDateString","error","console","likePost","$message","warning","$http","success","sharePost","navigator","share","url","window","location","href","likeComment","comment","has","likes","add","submitComment","trim","log","res","postId","newComment","now","avatar","username","toISOString","unshift","$route","params","get","Array","isArray","deleteComment","commentId","$confirm","confirmButtonText","cancelButtonText","type","delete"],"sources":["src/views/community/PostDetail.vue"],"sourcesContent":["<template>\n  <div class=\"post-detail\">\n    <el-backtop :right=\"40\" :bottom=\"40\" />\n\n    <div class=\"post-header\">\n      <el-button type=\"primary\" @click=\"$router.back()\" plain>\n        <i class=\"el-icon-arrow-left\"></i> 返回\n      </el-button>\n      <div class=\"post-info\">\n        <div class=\"author-info\">\n          <el-avatar :size=\"50\" :src=\"post.authorAvatar\"></el-avatar>\n          <div class=\"author-meta\">\n            <h3 class=\"author-name\">{{ post.authorName }}</h3>\n            <span class=\"post-time\">{{ post.createTime }}</span>\n          </div>\n        </div>\n        <h1 class=\"post-title\">{{ post.title }}</h1>\n        <div class=\"post-meta\">\n          <span class=\"topic\">{{ post.topic }}</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"post-content\" v-html=\"post.content\"></div>\n\n    <div class=\"post-actions\">\n      <el-button @click=\"likePost\">\n        <i class=\"el-icon-star-off\"></i> 点赞 ({{ post.likeCount }})\n      </el-button>\n      <el-button @click=\"sharePost\">\n        <i class=\"el-icon-share\"></i> 分享\n      </el-button>\n    </div>\n\n    <div class=\"comments-section\">\n      <h3>评论 ({{ comments.length }})</h3>\n      <div class=\"comment-form\">\n        <el-input\n          v-model=\"commentContent\"\n          type=\"textarea\"\n          :rows=\"3\"\n          placeholder=\"写下你的评论...\"\n        ></el-input>\n        <el-button type=\"primary\" @click=\"submitComment\" class=\"comment-btn\">提交评论</el-button>\n      </div>\n      <div class=\"comments-list\">\n        <el-card v-for=\"comment in comments\" :key=\"comment.id\" class=\"comment-card\">\n          <div class=\"comment-header\">\n            <el-avatar :size=\"32\" :src=\"comment.avatar || ''\"></el-avatar>\n            <div class=\"comment-meta\">\n              <span class=\"comment-author\">{{ comment.username || '用户' + comment.userId }}</span>\n              <span class=\"comment-time\">{{ formatTime(comment.createTime) }}</span>\n            </div>\n          </div>\n          <div class=\"comment-content\">{{ comment.content }}</div>\n          <div class=\"comment-actions\">\n            <span @click=\"likeComment(comment)\">\n              <i class=\"el-icon-star-off\"></i> {{ comment.likes || comment.likeCount || 0 }}\n            </span>\n            <span v-if=\"isLoggedIn && comment.userId === currentUserId\" @click=\"deleteComment(comment.id)\" class=\"delete-btn\">\n              <i class=\"el-icon-delete\"></i> 删除\n            </span>\n          </div>\n        </el-card>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { mapGetters } from 'vuex'\n\nexport default {\n  name: 'PostDetail',\n  data() {\n    return {\n      post: {\n        id: 0,\n        title: '',\n        content: '',\n        authorName: '',\n        authorAvatar: '',\n        topic: '',\n        likeCount: 0,\n        commentCount: 0,\n        createTime: ''\n      },\n      comments: [],\n      commentContent: '',\n      liked: false,\n      likedComments: new Set()\n    }\n  },\n  computed: {\n    ...mapGetters('user', ['isLoggedIn', 'userInfo']),\n    currentUserId() {\n      return this.userInfo ? this.userInfo.id : null\n    }\n  },\n  created() {\n    this.getPostDetail()\n    this.getComments()\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return ''\n      try {\n        // 处理 LocalDateTime 格式的时间\n        if (typeof time === 'string' && time.includes('T')) {\n          time = time.replace('T', ' ')\n        }\n        return new Date(time).toLocaleDateString('zh-CN')\n      } catch (error) {\n        console.error('时间格式化失败:', error)\n        return time\n      }\n    },\n    async likePost() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了')\n        return\n      }\n\n      try {\n        await this.$http.post(`/community/post/${this.post.id}/like`)\n        this.post.likeCount++\n        this.liked = true\n        this.$message.success('点赞成功')\n      } catch (error) {\n        console.error('点赞失败:', error)\n        this.$message.error('点赞失败，请稍后重试')\n      }\n    },\n    sharePost() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.post.title,\n          url: window.location.href\n        })\n      }\n    },\n    async likeComment(comment) {\n      if (this.likedComments.has(comment.id)) {\n        this.$message.warning('您已经点过赞了')\n        return\n      }\n\n      try {\n        await this.$http.post(`/community/comment/${comment.id}/like`)\n        // 同时更新 likes 和 likeCount 字段\n        comment.likes = (comment.likes || comment.likeCount || 0) + 1\n        comment.likeCount = comment.likes\n        this.likedComments.add(comment.id)\n        this.$message.success('点赞成功')\n      } catch (error) {\n        console.error('点赞失败:', error)\n        this.$message.error('点赞失败，请稍后重试')\n      }\n    },\n    async submitComment() {\n      if (!this.commentContent.trim()) {\n        return\n      }\n\n      try {\n        console.log('提交评论，帖子ID:', this.post.id)\n        const res = await this.$http.post('/community/comment', {\n          postId: this.post.id,\n          content: this.commentContent\n        })\n\n        console.log('评论提交响应:', res)\n\n        // 响应成功，添加评论到前端\n        const newComment = {\n          id: res?.id || Date.now(),\n          avatar: '',\n          username: '当前用户',\n          content: this.commentContent,\n          likes: 0,\n          likeCount: 0,\n          createTime: new Date().toISOString()\n        }\n        this.comments.unshift(newComment)\n        this.commentContent = ''\n        this.post.commentCount++\n        this.$message.success('评论成功')\n      } catch (error) {\n        console.error('评论失败:', error)\n        this.$message.error('评论失败，请稍后重试')\n      }\n    },\n    async getPostDetail() {\n      try {\n        const id = this.$route.params.id\n        console.log('获取帖子详情，帖子 ID:', id)\n        const res = await this.$http.get(`/community/post/${id}`)\n        console.log('帖子详情响应:', res)\n        // 拦截器已经返回 res.data，直接使用\n        this.post = res || {}\n        console.log('帖子详情数据:', this.post)\n      } catch (error) {\n        console.error('获取帖子详情失败:', error)\n        this.$message.error('获取帖子详情失败')\n      }\n    },\n    async getComments() {\n      try {\n        const id = this.$route.params.id\n        console.log('获取评论的帖子 ID:', id)\n        const res = await this.$http.get(`/community/post/${id}/comments`)\n        console.log('获取评论的响应:', res)\n        // 确保 comments 是数组\n        if (Array.isArray(res)) {\n          this.comments = res\n        } else {\n          this.comments = []\n          console.error('获取评论失败：响应数据不是数组')\n        }\n        console.log('获取到的评论:', this.comments)\n      } catch (error) {\n        console.error('获取评论失败:', error)\n        this.comments = []\n      }\n    },\n    async deleteComment(commentId) {\n      try {\n        await this.$confirm('确定要删除这条评论吗？', '提示', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        })\n\n        await this.$http.delete(`/community/comment/${commentId}`)\n        this.$message.success('删除成功')\n        // 重新获取评论列表\n        await this.getComments()\n        // 更新评论数\n        this.post.commentCount--\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('删除评论失败:', error)\n          this.$message.error('删除失败，请稍后重试')\n        }\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.post-detail {\n  padding: 20px;\n\n  .post-header {\n    margin-bottom: 30px;\n\n    .post-info {\n      margin-top: 20px;\n\n      .author-info {\n        display: flex;\n        align-items: center;\n        gap: 15px;\n        margin-bottom: 20px;\n\n        .author-meta {\n          .author-name {\n            font-size: 18px;\n            font-weight: bold;\n            margin: 0 0 5px 0;\n          }\n          .post-time {\n            font-size: 14px;\n            color: #909399;\n          }\n        }\n      }\n\n      .post-title {\n        font-size: 24px;\n        color: #303133;\n        margin: 0 0 15px 0;\n      }\n\n      .post-meta {\n        .topic {\n          background: #ECF5FF;\n          color: #409EFF;\n          padding: 4px 12px;\n          border-radius: 4px;\n          font-size: 14px;\n        }\n      }\n    }\n  }\n\n  .post-content {\n    margin-bottom: 30px;\n    line-height: 1.8;\n    font-size: 16px;\n    color: #303133;\n  }\n\n  .post-actions {\n    margin-bottom: 40px;\n    display: flex;\n    gap: 20px;\n  }\n\n  .comments-section {\n    h3 {\n      font-size: 18px;\n      margin-bottom: 20px;\n      color: #303133;\n    }\n\n    .comment-form {\n      margin-bottom: 30px;\n\n      .comment-btn {\n        margin-top: 10px;\n      }\n    }\n\n    .comments-list {\n      .comment-card {\n        margin-bottom: 15px;\n\n        .comment-header {\n          display: flex;\n          align-items: center;\n          gap: 10px;\n          margin-bottom: 10px;\n\n          .comment-meta {\n            .comment-author {\n              font-weight: bold;\n              font-size: 14px;\n            }\n            .comment-time {\n              font-size: 12px;\n              color: #909399;\n              margin-left: 10px;\n            }\n          }\n        }\n\n        .comment-content {\n          margin-bottom: 10px;\n          line-height: 1.5;\n        }\n\n        .comment-actions {\n          font-size: 14px;\n          color: #909399;\n          display: flex;\n          gap: 15px;\n\n          .delete-btn {\n            color: #F56C6C;\n\n            &:hover {\n              color: #F78989;\n            }\n          }\n\n          span {\n            cursor: pointer;\n\n            &:hover {\n              color: #409EFF;\n            }\n\n            i {\n              margin-right: 5px;\n            }\n          }\n        }\n      }\n    }\n  }\n}\n</style>\n"],"mappings":";;;;;;;AAsEA,SAAAA,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;QACAC,EAAA;QACAC,KAAA;QACAC,OAAA;QACAC,UAAA;QACAC,YAAA;QACAC,KAAA;QACAC,SAAA;QACAC,YAAA;QACAC,UAAA;MACA;MACAC,QAAA;MACAC,cAAA;MACAC,KAAA;MACAC,aAAA,MAAAC,GAAA;IACA;EACA;EACAC,QAAA;IACA,GAAAlB,UAAA;IACAmB,cAAA;MACA,YAAAC,QAAA,QAAAA,QAAA,CAAAhB,EAAA;IACA;EACA;EACAiB,QAAA;IACA,KAAAC,aAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAC,WAAAC,IAAA;MACA,KAAAA,IAAA;MACA;QACA;QACA,WAAAA,IAAA,iBAAAA,IAAA,CAAAC,QAAA;UACAD,IAAA,GAAAA,IAAA,CAAAE,OAAA;QACA;QACA,WAAAC,IAAA,CAAAH,IAAA,EAAAI,kBAAA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,aAAAA,KAAA;QACA,OAAAL,IAAA;MACA;IACA;IACA,MAAAO,SAAA;MACA,SAAAlB,KAAA;QACA,KAAAmB,QAAA,CAAAC,OAAA;QACA;MACA;MAEA;QACA,WAAAC,KAAA,CAAAjC,IAAA,yBAAAA,IAAA,CAAAC,EAAA;QACA,KAAAD,IAAA,CAAAO,SAAA;QACA,KAAAK,KAAA;QACA,KAAAmB,QAAA,CAAAG,OAAA;MACA,SAAAN,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAG,QAAA,CAAAH,KAAA;MACA;IACA;IACAO,UAAA;MACA,IAAAC,SAAA,CAAAC,KAAA;QACAD,SAAA,CAAAC,KAAA;UACAnC,KAAA,OAAAF,IAAA,CAAAE,KAAA;UACAoC,GAAA,EAAAC,MAAA,CAAAC,QAAA,CAAAC;QACA;MACA;IACA;IACA,MAAAC,YAAAC,OAAA;MACA,SAAA9B,aAAA,CAAA+B,GAAA,CAAAD,OAAA,CAAA1C,EAAA;QACA,KAAA8B,QAAA,CAAAC,OAAA;QACA;MACA;MAEA;QACA,WAAAC,KAAA,CAAAjC,IAAA,uBAAA2C,OAAA,CAAA1C,EAAA;QACA;QACA0C,OAAA,CAAAE,KAAA,IAAAF,OAAA,CAAAE,KAAA,IAAAF,OAAA,CAAApC,SAAA;QACAoC,OAAA,CAAApC,SAAA,GAAAoC,OAAA,CAAAE,KAAA;QACA,KAAAhC,aAAA,CAAAiC,GAAA,CAAAH,OAAA,CAAA1C,EAAA;QACA,KAAA8B,QAAA,CAAAG,OAAA;MACA,SAAAN,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAG,QAAA,CAAAH,KAAA;MACA;IACA;IACA,MAAAmB,cAAA;MACA,UAAApC,cAAA,CAAAqC,IAAA;QACA;MACA;MAEA;QACAnB,OAAA,CAAAoB,GAAA,oBAAAjD,IAAA,CAAAC,EAAA;QACA,MAAAiD,GAAA,cAAAjB,KAAA,CAAAjC,IAAA;UACAmD,MAAA,OAAAnD,IAAA,CAAAC,EAAA;UACAE,OAAA,OAAAQ;QACA;QAEAkB,OAAA,CAAAoB,GAAA,YAAAC,GAAA;;QAEA;QACA,MAAAE,UAAA;UACAnD,EAAA,EAAAiD,GAAA,EAAAj