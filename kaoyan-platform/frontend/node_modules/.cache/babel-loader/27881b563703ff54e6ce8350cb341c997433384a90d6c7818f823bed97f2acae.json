{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.set.difference.v2.js\";\nimport \"core-js/modules/es.set.intersection.v2.js\";\nimport \"core-js/modules/es.set.is-disjoint-from.v2.js\";\nimport \"core-js/modules/es.set.is-subset-of.v2.js\";\nimport \"core-js/modules/es.set.is-superset-of.v2.js\";\nimport \"core-js/modules/es.set.symmetric-difference.v2.js\";\nimport \"core-js/modules/es.set.union.v2.js\";\nimport * as echarts from 'echarts';\nexport default {\n  name: 'SchoolDetail',\n  data() {\n    return {\n      school: {},\n      loading: false,\n      activeTab: 'overview',\n      // 分数线\n      scoreLines: [],\n      scoreYear: null,\n      scoreMajor: '',\n      scorePage: 1,\n      scoreSize: 10,\n      scoreTotal: 0,\n      years: [2024, 2023, 2022, 2021],\n      myScore: {\n        political: 60,\n        english: 60,\n        course1: 110,\n        course2: 110\n      },\n      targetMajor: '',\n      gapResult: null,\n      chartInstance: null,\n      // 报录比\n      ratioData: [],\n      ratioLoading: false,\n      // 专业目录\n      majorList: []\n    };\n  },\n  computed: {\n    myTotal() {\n      return this.myScore.political + this.myScore.english + this.myScore.course1 + this.myScore.course2;\n    },\n    majorOptions() {\n      return [...new Set(this.scoreLines.map(s => s.major))];\n    }\n  },\n  created() {\n    this.fetchSchool();\n    this.fetchScoreLines();\n  },\n  methods: {\n    async fetchSchool() {\n      this.loading = true;\n      try {\n        const res = await this.$http.get(`/school/detail/${this.$route.params.id}`);\n        this.school = res || {};\n      } catch (e) {\n        console.error(e);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async fetchScoreLines() {\n      try {\n        const res = await this.$http.get(`/school/${this.$route.params.id}/score-lines`, {\n          params: {\n            year: this.scoreYear || undefined,\n            major: this.scoreMajor || undefined,\n            page: this.scorePage,\n            size: this.scoreSize\n          }\n        });\n        this.scoreLines = res?.records || [];\n        this.scoreTotal = res?.total || 0;\n        this.buildRatioAndMajor();\n        this.$nextTick(() => this.renderChart());\n      } catch (e) {\n        console.error(e);\n      }\n    },\n    handleTabClick(tab) {\n      if (tab.name === 'score') this.$nextTick(() => this.renderChart());\n      if (tab.name === 'ratio') this.buildRatioAndMajor();\n      if (tab.name === 'major') this.buildRatioAndMajor();\n    },\n    buildRatioAndMajor() {\n      this.ratioData = [...this.scoreLines].filter(s => s.applicantCount && s.admitCount);\n      // 构建专业目录汇总\n      const majorMap = {};\n      this.scoreLines.forEach(s => {\n        if (!majorMap[s.major]) {\n          majorMap[s.major] = {\n            major: s.major,\n            majorCode: s.majorCode || '',\n            degreeType: s.degreeType || '硕士',\n            scores: [],\n            ratios: [],\n            years: []\n          };\n        }\n        majorMap[s.major].scores.push(s.totalScore);\n        if (s.applicantCount && s.admitCount) majorMap[s.major].ratios.push(s.applicantCount / s.admitCount);\n        majorMap[s.major].years.push(s.year);\n      });\n      this.majorList = Object.values(majorMap).map(m => ({\n        ...m,\n        minScore: Math.min(...m.scores),\n        maxScore: Math.max(...m.scores),\n        minRatio: m.ratios.length > 0 ? Math.min(...m.ratios).toFixed(1) : '-',\n        maxRatio: m.ratios.length > 0 ? Math.max(...m.ratios).toFixed(1) : '-',\n        dataYears: [...new Set(m.years)].length\n      }));\n    },\n    handleScorePage(p) {\n      this.scorePage = p;\n      this.fetchScoreLines();\n    },\n    analyzeGap() {\n      const major = this.targetMajor || (this.scoreLines.length > 0 ? this.scoreLines[0].major : '');\n      if (!major) {\n        this.$message.warning('请先选择参考专业');\n        return;\n      }\n      const latestLine = this.scoreLines.filter(s => s.major === major).sort((a, b) => b.year - a.year)[0];\n      if (!latestLine) {\n        this.$message.warning('未找到该专业的分数线数据');\n        return;\n      }\n      const details = [{\n        label: '政治',\n        mine: this.myScore.political,\n        line: latestLine.politicalScore || 0,\n        gap: this.myScore.political - (latestLine.politicalScore || 0)\n      }, {\n        label: '英语',\n        mine: this.myScore.english,\n        line: latestLine.englishScore || 0,\n        gap: this.myScore.english - (latestLine.englishScore || 0)\n      }, {\n        label: '业务课1',\n        mine: this.myScore.course1,\n        line: latestLine.course1Score || 0,\n        gap: this.myScore.course1 - (latestLine.course1Score || 0)\n      }];\n      if (latestLine.course2Score) details.push({\n        label: '业务课2',\n        mine: this.myScore.course2,\n        line: latestLine.course2Score,\n        gap: this.myScore.course2 - latestLine.course2Score\n      });\n      this.gapResult = {\n        year: latestLine.year,\n        major: latestLine.major,\n        refTotal: latestLine.totalScore,\n        totalGap: this.myTotal - latestLine.totalScore,\n        admitCount: latestLine.admitCount,\n        applicantCount: latestLine.applicantCount,\n        details\n      };\n    },\n    renderChart() {\n      if (!this.$refs.chartDom) return;\n      if (!this.chartInstance) this.chartInstance = echarts.init(this.$refs.chartDom);\n      const majors = [...new Set(this.scoreLines.map(s => s.major))].slice(0, 5);\n      const allYears = [...new Set(this.scoreLines.map(s => s.year))].sort();\n      if (allYears.length === 0) {\n        this.chartInstance.setOption({\n          title: {\n            text: '暂无数据',\n            left: 'center',\n            top: 'middle',\n            textStyle: {\n              color: '#C0C4CC'\n            }\n          }\n        });\n        return;\n      }\n      this.chartInstance.setOption({\n        tooltip: {\n          trigger: 'axis'\n        },\n        legend: {\n          data: majors,\n          bottom: 0\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '15%',\n          containLabel: true\n        },\n        xAxis: {\n          type: 'category',\n          data: allYears.map(y => y + '年')\n        },\n        yAxis: {\n          type: 'value',\n          name: '总分',\n          min: 250\n        },\n        series: majors.map(m => ({\n          name: m,\n          type: 'line',\n          smooth: true,\n          data: allYears.map(y => {\n            const item = this.scoreLines.find(s => s.major === m && s.year === y);\n            return item ? item.totalScore : null;\n          }),\n          label: {\n            show: true,\n            position: 'top'\n          }\n        }))\n      });\n      window.addEventListener('resize', () => this.chartInstance && this.chartInstance.resize());\n    }\n  },\n  beforeDestroy() {\n    if (this.chartInstance) this.chartInstance.dispose();\n  }\n};","map":{"version":3,"names":["echarts","name","data","school","loading","activeTab","scoreLines","scoreYear","scoreMajor","scorePage","scoreSize","scoreTotal","years","myScore","political","english","course1","course2","targetMajor","gapResult","chartInstance","ratioData","ratioLoading","majorList","computed","myTotal","majorOptions","Set","map","s","major","created","fetchSchool","fetchScoreLines","methods","res","$http","get","$route","params","id","e","console","error","year","undefined","page","size","records","total","buildRatioAndMajor","$nextTick","renderChart","handleTabClick","tab","filter","applicantCount","admitCount","majorMap","forEach","majorCode","degreeType","scores","ratios","push","totalScore","Object","values","m","minScore","Math","min","maxScore","max","minRatio","length","toFixed","maxRatio","dataYears","handleScorePage","p","analyzeGap","$message","warning","latestLine","sort","a","b","details","label","mine","line","politicalScore","gap","englishScore","course1Score","course2Score","refTotal","totalGap","$refs","chartDom","init","majors","slice","allYears","setOption","title","text","left","top","textStyle","color","tooltip","trigger","legend","bottom","grid","right","containLabel","xAxis","type","y","yAxis","series","smooth","item","find","show","position","window","addEventListener","resize","beforeDestroy","dispose"],"sources":["src/views/school/SchoolDetail.vue"],"sourcesContent":["<template>\n  <div class=\"school-detail\" v-loading=\"loading\">\n    <!-- 顶部学校信息横幅 -->\n    <div class=\"school-banner\">\n      <el-button type=\"text\" icon=\"el-icon-arrow-left\" @click=\"$router.back()\" class=\"back-btn\">返回院校库</el-button>\n      <div class=\"banner-main\">\n        <div class=\"banner-left\">\n          <h1>{{ school.name }}</h1>\n          <div class=\"banner-tags\">\n            <el-tag :type=\"school.type==='985'?'danger':school.type==='211'?'warning':school.type==='双一流'?'success':'info'\" size=\"medium\">{{ school.type }}</el-tag>\n            <el-tag v-if=\"school.isSelfDrawing\" type=\"danger\" size=\"medium\">自主划线</el-tag>\n            <span class=\"banner-meta\" v-if=\"school.affiliation\"><i class=\"el-icon-school\"></i> {{ school.affiliation }}直属</span>\n            <span class=\"banner-meta\"><i class=\"el-icon-location-outline\"></i> {{ school.province }} {{ school.city }}</span>\n            <span class=\"banner-meta\" v-if=\"school.ranking\"><i class=\"el-icon-medal\"></i> 全国排名第{{ school.ranking }}名</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Tab导航 -->\n    <el-tabs v-model=\"activeTab\" @tab-click=\"handleTabClick\" class=\"detail-tabs\" type=\"border-card\">\n      <!-- ========== 概况 Tab ========== -->\n      <el-tab-pane label=\"院校概况\" name=\"overview\">\n        <div class=\"overview-content\">\n          <el-card class=\"info-card\">\n            <h3 slot=\"header\"><i class=\"el-icon-info\"></i> 基本信息</h3>\n            <el-descriptions :column=\"3\" border size=\"medium\">\n              <el-descriptions-item label=\"院校名称\">{{ school.name }}</el-descriptions-item>\n              <el-descriptions-item label=\"院校类型\">{{ school.type }}</el-descriptions-item>\n              <el-descriptions-item label=\"所在地\">{{ school.province }} · {{ school.city }}</el-descriptions-item>\n              <el-descriptions-item label=\"隶属部门\">{{ school.affiliation || '暂无' }}</el-descriptions-item>\n              <el-descriptions-item label=\"建校年份\">{{ school.establishedYear || '暂无' }}年</el-descriptions-item>\n              <el-descriptions-item label=\"全国排名\">第 {{ school.ranking || '-' }} 名</el-descriptions-item>\n              <el-descriptions-item label=\"自主划线\">{{ school.isSelfDrawing ? '是（34所自划线院校）' : '否' }}</el-descriptions-item>\n              <el-descriptions-item label=\"硕士点\">{{ school.masterPoints || '-' }} 个</el-descriptions-item>\n              <el-descriptions-item label=\"博士点\">{{ school.doctorPoints || '-' }} 个</el-descriptions-item>\n              <el-descriptions-item label=\"官网\" :span=\"3\">\n                <a v-if=\"school.website\" :href=\"school.website\" target=\"_blank\" rel=\"noopener\">{{ school.website }}</a>\n                <span v-else>暂无</span>\n              </el-descriptions-item>\n            </el-descriptions>\n          </el-card>\n\n          <el-card class=\"info-card\" style=\"margin-top:20px\">\n            <h3 slot=\"header\"><i class=\"el-icon-document\"></i> 院校简介</h3>\n            <p class=\"intro-text\">{{ school.introduction || '暂无简介信息' }}</p>\n          </el-card>\n\n          <el-row :gutter=\"20\" style=\"margin-top:20px\">\n            <el-col :span=\"12\">\n              <el-card class=\"info-card\">\n                <h3 slot=\"header\"><i class=\"el-icon-star-off\"></i> 重点学科</h3>\n                <p v-if=\"school.keyDisciplines\" class=\"discipline-text\">{{ school.keyDisciplines }}</p>\n                <el-empty v-else description=\"暂无数据\" :image-size=\"60\"/>\n              </el-card>\n            </el-col>\n            <el-col :span=\"12\">\n              <el-card class=\"info-card\">\n                <h3 slot=\"header\"><i class=\"el-icon-office-building\"></i> 院系设置</h3>\n                <p v-if=\"school.departments\" class=\"discipline-text\">{{ school.departments }}</p>\n                <el-empty v-else description=\"暂无数据\" :image-size=\"60\"/>\n              </el-card>\n            </el-col>\n          </el-row>\n        </div>\n      </el-tab-pane>\n\n      <!-- ========== 分数线 Tab ========== -->\n      <el-tab-pane label=\"历年分数线\" name=\"score\">\n        <div class=\"score-content\">\n          <!-- 差距分析 -->\n          <el-card class=\"gap-card\">\n            <h3><i class=\"el-icon-data-analysis\"></i> 分数线差距分析</h3>\n            <el-row :gutter=\"12\" type=\"flex\" align=\"middle\" style=\"flex-wrap:wrap;margin-top:16px\">\n              <el-col :span=\"4\" :xs=\"12\"><div class=\"score-label\">政治</div><el-input-number v-model=\"myScore.political\" :min=\"0\" :max=\"150\" size=\"small\" controls-position=\"right\" style=\"width:100%\"/></el-col>\n              <el-col :span=\"4\" :xs=\"12\"><div class=\"score-label\">英语</div><el-input-number v-model=\"myScore.english\" :min=\"0\" :max=\"150\" size=\"small\" controls-position=\"right\" style=\"width:100%\"/></el-col>\n              <el-col :span=\"4\" :xs=\"12\"><div class=\"score-label\">业务课1</div><el-input-number v-model=\"myScore.course1\" :min=\"0\" :max=\"150\" size=\"small\" controls-position=\"right\" style=\"width:100%\"/></el-col>\n              <el-col :span=\"4\" :xs=\"12\"><div class=\"score-label\">业务课2</div><el-input-number v-model=\"myScore.course2\" :min=\"0\" :max=\"150\" size=\"small\" controls-position=\"right\" style=\"width:100%\"/></el-col>\n              <el-col :span=\"4\" :xs=\"12\"><div class=\"score-label\">参考专业</div><el-select v-model=\"targetMajor\" placeholder=\"选择专业\" size=\"small\" style=\"width:100%\" clearable><el-option v-for=\"m in majorOptions\" :key=\"m\" :label=\"m\" :value=\"m\"/></el-select></el-col>\n              <el-col :span=\"4\" :xs=\"24\"><el-button type=\"primary\" size=\"small\" @click=\"analyzeGap\" style=\"width:100%;margin-top:22px\"><i class=\"el-icon-search\"/> 差距分析</el-button></el-col>\n            </el-row>\n            <div v-if=\"gapResult\" class=\"gap-result\" style=\"margin-top:20px\">\n              <el-divider/>\n              <div class=\"gap-summary\">\n                <span class=\"my-total\">我的总分：<strong>{{ myTotal }}</strong> 分</span>\n                <span class=\"ref-total\">参考线（{{ gapResult.year }}年 {{ gapResult.major }}）：<strong>{{ gapResult.refTotal }}</strong> 分</span>\n                <span :class=\"['gap-verdict', gapResult.totalGap >= 0 ? 'pass' : 'fail']\">\n                  {{ gapResult.totalGap >= 0 ? `超出 ${gapResult.totalGap} 分` : `差距 ${Math.abs(gapResult.totalGap)} 分` }}\n                </span>\n                <span v-if=\"gapResult.admitCount\" class=\"ratio-info\">\n                  报录比 {{ (gapResult.applicantCount / gapResult.admitCount).toFixed(1) }}:1（录{{ gapResult.admitCount }}/报{{ gapResult.applicantCount }}）\n                </span>\n              </div>\n            </div>\n          </el-card>\n\n          <!-- 分数线表格 -->\n          <el-card style=\"margin-top:20px\">\n            <div class=\"filter-row\">\n              <el-select v-model=\"scoreYear\" @change=\"fetchScoreLines\" clearable placeholder=\"全部年份\" style=\"width:120px\"><el-option v-for=\"y in years\" :key=\"y\" :label=\"y+'年'\" :value=\"y\"/></el-select>\n              <el-input v-model=\"scoreMajor\" placeholder=\"搜索专业\" clearable style=\"width:200px\" @keyup.enter=\"fetchScoreLines\"/>\n              <el-button type=\"primary\" size=\"small\" @click=\"fetchScoreLines\" icon=\"el-icon-search\">查询</el-button>\n            </div>\n            <el-table :data=\"scoreLines\" stripe border style=\"margin-top:12px\">\n              <el-table-column prop=\"year\" label=\"年份\" width=\"75\" align=\"center\"/>\n              <el-table-column prop=\"major\" label=\"专业\" min-width=\"140\"/>\n              <el-table-column prop=\"majorCode\" label=\"专业代码\" width=\"100\" align=\"center\"/>\n              <el-table-column prop=\"totalScore\" label=\"总分\" width=\"75\" align=\"center\"><template slot-scope=\"s\"><strong style=\"color:#409EFF\">{{ s.row.totalScore }}</strong></template></el-table-column>\n              <el-table-column prop=\"politicalScore\" label=\"政治\" width=\"60\" align=\"center\"/>\n              <el-table-column prop=\"englishScore\" label=\"英语\" width=\"60\" align=\"center\"/>\n              <el-table-column prop=\"course1Score\" label=\"业务课1\" width=\"75\" align=\"center\"/>\n              <el-table-column prop=\"course2Score\" label=\"业务课2\" width=\"75\" align=\"center\"><template slot-scope=\"s\">{{ s.row.course2Score || '-' }}</template></el-table-column>\n              <el-table-column label=\"录取/报考\" width=\"90\" align=\"center\"><template slot-scope=\"s\">{{ s.row.admitCount||'-' }} / {{ s.row.applicantCount||'-' }}</template></el-table-column>\n              <el-table-column label=\"报录比\" width=\"80\" align=\"center\">\n                <template slot-scope=\"s\">\n                  <el-tag v-if=\"s.row.applicantCount && s.row.admitCount\" size=\"mini\" :type=\"(s.row.applicantCount/s.row.admitCount)>=10?'danger':(s.row.applicantCount/s.row.admitCount)>=5?'warning':'success'\">{{ (s.row.applicantCount/s.row.admitCount).toFixed(1) }}∶1</el-tag>\n                  <span v-else>-</span>\n                </template>\n              </el-table-column>\n            </el-table>\n            <el-pagination style=\"margin-top:12px\" small @current-change=\"handleScorePage\" :current-page=\"scorePage\" :page-size=\"scoreSize\" :total=\"scoreTotal\" layout=\"total,prev,pager,next\"/>\n          </el-card>\n\n          <!-- 趋势图 -->\n          <el-card style=\"margin-top:20px\">\n            <h3 style=\"margin:0 0 16px\"><i class=\"el-icon-trend-charts\"></i> 分数线趋势</h3>\n            <div ref=\"chartDom\" style=\"width:100%;height:350px\"/>\n          </el-card>\n        </div>\n      </el-tab-pane>\n\n      <!-- ========== 报录比 Tab ========== -->\n      <el-tab-pane label=\"报录比分析\" name=\"ratio\">\n        <el-card>\n          <h3 style=\"margin:0 0 16px\"><i class=\"el-icon-pie-chart\"></i> 各专业历年报录比统计</h3>\n          <el-table :data=\"ratioData\" stripe border v-loading=\"ratioLoading\">\n            <el-table-column prop=\"year\" label=\"年份\" width=\"80\" align=\"center\"/>\n            <el-table-column prop=\"major\" label=\"专业\" min-width=\"140\"/>\n            <el-table-column prop=\"admitCount\" label=\"录取人数\" width=\"90\" align=\"center\"/>\n            <el-table-column prop=\"applicantCount\" label=\"报考人数\" width=\"90\" align=\"center\"/>\n            <el-table-column label=\"报录比\" width=\"100\" align=\"center\">\n              <template slot-scope=\"s\">\n                <el-progress\n                  v-if=\"s.row.applicantCount && s.row.admitCount\"\n                  :percentage=\"Math.min(100, Math.round((s.row.admitCount / s.row.applicantCount) * 100))\"\n                  :color=\"s.row.applicantCount/s.row.admitCount >= 15 ? '#F56C6C' : s.row.applicantCount/s.row.admitCount >= 8 ? '#E6A23C' : '#67C23A'\"\n                  :format=\"() => (s.row.applicantCount/s.row.admitCount).toFixed(1)+':1'\"\n                  :stroke-width=\"20\"\n                />\n                <span v-else>-</span>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"录取率\" width=\"90\" align=\"center\">\n              <template slot-scope=\"s\">\n                <span v-if=\"s.row.applicantCount && s.row.admitCount\" :style=\"{ color: (s.row.admitCount/s.row.applicantCount) >= 0.1 ? '#67C23A' : '#F56C6C' }\">\n                  {{ (s.row.admitCount / s.row.applicantCount * 100).toFixed(1) }}%\n                </span>\n                <span v-else>-</span>\n              </template>\n            </el-table-column>\n          </el-table>\n          <el-empty v-if=\"ratioData.length === 0 && !ratioLoading\" description=\"暂无报录比数据\" :image-size=\"80\"/>\n        </el-card>\n      </el-tab-pane>\n\n      <!-- ========== 专业目录 Tab ========== -->\n      <el-tab-pane label=\"招生专业\" name=\"major\">\n        <el-card>\n          <h3 style=\"margin:0 0 16px\"><i class=\"el-icon-collection-tag\"></i> 招生专业一览</h3>\n          <el-table :data=\"majorList\" stripe border>\n            <el-table-column prop=\"major\" label=\"专业名称\" min-width=\"160\"/>\n            <el-table-column prop=\"majorCode\" label=\"专业代码\" width=\"100\" align=\"center\"/>\n            <el-table-column prop=\"degreeType\" label=\"学位类型\" width=\"90\" align=\"center\">\n              <template slot-scope=\"s\"><el-tag size=\"mini\" :type=\"s.row.degreeType==='硕士'?'':'info'\">{{ s.row.degreeType }}</el-tag></template>\n            </el-table-column>\n            <el-table-column label=\"近年复试线范围\" width=\"130\" align=\"center\">\n              <template slot-scope=\"s\">\n                <span style=\"color:#409EFF;font-weight:600\">{{ s.row.minScore }} - {{ s.row.maxScore }}</span>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"近年报录比范围\" width=\"130\" align=\"center\">\n              <template slot-scope=\"s\">\n                <el-tag size=\"mini\" :type=\"s.row.maxRatio >= 15 ? 'danger' : s.row.maxRatio >= 8 ? 'warning' : 'success'\">\n                  {{ s.row.minRatio }}:1 - {{ s.row.maxRatio }}:1\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"数据年份\" width=\"80\" align=\"center\">\n              <template slot-scope=\"s\">{{ s.row.dataYears }}年</template>\n            </el-table-column>\n          </el-table>\n          <el-empty v-if=\"majorList.length === 0\" description=\"暂无专业数据\" :image-size=\"80\"/>\n        </el-card>\n      </el-tab-pane>\n    </el-tabs>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nexport default {\n  name: 'SchoolDetail',\n  data() {\n    return {\n      school: {},\n      loading: false,\n      activeTab: 'overview',\n      // 分数线\n      scoreLines: [], scoreYear: null, scoreMajor: '', scorePage:1, scoreSize:10, scoreTotal:0,\n      years: [2024,2023,2022,2021],\n      myScore: { political:60, english:60, course1:110, course2:110 },\n      targetMajor: '', gapResult: null, chartInstance: null,\n      // 报录比\n      ratioData: [], ratioLoading: false,\n      // 专业目录\n      majorList: []\n    }\n  },\n  computed: {\n    myTotal() { return this.myScore.political + this.myScore.english + this.myScore.course1 + this.myScore.course2 },\n    majorOptions() { return [...new Set(this.scoreLines.map(s => s.major))] }\n  },\n  created() {\n    this.fetchSchool()\n    this.fetchScoreLines()\n  },\n  methods: {\n    async fetchSchool() {\n      this.loading = true\n      try { const res = await this.$http.get(`/school/detail/${this.$route.params.id}`); this.school = res || {} }\n      catch(e) { console.error(e) } finally { this.loading = false }\n    },\n    async fetchScoreLines() {\n      try {\n        const res = await this.$http.get(`/school/${this.$route.params.id}/score-lines`, {\n          params: { year: this.scoreYear||undefined, major: this.scoreMajor||undefined, page:this.scorePage, size:this.scoreSize }\n        })\n        this.scoreLines = res?.records || []; this.scoreTotal = res?.total || 0\n        this.buildRatioAndMajor()\n        this.$nextTick(() => this.renderChart())\n      } catch(e) { console.error(e) }\n    },\n    handleTabClick(tab) {\n      if (tab.name === 'score') this.$nextTick(() => this.renderChart())\n      if (tab.name === 'ratio') this.buildRatioAndMajor()\n      if (tab.name === 'major') this.buildRatioAndMajor()\n    },\n    buildRatioAndMajor() {\n      this.ratioData = [...this.scoreLines].filter(s => s.applicantCount && s.admitCount)\n      // 构建专业目录汇总\n      const majorMap = {}\n      this.scoreLines.forEach(s => {\n        if (!majorMap[s.major]) {\n          majorMap[s.major] = { major: s.major, majorCode: s.majorCode||'', degreeType: s.degreeType||'硕士', scores:[], ratios:[], years:[] }\n        }\n        majorMap[s.major].scores.push(s.totalScore)\n        if (s.applicantCount && s.admitCount) majorMap[s.major].ratios.push(s.applicantCount/s.admitCount)\n        majorMap[s.major].years.push(s.year)\n      })\n      this.majorList = Object.values(majorMap).map(m => ({\n        ...m,\n        minScore: Math.min(...m.scores), maxScore: Math.max(...m.scores),\n        minRatio: m.ratios.length > 0 ? Math.min(...m.ratios).toFixed(1) : '-',\n        maxRatio: m.ratios.length > 0 ? Math.max(...m.ratios).toFixed(1) : '-',\n        dataYears: [...new Set(m.years)].length\n      }))\n    },\n    handleScorePage(p) { this.scorePage = p; this.fetchScoreLines() },\n    analyzeGap() {\n      const major = this.targetMajor || (this.scoreLines.length > 0 ? this.scoreLines[0].major : '')\n      if (!major) { this.$message.warning('请先选择参考专业'); return }\n      const latestLine = this.scoreLines.filter(s => s.major === major).sort((a,b) => b.year - a.year)[0]\n      if (!latestLine) { this.$message.warning('未找到该专业的分数线数据'); return }\n      const details = [\n        { label:'政治', mine:this.myScore.political, line:latestLine.politicalScore||0, gap:this.myScore.political-(latestLine.politicalScore||0) },\n        { label:'英语', mine:this.myScore.english, line:latestLine.englishScore||0, gap:this.myScore.english-(latestLine.englishScore||0) },\n        { label:'业务课1', mine:this.myScore.course1, line:latestLine.course1Score||0, gap:this.myScore.course1-(latestLine.course1Score||0) },\n      ]\n      if (latestLine.course2Score) details.push({ label:'业务课2', mine:this.myScore.course2, line:latestLine.course2Score, gap:this.myScore.course2-latestLine.course2Score })\n      this.gapResult = {\n        year: latestLine.year, major: latestLine.major, refTotal: latestLine.totalScore,\n        totalGap: this.myTotal - latestLine.totalScore,\n        admitCount: latestLine.admitCount, applicantCount: latestLine.applicantCount, details\n      }\n    },\n    renderChart() {\n      if (!this.$refs.chartDom) return\n      if (!this.chartInstance) this.chartInstance = echarts.init(this.$refs.chartDom)\n      const majors = [...new Set(this.scoreLines.map(s => s.major))].slice(0, 5)\n      const allYears = [...new Set(this.scoreLines.map(s => s.year))].sort()\n      if (allYears.length === 0) { this.chartInstance.setOption({ title:{ text:'暂无数据', left:'center', top:'middle', textStyle:{ color:'#C0C4CC' } } }); return }\n      this.chartInstance.setOption({\n        tooltip:{ trigger:'axis' }, legend:{ data:majors, bottom:0 }, grid:{ left:'3%', right:'4%', bottom:'15%', containLabel:true },\n        xAxis:{ type:'category', data:allYears.map(y => y+'年') }, yAxis:{ type:'value', name:'总分', min:250 },\n        series: majors.map(m => ({ name:m, type:'line', smooth:true,\n          data: allYears.map(y => { const item = this.scoreLines.find(s => s.major===m && s.year===y); return item ? item.totalScore : null }),\n          label:{ show:true, position:'top' }\n        }))\n      })\n      window.addEventListener('resize', () => this.chartInstance && this.chartInstance.resize())\n    }\n  },\n  beforeDestroy() { if (this.chartInstance) this.chartInstance.dispose() }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.school-detail { padding:20px; max-width:1200px; margin:0 auto; }\n.school-banner {\n  background:#fff; padding:24px 30px; border-radius:12px; margin-bottom:20px; box-shadow:0 2p