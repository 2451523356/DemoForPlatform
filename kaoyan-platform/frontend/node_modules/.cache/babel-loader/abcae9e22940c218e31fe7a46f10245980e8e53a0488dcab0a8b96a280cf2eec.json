{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'CourseDetail',\n  data() {\n    return {\n      activeTab: 'chapters',\n      isPurchased: false,\n      newReview: {\n        rating: 5,\n        content: ''\n      },\n      course: {\n        id: 0,\n        title: '',\n        cover: '',\n        stage: '',\n        form: '',\n        lessonCount: 0,\n        studentCount: 0,\n        price: 0,\n        description: '',\n        outline: '',\n        teacher: {\n          name: '',\n          title: '',\n          avatar: '',\n          introduction: '',\n          courseCount: 0,\n          studentCount: 0,\n          rating: 0\n        }\n      },\n      chapters: [],\n      reviews: [],\n      reviewCurrentPage: 1,\n      reviewPageSize: 10,\n      reviewTotal: 0,\n      payDialogVisible: false,\n      selectedPayType: 1\n    };\n  },\n  computed: {\n    isLoggedIn() {\n      return !!this.$store.state.user.token;\n    },\n    courseCover() {\n      return this.course.cover || '';\n    }\n  },\n  created() {\n    this.getCourseDetail();\n  },\n  methods: {\n    async submitReview() {\n      if (!this.newReview.content.trim()) {\n        this.$message.warning('请输入评论内容');\n        return;\n      }\n      try {\n        await this.$http.post('/course/review', {\n          courseId: this.course.id,\n          content: this.newReview.content,\n          rating: this.newReview.rating\n        });\n        this.$message.success('评论成功');\n        this.newReview.content = '';\n        this.newReview.rating = 5;\n        this.getCourseReviews();\n      } catch (error) {\n        console.error('评论失败:', error);\n        this.$message.error('评论失败');\n      }\n    },\n    async buyCourse() {\n      if (!this.$store.state.user.token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      if (!this.course || !this.course.id) {\n        this.$message.error('课程信息加载失败，请刷新页面重试');\n        return;\n      }\n      this.payDialogVisible = true;\n      this.selectedPayType = 1;\n    },\n    async confirmPay() {\n      try {\n        const res = await this.$http.post('/course/buy', {\n          courseId: this.course.id,\n          payType: this.selectedPayType\n        });\n        this.payDialogVisible = false;\n        this.$message.success('支付成功！已开通课程');\n        await this.checkIfPurchased();\n      } catch (e) {\n        if (e.response?.data?.message) this.$message.error(e.response.data.message);else this.$message.error('支付失败');\n      }\n    },\n    playChapter(chapter) {\n      console.log('播放章节', chapter.id);\n      this.$router.push(`/course/${this.course.id}/learning?chapterId=${chapter.id}`);\n    },\n    startLearning() {\n      this.$router.push(`/course/${this.course.id}/learning`);\n    },\n    async getCourseDetail() {\n      try {\n        const id = this.$route.params.id;\n        console.log('获取课程详情请求:', id);\n        const res = await this.$http.get(`/course/detail/${id}`);\n        console.log('获取课程详情响应:', res);\n        this.course = res || {};\n        console.log('课程详情:', this.course);\n        this.checkIfPurchased();\n        this.getCourseChapters();\n        this.getCourseReviews();\n      } catch (error) {\n        console.error('获取课程详情失败:', error);\n        this.$message.error('获取课程详情失败');\n      }\n    },\n    async checkIfPurchased() {\n      if (!this.course || !this.course.id) {\n        console.error('课程 ID 不存在');\n        this.isPurchased = false;\n        return;\n      }\n      try {\n        const res = await this.$http.get(`/course/check-purchase/${this.course.id}`);\n        this.isPurchased = res || false;\n      } catch (error) {\n        console.error('检查购买状态失败:', error);\n        this.isPurchased = false;\n      }\n    },\n    async getCourseChapters() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/course/chapters/${id}`);\n        console.log('Course chapters response:', res);\n        this.chapters = Array.isArray(res) ? res : [];\n      } catch (error) {\n        console.error('获取章节列表失败:', error);\n        this.$message.error('获取章节列表失败');\n      }\n    },\n    async getCourseReviews() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/course/reviews/${id}`, {\n          params: {\n            page: this.reviewCurrentPage,\n            size: this.reviewPageSize\n          }\n        });\n        console.log('Course reviews response:', res);\n        this.reviews = res?.records || [];\n        this.reviewTotal = res?.total || 0;\n      } catch (error) {\n        console.error('获取课程评论失败:', error);\n        this.reviews = [];\n        this.reviewTotal = 0;\n      }\n    },\n    handleReviewPageChange(current) {\n      this.reviewCurrentPage = current;\n      this.getCourseReviews();\n    }\n  }\n};","map":{"version":3,"names":["name","data","activeTab","isPurchased","newReview","rating","content","course","id","title","cover","stage","form","lessonCount","studentCount","price","description","outline","teacher","avatar","introduction","courseCount","chapters","reviews","reviewCurrentPage","reviewPageSize","reviewTotal","payDialogVisible","selectedPayType","computed","isLoggedIn","$store","state","user","token","courseCover","created","getCourseDetail","methods","submitReview","trim","$message","warning","$http","post","courseId","success","getCourseReviews","error","console","buyCourse","$router","push","confirmPay","res","payType","checkIfPurchased","e","response","message","playChapter","chapter","log","startLearning","$route","params","get","getCourseChapters","Array","isArray","page","size","records","total","handleReviewPageChange","current"],"sources":["src/views/course/CourseDetail.vue"],"sourcesContent":["<template>\n  <div class=\"course-detail\">\n    <el-backtop :right=\"40\" :bottom=\"40\" />\n\n    <div class=\"course-header\">\n      <el-button type=\"primary\" @click=\"$router.back()\" plain>\n        <i class=\"el-icon-arrow-left\"></i> 返回\n      </el-button>\n      <div class=\"course-info\">\n        <img :src=\"courseCover\" alt=\"课程封面\" class=\"course-cover\" />\n        <div class=\"course-meta\">\n          <h1>{{ course.title }}</h1>\n          <div class=\"meta-info\">\n            <span class=\"stage\">{{ course.stage }}</span>\n            <span class=\"form\">{{ course.form }}</span>\n            <span class=\"lesson\">{{ course.lessonCount }}课时</span>\n            <span class=\"student\">{{ course.studentCount }}人学习</span>\n          </div>\n          <p class=\"description\">{{ course.description }}</p>\n          <div class=\"course-price\">\n            <span v-if=\"course.price > 0\">¥{{ course.price }}</span>\n            <span v-else class=\"free\">免费</span>\n          </div>\n          <el-button v-if=\"!isPurchased && course.price > 0\" type=\"primary\" size=\"medium\" @click=\"buyCourse\">\n            立即购买\n          </el-button>\n          <el-button v-if=\"!isPurchased && course.price === 0\" type=\"success\" size=\"medium\" @click=\"buyCourse\">\n            免费报名\n          </el-button>\n          <el-button v-if=\"isPurchased\" type=\"success\" size=\"medium\" @click=\"startLearning\">\n            开始学习\n          </el-button>\n        </div>\n      </div>\n    </div>\n\n    <!-- 讲师信息卡片 -->\n    <div class=\"teacher-card\" v-if=\"course.teacher\">\n      <div class=\"teacher-avatar\">\n        <img :src=\"course.teacher.avatar || '/static/images/default-avatar.png'\" alt=\"讲师头像\" />\n      </div>\n      <div class=\"teacher-info\">\n        <h3>{{ course.teacher.name }}</h3>\n        <p class=\"teacher-title\">{{ course.teacher.title }}</p>\n        <p class=\"teacher-intro\">{{ course.teacher.introduction }}</p>\n        <div class=\"teacher-stats\">\n          <span>课程数：{{ course.teacher.courseCount }}</span>\n          <span>学员数：{{ course.teacher.studentCount }}</span>\n          <span>好评率：{{ course.teacher.rating }}%</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"course-content\">\n      <el-tabs v-model=\"activeTab\">\n        <el-tab-pane label=\"课程大纲\" name=\"outline\">\n          <div class=\"outline-content\" v-html=\"course.outline\"></div>\n        </el-tab-pane>\n        <el-tab-pane label=\"课程章节\" name=\"chapters\">\n          <div class=\"chapters-list\">\n            <el-card v-for=\"chapter in chapters\" :key=\"chapter.id\" class=\"chapter-card\">\n              <div class=\"chapter-header\">\n                <h3>{{ chapter.title }}</h3>\n                <span class=\"duration\">{{ chapter.duration }}分钟</span>\n              </div>\n              <div class=\"chapter-actions\">\n                <el-button\n                  :type=\"isPurchased ? 'primary' : (chapter.isFree ? 'success' : 'warning')\"\n                  size=\"small\"\n                  @click=\"playChapter(chapter)\"\n                  :disabled=\"!isPurchased && !chapter.isFree\"\n                >\n                  {{ isPurchased ? '开始学习' : (chapter.isFree ? '试看' : '付费解锁') }}\n                </el-button>\n              </div>\n            </el-card>\n          </div>\n        </el-tab-pane>\n        <el-tab-pane label=\"课程评论\" name=\"reviews\">\n          <div class=\"add-review\">\n            <h4>发表评论</h4>\n            <el-rate v-model=\"newReview.rating\" :texts=\"['很差','较差','一般','推荐','力荐']\" show-text></el-rate>\n            <el-input v-model=\"newReview.content\" type=\"textarea\" :rows=\"3\" placeholder=\"写下你对课程的评价...\"></el-input>\n            <el-button type=\"primary\" size=\"small\" @click=\"submitReview\" :disabled=\"!isLoggedIn\" style=\"margin-top:10px\">提交评论</el-button>\n          </div>\n          <div class=\"reviews-list\">\n            <div class=\"review-card\" v-for=\"review in reviews\" :key=\"review.id\">\n              <div class=\"review-header\">\n                <img :src=\"review.userAvatar || '/static/images/default-avatar.png'\" alt=\"用户头像\" class=\"review-avatar\" />\n                <div class=\"review-user\">\n                  <span class=\"username\">{{ review.username }}</span>\n                  <span class=\"review-time\">{{ review.createTime }}</span>\n                </div>\n                <el-rate v-model=\"review.rating\" disabled :max=\"5\" text-color=\"#ff9900\"></el-rate>\n              </div>\n              <p class=\"review-content\">{{ review.content }}</p>\n            </div>\n          </div>\n          <div class=\"pagination-section\" v-if=\"reviews.length > 0\">\n            <el-pagination\n              background\n              layout=\"prev, pager, next\"\n              :total=\"reviewTotal\"\n              :page-size=\"reviewPageSize\"\n              :current-page=\"reviewCurrentPage\"\n              @current-change=\"handleReviewPageChange\">\n            </el-pagination>\n          </div>\n        </el-tab-pane>\n      </el-tabs>\n    </div>\n\n    <el-dialog title=\"确认支付\" :visible.sync=\"payDialogVisible\" width=\"420px\">\n      <div class=\"pay-info\"><p><strong>课程：</strong>{{ course.title }}</p><p><strong>价格：</strong><span style=\"color:#F56C6C;font-size:20px;font-weight:700\">¥{{ course.price }}</span></p></div>\n      <div class=\"pay-method\"><p><strong>支付方式：</strong></p><el-radio-group v-model=\"selectedPayType\"><el-radio :label=\"1\">支付宝</el-radio><el-radio :label=\"2\">微信支付</el-radio></el-radio-group></div>\n      <span slot=\"footer\"><el-button @click=\"payDialogVisible=false\">取消</el-button><el-button type=\"primary\" @click=\"confirmPay\">确认支付 ¥{{ course.price }}</el-button></span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CourseDetail',\n  data() {\n    return {\n      activeTab: 'chapters',\n      isPurchased: false,\n      newReview: { rating: 5, content: '' },\n      course: {\n        id: 0,\n        title: '',\n        cover: '',\n        stage: '',\n        form: '',\n        lessonCount: 0,\n        studentCount: 0,\n        price: 0,\n        description: '',\n        outline: '',\n        teacher: {\n          name: '',\n          title: '',\n          avatar: '',\n          introduction: '',\n          courseCount: 0,\n          studentCount: 0,\n          rating: 0\n        }\n      },\n      chapters: [],\n      reviews: [],\n      reviewCurrentPage: 1,\n      reviewPageSize: 10,\n      reviewTotal: 0,\n      payDialogVisible: false,\n      selectedPayType: 1\n    }\n  },\n  computed: {\n    isLoggedIn() {\n      return !!this.$store.state.user.token\n    },\n    courseCover() {\n      return this.course.cover || ''\n    }\n  },\n  created() {\n    this.getCourseDetail()\n  },\n  methods: {\n    async submitReview() {\n      if (!this.newReview.content.trim()) {\n        this.$message.warning('请输入评论内容')\n        return\n      }\n      try {\n        await this.$http.post('/course/review', {\n          courseId: this.course.id,\n          content: this.newReview.content,\n          rating: this.newReview.rating\n        })\n        this.$message.success('评论成功')\n        this.newReview.content = ''\n        this.newReview.rating = 5\n        this.getCourseReviews()\n      } catch (error) {\n        console.error('评论失败:', error)\n        this.$message.error('评论失败')\n      }\n    },\n    async buyCourse() {\n      if (!this.$store.state.user.token) {\n        this.$message.warning('请先登录')\n        this.$router.push('/login')\n        return\n      }\n\n      if (!this.course || !this.course.id) {\n        this.$message.error('课程信息加载失败，请刷新页面重试')\n        return\n      }\n\n      this.payDialogVisible = true\n      this.selectedPayType = 1\n    },\n    async confirmPay() {\n      try {\n        const res = await this.$http.post('/course/buy', { courseId: this.course.id, payType: this.selectedPayType })\n        this.payDialogVisible = false\n        this.$message.success('支付成功！已开通课程')\n        await this.checkIfPurchased()\n      } catch (e) {\n        if (e.response?.data?.message) this.$message.error(e.response.data.message)\n        else this.$message.error('支付失败')\n      }\n    },\n    playChapter(chapter) {\n      console.log('播放章节', chapter.id)\n      this.$router.push(`/course/${this.course.id}/learning?chapterId=${chapter.id}`)\n    },\n    startLearning() {\n      this.$router.push(`/course/${this.course.id}/learning`)\n    },\n    async getCourseDetail() {\n      try {\n        const id = this.$route.params.id\n        console.log('获取课程详情请求:', id)\n        const res = await this.$http.get(`/course/detail/${id}`)\n        console.log('获取课程详情响应:', res)\n        this.course = res || {}\n        console.log('课程详情:', this.course)\n        this.checkIfPurchased()\n        this.getCourseChapters()\n        this.getCourseReviews()\n      } catch (error) {\n        console.error('获取课程详情失败:', error)\n        this.$message.error('获取课程详情失败')\n      }\n    },\n    async checkIfPurchased() {\n      if (!this.course || !this.course.id) {\n        console.error('课程 ID 不存在')\n        this.isPurchased = false\n        return\n      }\n\n      try {\n        const res = await this.$http.get(`/course/check-purchase/${this.course.id}`)\n        this.isPurchased = res || false\n      } catch (error) {\n        console.error('检查购买状态失败:', error)\n        this.isPurchased = false\n      }\n    },\n    async getCourseChapters() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/course/chapters/${id}`)\n        console.log('Course chapters response:', res)\n        this.chapters = Array.isArray(res) ? res : []\n      } catch (error) {\n        console.error('获取章节列表失败:', error)\n        this.$message.error('获取章节列表失败')\n      }\n    },\n    async getCourseReviews() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/course/reviews/${id}`, {\n          params: {\n            page: this.reviewCurrentPage,\n            size: this.reviewPageSize\n          }\n        })\n        console.log('Course reviews response:', res)\n        this.reviews = res?.records || []\n        this.reviewTotal = res?.total || 0\n      } catch (error) {\n        console.error('获取课程评论失败:', error)\n        this.reviews = []\n        this.reviewTotal = 0\n      }\n    },\n    handleReviewPageChange(current) {\n      this.reviewCurrentPage = current\n      this.getCourseReviews()\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.course-detail {\n  padding: 20px;\n\n  .course-header {\n    margin-bottom: 30px;\n\n    .course-info {\n      display: flex;\n      gap: 30px;\n      margin-top: 20px;\n\n      .course-cover {\n        width: 400px;\n        height: 250px;\n        object-fit: cover;\n        border-radius: 8px;\n        background: #f5f7fa;\n      }\n\n      .course-meta {\n        flex: 1;\n\n        h1 {\n          font-size: 24px;\n          margin-bottom: 15px;\n          color: #303133;\n        }\n\n        .meta-info {\n          display: flex;\n          gap: 15px;\n          margin-bottom: 15px;\n          font-size: 14px;\n\n          .stage, .form {\n            background: #ECF5FF;\n            color: #409EFF;\n            padding: 4px 12px;\n            border-radius: 4px;\n          }\n\n          .lesson, .student {\n            color: #606266;\n          }\n        }\n\n        .description {\n          font-size: 14px;\n          color: #606266;\n          margin-bottom: 20px;\n          line-height: 1.5;\n        }\n\n        .course-price {\n          font-size: 24px;\n          font-weight: bold;\n          color: #F56C6C;\n          margin-bottom: 20px;\n\n          .free {\n            color: #67C23A;\n          }\n        }\n      }\n    }\n  }\n\n  .teacher-card {\n    display: flex;\n    gap: 20px;\n    background: #fff;\n    border-radius: 8px;\n    box-shadow: 0 2px 12px rgba(0,0,0,0.1);\n    padding: 20px;\n    margin-bottom: 30px;\n\n    .teacher-avatar {\n    