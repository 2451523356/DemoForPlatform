{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'CourseDetail',\n  data() {\n    return {\n      activeTab: 'chapters',\n      isPurchased: false,\n      newReview: {\n        rating: 5,\n        content: ''\n      },\n      course: {},\n      chapters: [],\n      reviews: [],\n      reviewCurrentPage: 1,\n      reviewPageSize: 10,\n      reviewTotal: 0,\n      payDialogVisible: false,\n      selectedPayType: 1\n    };\n  },\n  computed: {\n    isLoggedIn() {\n      return !!this.$store.state.user.token;\n    },\n    courseCover() {\n      return this.course.cover || '';\n    },\n    completedChapterCount() {\n      return 0;\n    },\n    chapterProgress() {\n      return this.isPurchased ? Math.round(Math.random() * 60) : 0;\n    }\n  },\n  created() {\n    this.getCourseDetail();\n  },\n  methods: {\n    formatDuration(minutes) {\n      if (!minutes) return '0小时';\n      const h = Math.floor(minutes / 60);\n      const m = minutes % 60;\n      return h > 0 ? m > 0 ? h + '小时' + m + '分' : h + '小时' : m + '分钟';\n    },\n    async submitReview() {\n      if (!this.newReview.content.trim()) {\n        this.$message.warning('请输入评价内容');\n        return;\n      }\n      try {\n        await this.$http.post('/course/review', {\n          courseId: this.course.id,\n          content: this.newReview.content,\n          rating: this.newReview.rating\n        });\n        this.$message.success('评价成功');\n        this.newReview.content = '';\n        this.newReview.rating = 5;\n        this.getCourseReviews();\n      } catch (e) {\n        this.$message.error('评价失败');\n      }\n    },\n    async buyCourse() {\n      if (!this.$store.state.user.token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      this.payDialogVisible = true;\n      this.selectedPayType = 1;\n    },\n    async confirmPay() {\n      try {\n        await this.$http.post('/course/buy', {\n          courseId: this.course.id,\n          payType: this.selectedPayType\n        });\n        this.payDialogVisible = false;\n        this.$message.success('报名成功！');\n        await this.checkIfPurchased();\n      } catch (e) {\n        this.$message.error(e.response?.data?.message || '支付失败');\n      }\n    },\n    playChapter(chapter) {\n      this.$router.push(`/course/${this.course.id}/learning?chapterId=${chapter.id}`);\n    },\n    startLearning() {\n      this.$router.push(`/course/${this.course.id}/learning`);\n    },\n    downloadChapterFile(chapter) {\n      if (!chapter.fileUrl) {\n        this.$message.warning('该章节暂无资料');\n        return;\n      }\n      if (!this.isPurchased && chapter.isFree !== 1) {\n        this.$message.warning('请先购买课程');\n        return;\n      }\n      const token = this.$store.state.user.token;\n      const a = document.createElement('a');\n      a.href = chapter.fileUrl.startsWith('http') ? chapter.fileUrl : '/api' + chapter.fileUrl;\n      a.download = chapter.fileName || 'course-material';\n      document.body.appendChild(a);\n      a.click();\n      document.body.removeChild(a);\n    },\n    async getCourseDetail() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/course/detail/${id}`);\n        this.course = res || {};\n        this.checkIfPurchased();\n        this.getCourseChapters();\n        this.getCourseReviews();\n      } catch (e) {\n        this.$message.error('获取课程详情失败');\n      }\n    },\n    async checkIfPurchased() {\n      if (!this.course.id) return;\n      try {\n        const res = await this.$http.get(`/course/check-purchase/${this.course.id}`);\n        this.isPurchased = res || false;\n      } catch (e) {\n        this.isPurchased = false;\n      }\n    },\n    async getCourseChapters() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/course/chapters/${id}`);\n        this.chapters = Array.isArray(res) ? res : [];\n      } catch (e) {\n        this.$message.error('获取章节列表失败');\n      }\n    },\n    async getCourseReviews() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/course/reviews/${id}`, {\n          params: {\n            page: this.reviewCurrentPage,\n            size: this.reviewPageSize\n          }\n        });\n        this.reviews = res?.records || [];\n        this.reviewTotal = res?.total || 0;\n      } catch (e) {\n        this.reviews = [];\n        this.reviewTotal = 0;\n      }\n    },\n    handleReviewPageChange(current) {\n      this.reviewCurrentPage = current;\n      this.getCourseReviews();\n    }\n  }\n};","map":{"version":3,"names":["name","data","activeTab","isPurchased","newReview","rating","content","course","chapters","reviews","reviewCurrentPage","reviewPageSize","reviewTotal","payDialogVisible","selectedPayType","computed","isLoggedIn","$store","state","user","token","courseCover","cover","completedChapterCount","chapterProgress","Math","round","random","created","getCourseDetail","methods","formatDuration","minutes","h","floor","m","submitReview","trim","$message","warning","$http","post","courseId","id","success","getCourseReviews","e","error","buyCourse","$router","push","confirmPay","payType","checkIfPurchased","response","message","playChapter","chapter","startLearning","downloadChapterFile","fileUrl","isFree","a","document","createElement","href","startsWith","download","fileName","body","appendChild","click","removeChild","$route","params","res","get","getCourseChapters","Array","isArray","page","size","records","total","handleReviewPageChange","current"],"sources":["src/views/course/CourseDetail.vue"],"sourcesContent":["<template>\n  <div class=\"course-detail\">\n    <el-backtop :right=\"40\" :bottom=\"40\" />\n\n    <!-- 顶部课程概览 -->\n    <div class=\"course-hero\">\n      <div class=\"course-hero-bg\"></div>\n      <div class=\"course-hero-content\">\n        <div class=\"hero-left\">\n          <h1 class=\"hero-title\">{{ course.title }}</h1>\n          <p class=\"hero-subtitle\">{{ course.description }}</p>\n          <div class=\"hero-meta\">\n            <el-tag size=\"medium\" type=\"warning\">{{ course.stage }}</el-tag>\n            <el-tag size=\"medium\" type=\"info\">{{ course.form }}</el-tag>\n            <el-tag size=\"medium\" v-if=\"course.subject\">{{ course.subject }}</el-tag>\n            <span><i class=\"el-icon-video-camera\"></i> {{ course.lessonCount }}课时</span>\n            <span><i class=\"el-icon-time\"></i> {{ formatDuration(course.duration) }}</span>\n            <span><i class=\"el-icon-user\"></i> {{ course.studentCount }}人已学</span>\n          </div>\n          <div class=\"hero-price-row\">\n            <span class=\"hero-price\" v-if=\"course.price > 0\">¥{{ course.price }}</span>\n            <span class=\"hero-price free\" v-else>免费</span>\n            <el-button v-if=\"!isPurchased && course.price > 0\" type=\"danger\" size=\"large\" round @click=\"buyCourse\">\n              <i class=\"el-icon-shopping-cart-2\"></i> 立即购买\n            </el-button>\n            <el-button v-if=\"!isPurchased && course.price === 0\" type=\"success\" size=\"large\" round @click=\"buyCourse\">\n              <i class=\"el-icon-plus\"></i> 免费报名\n            </el-button>\n            <el-button v-if=\"isPurchased\" type=\"primary\" size=\"large\" round @click=\"startLearning\">\n              <i class=\"el-icon-video-play\"></i> 继续学习\n            </el-button>\n          </div>\n        </div>\n        <div class=\"hero-right\">\n          <img :src=\"courseCover\" alt=\"课程封面\" class=\"hero-cover\" />\n        </div>\n      </div>\n    </div>\n\n    <!-- 讲师信息 -->\n    <div class=\"teacher-section\" v-if=\"course.teacher\">\n      <h2 class=\"section-title\"><i class=\"el-icon-user-solid\"></i> 讲师介绍</h2>\n      <div class=\"teacher-card\">\n        <div class=\"teacher-avatar\">\n          <img :src=\"course.teacher.avatar || '/static/images/default-avatar.png'\" alt=\"讲师\" />\n        </div>\n        <div class=\"teacher-body\">\n          <h3>{{ course.teacher.name }}</h3>\n          <p class=\"teacher-bio\">{{ course.teacher.title || course.teacher.intro || '资深考研辅导讲师，多年教学经验，深谙考研命题规律与备考策略。' }}</p>\n          <div class=\"teacher-stats\">\n            <span><i class=\"el-icon-star-on\"></i> 评分 {{ course.rating || '5.0' }}</span>\n            <span><i class=\"el-icon-user\"></i> {{ course.studentCount }}学员</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- 课程核心信息 -->\n    <div class=\"info-grid\">\n      <!-- 课程亮点 -->\n      <div class=\"info-card\" v-if=\"course.highlights\">\n        <h3><i class=\"el-icon-star-on\"></i> 课程亮点</h3>\n        <div class=\"info-content\" v-html=\"course.highlights\"></div>\n      </div>\n      <!-- 适合人群 -->\n      <div class=\"info-card\" v-if=\"course.targetAudience\">\n        <h3><i class=\"el-icon-user\"></i> 适合人群</h3>\n        <div class=\"info-content\" v-html=\"course.targetAudience\"></div>\n      </div>\n      <!-- 前置要求 -->\n      <div class=\"info-card\" v-if=\"course.prerequisites\">\n        <h3><i class=\"el-icon reading\"></i> 前置要求</h3>\n        <div class=\"info-content\" v-html=\"course.prerequisites\"></div>\n      </div>\n      <!-- 课程简介 -->\n      <div class=\"info-card\">\n        <h3><i class=\"el-icon-document\"></i> 课程简介</h3>\n        <div class=\"info-content\">{{ course.description }}</div>\n      </div>\n    </div>\n\n    <!-- Tab 切换 -->\n    <div class=\"course-tabs\">\n      <el-tabs v-model=\"activeTab\">\n        <!-- 课程大纲 -->\n        <el-tab-pane label=\"课程大纲\" name=\"outline\">\n          <div class=\"outline-section\">\n            <div class=\"outline-content\" v-html=\"course.outline || '<p>暂无大纲信息</p>'\"></div>\n          </div>\n        </el-tab-pane>\n\n        <!-- 课程章节 -->\n        <el-tab-pane label=\"课程章节\" name=\"chapters\">\n          <div class=\"chapters-section\">\n            <div class=\"chapters-summary\">\n              共 <strong>{{ chapters.length }}</strong> 个章节 · 已完成 <strong>{{ completedChapterCount }}</strong> 个\n              <el-progress v-if=\"isPurchased\" :percentage=\"chapterProgress\" :stroke-width=\"8\" style=\"margin-top:8px\" />\n            </div>\n            <div class=\"chapters-list\">\n              <div class=\"chapter-item\" v-for=\"(chapter, index) in chapters\" :key=\"chapter.id\"\n                :class=\"{ 'is-free': chapter.isFree === 1, 'is-locked': !isPurchased && chapter.isFree !== 1 }\">\n                <div class=\"chapter-index\">{{ index + 1 }}</div>\n                <div class=\"chapter-body\">\n                  <div class=\"chapter-title\">\n                    {{ chapter.title }}\n                    <el-tag v-if=\"chapter.isFree === 1\" size=\"mini\" type=\"success\">免费试看</el-tag>\n                    <el-tag v-if=\"!isPurchased && chapter.isFree !== 1\" size=\"mini\" type=\"warning\">付费</el-tag>\n                  </div>\n                  <div class=\"chapter-meta\">\n                    <span v-if=\"chapter.duration\"><i class=\"el-icon-time\"></i> {{ chapter.duration }}分钟</span>\n                    <span v-if=\"chapter.fileName\"><i class=\"el-icon-paperclip\"></i> {{ chapter.fileName }}</span>\n                  </div>\n                </div>\n                <div class=\"chapter-actions\">\n                  <el-button v-if=\"chapter.fileUrl\" size=\"small\" type=\"info\" plain @click=\"downloadChapterFile(chapter)\">\n                    <i class=\"el-icon-download\"></i> 资料\n                  </el-button>\n                  <el-button size=\"small\" :type=\"isPurchased || chapter.isFree === 1 ? 'primary' : 'warning'\"\n                    @click=\"playChapter(chapter)\" :disabled=\"!isPurchased && chapter.isFree !== 1\">\n                    <i :class=\"isPurchased || chapter.isFree === 1 ? 'el-icon-video-play' : 'el-icon-lock'\"></i>\n                    {{ isPurchased ? '学习' : (chapter.isFree === 1 ? '试看' : '付费解锁') }}\n                  </el-button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </el-tab-pane>\n\n        <!-- 课程评价 -->\n        <el-tab-pane label=\"课程评价\" name=\"reviews\">\n          <div class=\"reviews-section\">\n            <div class=\"add-review\">\n              <h3>发表评价</h3>\n              <el-rate v-model=\"newReview.rating\" :texts=\"['很差','较差','一般','推荐','力荐']\" show-text></el-rate>\n              <el-input v-model=\"newReview.content\" type=\"textarea\" :rows=\"3\" placeholder=\"分享你的学习感受...\" maxlength=\"500\" show-word-limit></el-input>\n              <el-button type=\"primary\" size=\"small\" @click=\"submitReview\" :disabled=\"!isLoggedIn\" style=\"margin-top:10px\">提交评价</el-button>\n            </div>\n            <div class=\"reviews-list\" v-if=\"reviews.length > 0\">\n              <div class=\"review-card\" v-for=\"review in reviews\" :key=\"review.id\">\n                <div class=\"review-header\">\n                  <img :src=\"review.userAvatar || '/static/images/default-avatar.png'\" class=\"review-avatar\" />\n                  <div class=\"review-user\">\n                    <span class=\"username\">{{ review.username }}</span>\n                    <span class=\"review-time\">{{ review.createTime }}</span>\n                  </div>\n                  <el-rate v-model=\"review.rating\" disabled text-color=\"#ff9900\"></el-rate>\n                </div>\n                <p class=\"review-content\">{{ review.content }}</p>\n              </div>\n            </div>\n            <el-empty v-else description=\"暂无评价，成为第一个评价的人吧！\" :image-size=\"80\" />\n            <div class=\"pagination-section\" v-if=\"reviewTotal > reviewPageSize\">\n              <el-pagination background layout=\"prev, pager, next\" :total=\"reviewTotal\"\n                :page-size=\"reviewPageSize\" :current-page=\"reviewCurrentPage\" @current-change=\"handleReviewPageChange\" />\n            </div>\n          </div>\n        </el-tab-pane>\n      </el-tabs>\n    </div>\n\n    <!-- 支付弹窗 -->\n    <el-dialog title=\"确认支付\" :visible.sync=\"payDialogVisible\" width=\"420px\">\n      <div class=\"pay-info\">\n        <p><strong>课程：</strong>{{ course.title }}</p>\n        <p><strong>价格：</strong><span style=\"color:#F56C6C;font-size:20px;font-weight:700\">¥{{ course.price }}</span></p>\n      </div>\n      <div class=\"pay-method\">\n        <p><strong>支付方式：</strong></p>\n        <el-radio-group v-model=\"selectedPayType\">\n          <el-radio :label=\"1\">支付宝</el-radio>\n          <el-radio :label=\"2\">微信支付</el-radio>\n        </el-radio-group>\n      </div>\n      <span slot=\"footer\"><el-button @click=\"payDialogVisible=false\">取消</el-button><el-button type=\"primary\" @click=\"confirmPay\">确认支付 ¥{{ course.price }}</el-button></span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CourseDetail',\n  data() {\n    return {\n      activeTab: 'chapters',\n      isPurchased: false,\n      newReview: { rating: 5, content: '' },\n      course: {},\n      chapters: [],\n      reviews: [],\n      reviewCurrentPage: 1,\n      reviewPageSize: 10,\n      reviewTotal: 0,\n      payDialogVisible: false,\n      selectedPayType: 1\n    }\n  },\n  computed: {\n    isLoggedIn() { return !!this.$store.state.user.token },\n    courseCover() { return this.course.cover || '' },\n    completedChapterCount() { return 0 },\n    chapterProgress() { return this.isPurchased ? Math.round(Math.random() * 60) : 0 }\n  },\n  created() { this.getCourseDetail() },\n  methods: {\n    formatDuration(minutes) {\n      if (!minutes) return '0小时'\n      const h = Math.floor(minutes / 60)\n      const m = minutes % 60\n      return h > 0 ? (m > 0 ? h + '小时' + m + '分' : h + '小时') : m + '分钟'\n    },\n    async submitReview() {\n      if (!this.newReview.content.trim()) { this.$message.warning('请输入评价内容'); return }\n      try {\n        await this.$http.post('/course/review', { courseId: this.course.id, content: this.newReview.content, rating: this.newReview.rating })\n        this.$message.success('评价成功')\n        this.newReview.content = ''; this.newReview.rating = 5\n        this.getCourseReviews()\n      } catch (e) { this.$message.error('评价失败') }\n    },\n    async buyCourse() {\n      if (!this.$store.state.user.token) { this.$message.warning('请先登录'); this.$router.push('/login'); return }\n      this.payDialogVisible = true; this.selectedPayType = 1\n    },\n    async confirmPay() {\n      try {\n        await this.$http.post('/course/buy', { courseId: this.course.id, payType: this.selectedPayType })\n        this.payDialogVisible = false\n        this.$message.success('报名成功！')\n        await this.checkIfPurchased()\n      } catch (e) {\n        this.$message.error(e.response?.data?.message || '支付失败')\n      }\n    },\n    playChapter(chapter) {\n      this.$router.push(`/course/${this.course.id}/learning?chapterId=${chapter.id}`)\n    },\n    startLearning() { this.$router.push(`/course/${this.course.id}/learning`) },\n    downloadChapterFile(chapter) {\n      if (!chapter.fileUrl) { this.$message.warning('该章节暂无资料'); return }\n      if (!this.isPurchased && chapter.isFree !== 1) { this.$message.warning('请先购买课程'); return }\n      const token = this.$store.state.user.token\n      const a = document.createElement('a')\n      a.href = chapter.fileUrl.startsWith('http') ? chapter.fileUrl : '/api' + chapter.fileUrl\n      a.download = chapter.fileName || 'course-material'\n      document.body.appendChild(a); a.click(); document.body.removeChild(a)\n    },\n    async getCourseDetail() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/course/detail/${id}`)\n        this.course = res || {}\n        this.checkIfPurchased()\n        this.getCourseChapters()\n        this.getCourseReviews()\n      } catch (e) { this.$message.error('获取课程详情失败') }\n    },\n    async checkIfPurchased() {\n      if (!this.course.id) return\n      try {\n        const res = await this.$http.get(`/course/check-purchase/${this.course.id}`)\n        this.isPurchased = res || false\n      } catch (e) { this.isPurchased = false }\n    },\n    async getCourseChapters() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/course/chapters/${id}`)\n        this.chapters = Array.isArray(res) ? res : []\n      } catch (e) { this.$message.error('获取章节列表失败') }\n    },\n    async getCourseReviews() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/course/reviews/${id}`, { params: { page: this.reviewCurrentPage, size: this.reviewPageSize } })\n        this.reviews = res?.records || []\n        this.reviewTotal = res?.total || 0\n      } catch (e) { this.reviews = []; this.reviewTotal = 0 }\n    },\n    handleReviewPageChange(current) { this.reviewCurrentPage = current; this.getCourseReviews() }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.course-detail { padding: 20px; max-width: 1100px; margin: 0 auto; }\n\n.course-hero {\n  position: relative; border-radius: 12px; overflow: hidden;\n  margin-bottom: 30px; background: linear-gradient(135deg, #1a3a5c 0%, #2d6aa0 100%);\n  .course-hero-bg { position: absolute; inset: 0; opacity: .08;\n    background: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.1) 35px, rgba(255,255,255,.1) 70px); }\n  .course-hero-content {\n    position: relative; display: flex; gap: 40px; padding: 40px;\n    .hero-left {\n      flex: 1; color: #fff;\n      .hero-title { font-size: 28px; font-weight: 700; margin: 0 0 12px; }\n      .hero-subtitle { font-size: 15px; opacity: .85; margin: 0 0 20px; line-height: 1.6; }\n      .hero-meta {\n        display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 24px;\n        font-size: 14px; opacity: .9;\n        span { display: flex; align-items: center; gap: 4px; }\n      }\n      .hero-price-row {\n        display: flex; align-items: center; gap: 20px;\n        .hero-price { font-size: 32px; font-weight: 800; &.free { color: #67c23a; } }\n      }\n    }\n    .hero-right {\n      flex-shrink: 0;\n      .hero-cover { width: 320px; height: 200px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 30px rgba(0,0,0,.3); }\n    }\n  }\n}\n\n.teacher-section {\n  background: #fff; border-radius: 10px; padding: 24px; margin-bottom: 24px;\n  box-shadow: 0 2px 12px rgba(0,0,0,.06);\n  .section-title { font-size: 18px; margin: 0 0 16px; i { color: #409eff; margin-right: 6px; } }\n  .teacher-card { display: flex; gap: 20px; align-items: center;\n    .teacher-avatar img { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; background: #f5f7fa; }\n    .teacher-body {\n      h3 { margin: 0 0 8px; font-size: 18px; }\n      .teacher-bio { color: #606266; margin: 0 0 10px; line-height: 1.6; }\n      .teacher-stats { display: flex; gap: 20px; font-size: 13px; color: #909399; }\n    }\n  }\n}\n\n.info-grid {\n  display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;\n  .info-card {\n    background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06);\n    h3 { font-size: 16px; margin: 0 0 12px; i { color: #409eff; margin-right: 6px; } }\n    .info-content { font-size: 14px; color: #606266; line-height: 1.7; }\n  }\n}\n\n.course-tabs {\n  background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06);\n}\n\n.outline-section {\n  .outline-content { line-height: 1.8; color: #606266; }\n}\n\n.chapters-section {\n  .chapters-summary { margin-bottom: 20px; padding: 12px 16px; background: #f5f7fa; border-radius: 8px; font-size: 14px; color: #606266; }\n  .chapters-list {\n    .chapter-item {\n      display: flex; align-items: center; gap: 16px; padding: 16px;\n      border-bottom: 1px solid #f0f0f0; transition: all .3s;\n      &:hover { background: #fafbfc; }\n    