{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'MyCourses',\n  data() {\n    return {\n      courses: [],\n      loading: true\n    };\n  },\n  created() {\n    this.fetchMyCourses();\n  },\n  methods: {\n    async fetchMyCourses() {\n      this.loading = true;\n      try {\n        const res = await this.$http.get('/course/user-courses');\n        this.courses = Array.isArray(res) ? res : res?.records || [];\n      } catch (e) {\n        console.error('获取我的课程失败:', e);\n        this.$message.error('获取课程列表失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    goToCourse(courseId) {\n      this.$router.push(`/course/${courseId}`);\n    },\n    continueLearning(courseId) {\n      this.$router.push(`/course/${courseId}/learning`);\n    },\n    async requestRefund(item) {\n      try {\n        await this.$confirm('确定要申请退款吗？退款后课程将被收回。', '退款申请', {\n          confirmButtonText: '确定退款',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        await this.$http.post(`/course/refund-request/${item.courseId}`);\n        this.$message.success('退款申请已提交，请等待管理员处理');\n        this.fetchMyCourses();\n      } catch (e) {\n        if (e !== 'cancel') this.$message.error('申请退款失败');\n      }\n    },\n    progressColor(progress) {\n      if (progress >= 80) return '#67C23A';\n      if (progress >= 40) return '#409EFF';\n      return '#E6A23C';\n    },\n    formatDuration(minutes) {\n      if (!minutes) return '0分钟';\n      const h = Math.floor(minutes / 60);\n      const m = minutes % 60;\n      return h > 0 ? `${h}小时${m}分钟` : `${m}分钟`;\n    },\n    formatDate(dateStr) {\n      if (!dateStr) return '';\n      try {\n        return new Date(dateStr).toLocaleDateString('zh-CN');\n      } catch (e) {\n        return dateStr;\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","courses","loading","created","fetchMyCourses","methods","res","$http","get","Array","isArray","records","e","console","error","$message","goToCourse","courseId","$router","push","continueLearning","requestRefund","item","$confirm","confirmButtonText","cancelButtonText","type","post","success","progressColor","progress","formatDuration","minutes","h","Math","floor","m","formatDate","dateStr","Date","toLocaleDateString"],"sources":["src/views/course/MyCourses.vue"],"sourcesContent":["<template>\n  <div class=\"my-courses\">\n    <div class=\"page-header\">\n      <h2>我的课程</h2>\n      <p class=\"subtitle\">管理已购买的课程，继续你的学习之旅</p>\n    </div>\n\n    <div v-if=\"loading\" class=\"loading-container\">\n      <el-skeleton :rows=\"5\" animated />\n    </div>\n\n    <div v-else-if=\"courses.length === 0\" class=\"empty-state\">\n      <el-empty description=\"还没有购买任何课程\">\n        <el-button type=\"primary\" @click=\"$router.push('/course')\">去看看课程</el-button>\n      </el-empty>\n    </div>\n\n    <div v-else class=\"course-grid\">\n      <el-card v-for=\"item in courses\" :key=\"item.id\" class=\"course-card\" shadow=\"hover\">\n        <div class=\"course-cover-wrap\" @click=\"goToCourse(item.courseId)\">\n          <img :src=\"item.cover || 'https://picsum.photos/400/240?random=' + item.courseId\" alt=\"课程封面\" class=\"course-cover\" />\n          <div class=\"cover-overlay\">\n            <el-button type=\"primary\" size=\"small\">查看详情</el-button>\n          </div>\n        </div>\n        <div class=\"course-info\">\n          <h3 class=\"course-title\" @click=\"goToCourse(item.courseId)\">{{ item.title }}</h3>\n          <div class=\"course-meta\">\n            <span>{{ item.lessonCount || 0 }}课时</span>\n            <span v-if=\"item.stage\" class=\"stage-tag\">{{ item.stage }}</span>\n          </div>\n          <div class=\"progress-section\">\n            <div class=\"progress-label\">\n              <span>学习进度</span>\n              <span class=\"progress-percent\">{{ item.progress || 0 }}%</span>\n            </div>\n            <el-progress :percentage=\"item.progress || 0\" :stroke-width=\"8\" :color=\"progressColor(item.progress)\" />\n          </div>\n          <div class=\"course-stats\">\n            <span><i class=\"el-icon-time\"></i> {{ formatDuration(item.studyDuration) }}</span>\n            <span v-if=\"item.lastStudyTime\"><i class=\"el-icon-date\"></i> {{ formatDate(item.lastStudyTime) }}</span>\n          </div>\n          <div class=\"course-actions\">\n            <el-button type=\"primary\" size=\"small\" @click=\"continueLearning(item.courseId)\" style=\"width:100%\">\n              {{ item.progress > 0 ? '继续学习' : '开始学习' }}\n            </el-button>\n            <el-button type=\"text\" size=\"small\" style=\"color:#f56c6c;margin-top:4px\"\n              @click=\"requestRefund(item)\">\n              <i class=\"el-icon-warning-outline\"></i> 申请退款\n            </el-button>\n          </div>\n        </div>\n      </el-card>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'MyCourses',\n  data() {\n    return {\n      courses: [],\n      loading: true\n    }\n  },\n  created() {\n    this.fetchMyCourses()\n  },\n  methods: {\n    async fetchMyCourses() {\n      this.loading = true\n      try {\n        const res = await this.$http.get('/course/user-courses')\n        this.courses = Array.isArray(res) ? res : (res?.records || [])\n      } catch (e) {\n        console.error('获取我的课程失败:', e)\n        this.$message.error('获取课程列表失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    goToCourse(courseId) {\n      this.$router.push(`/course/${courseId}`)\n    },\n    continueLearning(courseId) {\n      this.$router.push(`/course/${courseId}/learning`)\n    },\n    async requestRefund(item) {\n      try {\n        await this.$confirm('确定要申请退款吗？退款后课程将被收回。', '退款申请', {\n          confirmButtonText: '确定退款', cancelButtonText: '取消', type: 'warning'\n        })\n        await this.$http.post(`/course/refund-request/${item.courseId}`)\n        this.$message.success('退款申请已提交，请等待管理员处理')\n        this.fetchMyCourses()\n      } catch (e) {\n        if (e !== 'cancel') this.$message.error('申请退款失败')\n      }\n    },\n    progressColor(progress) {\n      if (progress >= 80) return '#67C23A'\n      if (progress >= 40) return '#409EFF'\n      return '#E6A23C'\n    },\n    formatDuration(minutes) {\n      if (!minutes) return '0分钟'\n      const h = Math.floor(minutes / 60)\n      const m = minutes % 60\n      return h > 0 ? `${h}小时${m}分钟` : `${m}分钟`\n    },\n    formatDate(dateStr) {\n      if (!dateStr) return ''\n      try {\n        return new Date(dateStr).toLocaleDateString('zh-CN')\n      } catch (e) {\n        return dateStr\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.my-courses {\n  padding: 20px;\n  max-width: 1200px;\n  margin: 0 auto;\n\n  .page-header {\n    margin-bottom: 30px;\n    h2 { font-size: 24px; color: #303133; margin-bottom: 8px; }\n    .subtitle { color: #909399; font-size: 14px; margin: 0; }\n  }\n\n  .loading-container {\n    padding: 40px;\n  }\n\n  .empty-state {\n    padding: 80px 0;\n    text-align: center;\n  }\n\n  .course-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 20px;\n  }\n\n  .course-card {\n    transition: all 0.3s;\n    &:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }\n\n    .course-cover-wrap {\n      position: relative;\n      cursor: pointer;\n      overflow: hidden;\n      border-radius: 4px;\n      margin-bottom: 12px;\n\n      .course-cover {\n        width: 100%;\n        height: 160px;\n        object-fit: cover;\n        background: #f5f7fa;\n        display: block;\n      }\n\n      .cover-overlay {\n        position: absolute;\n        top: 0; left: 0; right: 0; bottom: 0;\n        background: rgba(0,0,0,0.4);\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        opacity: 0;\n        transition: opacity 0.3s;\n      }\n\n      &:hover .cover-overlay { opacity: 1; }\n    }\n\n    .course-info {\n      .course-title {\n        font-size: 15px;\n        color: #303133;\n        margin-bottom: 8px;\n        cursor: pointer;\n        overflow: hidden;\n        text-overflow: ellipsis;\n        white-space: nowrap;\n        &:hover { color: #409EFF; }\n      }\n\n      .course-meta {\n        display: flex;\n        gap: 10px;\n        font-size: 13px;\n        color: #909399;\n        margin-bottom: 12px;\n\n        .stage-tag {\n          background: #ECF5FF;\n          color: #409EFF;\n          padding: 0 6px;\n          border-radius: 3px;\n          font-size: 12px;\n        }\n      }\n\n      .progress-section {\n        margin-bottom: 12px;\n        .progress-label {\n          display: flex;\n          justify-content: space-between;\n          font-size: 13px;\n          color: #606266;\n          margin-bottom: 4px;\n          .progress-percent { font-weight: 600; }\n        }\n      }\n\n      .course-stats {\n        display: flex;\n        gap: 16px;\n        font-size: 12px;\n        color: #909399;\n        margin-bottom: 12px;\n        i { margin-right: 2px; }\n      }\n\n      .course-actions {\n        .el-button { width: 100%; }\n      }\n    }\n  }\n}\n</style>\n"],"mappings":";AA0DA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACA,MAAAD,eAAA;MACA,KAAAF,OAAA;MACA;QACA,MAAAI,GAAA,cAAAC,KAAA,CAAAC,GAAA;QACA,KAAAP,OAAA,GAAAQ,KAAA,CAAAC,OAAA,CAAAJ,GAAA,IAAAA,GAAA,GAAAA,GAAA,EAAAK,OAAA;MACA,SAAAC,CAAA;QACAC,OAAA,CAAAC,KAAA,cAAAF,CAAA;QACA,KAAAG,QAAA,CAAAD,KAAA;MACA;QACA,KAAAZ,OAAA;MACA;IACA;IACAc,WAAAC,QAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,YAAAF,QAAA;IACA;IACAG,iBAAAH,QAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,YAAAF,QAAA;IACA;IACA,MAAAI,cAAAC,IAAA;MACA;QACA,WAAAC,QAAA;UACAC,iBAAA;UAAAC,gBAAA;UAAAC,IAAA;QACA;QACA,WAAAnB,KAAA,CAAAoB,IAAA,2BAAAL,IAAA,CAAAL,QAAA;QACA,KAAAF,QAAA,CAAAa,OAAA;QACA,KAAAxB,cAAA;MACA,SAAAQ,CAAA;QACA,IAAAA,CAAA,oBAAAG,QAAA,CAAAD,KAAA;MACA;I