{"ast":null,"code":"import { marked } from 'marked';\nexport default {\n  name: 'NewsDetail',\n  data() {\n    return {\n      news: {\n        id: 0,\n        title: '',\n        category: '',\n        content: '',\n        viewCount: 0,\n        likeCount: 0,\n        createTime: ''\n      },\n      liked: false\n    };\n  },\n  computed: {\n    renderedContent() {\n      return this.news.content ? marked(this.news.content) : '';\n    }\n  },\n  created() {\n    this.getNewsDetail();\n  },\n  methods: {\n    formatTime(time) {\n      return new Date(time).toLocaleDateString('zh-CN');\n    },\n    async likeNews() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了');\n        return;\n      }\n      try {\n        await this.$http.post(`/news/like/${this.news.id}`);\n        this.news.likeCount++;\n        this.liked = true;\n        this.$message.success('点赞成功');\n      } catch (error) {\n        console.error('点赞失败:', error);\n        this.$message.error('点赞失败，请稍后重试');\n      }\n    },\n    shareNews() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.news.title,\n          url: window.location.href\n        });\n      }\n    },\n    async getNewsDetail() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/news/detail/${id}`);\n        console.log('News detail response:', res);\n        // 拦截器已经返回 res.data，直接使用\n        this.news = res || {};\n      } catch (error) {\n        console.error('获取资讯详情失败:', error);\n        this.$message.error('获取资讯详情失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["marked","name","data","news","id","title","category","content","viewCount","likeCount","createTime","liked","computed","renderedContent","created","getNewsDetail","methods","formatTime","time","Date","toLocaleDateString","likeNews","$message","warning","$http","post","success","error","console","shareNews","navigator","share","url","window","location","href","$route","params","res","get","log"],"sources":["src/views/news/NewsDetail.vue"],"sourcesContent":["<template>\n  <div class=\"news-detail\">\n    <el-backtop :right=\"40\" :bottom=\"40\" />\n\n    <div class=\"news-header\">\n      <el-button type=\"primary\" @click=\"$router.back()\" plain>\n        <i class=\"el-icon-arrow-left\"></i> 返回\n      </el-button>\n      <h1>{{ news.title }}</h1>\n      <div class=\"news-meta\">\n        <span class=\"category\">{{ news.category }}</span>\n        <span class=\"time\">{{ formatTime(news.createTime) }}</span>\n        <span class=\"view-count\"><i class=\"el-icon-view\"></i> {{ news.viewCount }}</span>\n      </div>\n    </div>\n\n    <div class=\"news-content\" v-html=\"renderedContent\"></div>\n\n    <div class=\"news-actions\">\n      <el-button @click=\"likeNews\">\n        <i class=\"el-icon-star-off\"></i> 点赞 ({{ news.likeCount }})\n      </el-button>\n      <el-button @click=\"shareNews\">\n        <i class=\"el-icon-share\"></i> 分享\n      </el-button>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { marked } from 'marked'\n\nexport default {\n  name: 'NewsDetail',\n  data() {\n    return {\n      news: {\n        id: 0,\n        title: '',\n        category: '',\n        content: '',\n        viewCount: 0,\n        likeCount: 0,\n        createTime: ''\n      },\n      liked: false\n    }\n  },\n  computed: {\n    renderedContent() {\n      return this.news.content ? marked(this.news.content) : ''\n    }\n  },\n  created() {\n    this.getNewsDetail()\n  },\n  methods: {\n    formatTime(time) {\n      return new Date(time).toLocaleDateString('zh-CN')\n    },\n    async likeNews() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了')\n        return\n      }\n\n      try {\n        await this.$http.post(`/news/like/${this.news.id}`)\n        this.news.likeCount++\n        this.liked = true\n        this.$message.success('点赞成功')\n      } catch (error) {\n        console.error('点赞失败:', error)\n        this.$message.error('点赞失败，请稍后重试')\n      }\n    },\n    shareNews() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.news.title,\n          url: window.location.href\n        })\n      }\n    },\n    async getNewsDetail() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/news/detail/${id}`)\n        console.log('News detail response:', res)\n        // 拦截器已经返回 res.data，直接使用\n        this.news = res || {}\n      } catch (error) {\n        console.error('获取资讯详情失败:', error)\n        this.$message.error('获取资讯详情失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.news-detail {\n  padding: 20px;\n\n  .news-header {\n    margin-bottom: 30px;\n\n    h1 {\n      font-size: 24px;\n      color: #303133;\n      margin: 20px 0;\n    }\n\n    .news-meta {\n      display: flex;\n      gap: 20px;\n      font-size: 14px;\n      color: #909399;\n\n      .category {\n        background: #ECF5FF;\n        color: #409EFF;\n        padding: 4px 12px;\n        border-radius: 4px;\n      }\n    }\n  }\n\n  .news-content {\n    background: #fff;\n    padding: 30px;\n    border-radius: 8px;\n    box-shadow: 0 2px 12px rgba(0,0,0,0.1);\n    margin-bottom: 30px;\n    line-height: 1.8;\n    color: #606266;\n\n    h1, h2, h3 {\n      color: #303133;\n      margin: 20px 0 15px;\n    }\n\n    h1 {\n      font-size: 22px;\n    }\n\n    h2 {\n      font-size: 20px;\n      border-bottom: 1px solid #EBEEF5;\n      padding-bottom: 10px;\n    }\n\n    h3 {\n      font-size: 18px;\n    }\n\n    p {\n      margin: 15px 0;\n    }\n\n    ul, ol {\n      margin: 15px 0;\n      padding-left: 30px;\n    }\n\n    li {\n      margin: 8px 0;\n    }\n\n    strong {\n      font-weight: 600;\n      color: #303133;\n    }\n\n    br {\n      margin: 5px 0;\n    }\n  }\n\n  .news-actions {\n    display: flex;\n    gap: 20px;\n    margin-bottom: 40px;\n  }\n}\n</style>\n"],"mappings":"AA8BA,SAAAA,MAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,OAAA;QACAC,SAAA;QACAC,SAAA;QACAC,UAAA;MACA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACAC,gBAAA;MACA,YAAAV,IAAA,CAAAI,OAAA,GAAAP,MAAA,MAAAG,IAAA,CAAAI,OAAA;IACA;EACA;EACAO,QAAA;IACA,KAAAC,aAAA;EACA;EACAC,OAAA;IACAC,WAAAC,IAAA;MACA,WAAAC,IAAA,CAAAD,IAAA,EAAAE,kBAAA;IACA;IACA,MAAAC,SAAA;MACA,SAAAV,KAAA;QACA,KAAAW,QAAA,CAAAC,OAAA;QACA;MACA;MAEA;QACA,WAAAC,KAAA,CAAAC,IAAA,oBAAAtB,IAAA,CAAAC,EAAA;QACA,KAAAD,IAAA,CAAAM,SAAA;QACA,KAAAE,KAAA;QACA,KAAAW,QAAA,CAAAI,OAAA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAL,QAAA,CAAAK,KAAA;MACA;IACA;IACAE,UAAA;MACA,IAAAC,SAAA,CAAAC,KAAA;QACAD,SAAA,CAAAC,KAAA;UACA1B,KAAA,OAAAF,IAAA,CAAAE,KAAA;UACA2B,GAAA,EAAAC,MAAA,CAAAC,QAAA,CAAAC;QACA;MACA;IACA;IACA,MAAApB,cAAA;MACA;QACA,MAAAX,EAAA,QAAAgC,MAAA,CAAAC,MAAA,CAAAjC,EAAA;QACA,MAAAkC,GAAA,cAAAd,KAAA,CAAAe,GAAA,iBAAAnC,EAAA;QACAwB,OAAA,CAAAY,GAAA,0BAAAF,GAAA;QACA;QACA,KAAAnC,IAAA,GAAAmC,GAAA;MACA,SAAAX,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAL,QAAA,CAAAK,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}