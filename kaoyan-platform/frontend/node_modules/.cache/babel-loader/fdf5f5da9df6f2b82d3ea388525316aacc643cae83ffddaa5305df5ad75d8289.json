{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nexport default {\n  name: 'MyCourses',\n  data() {\n    return {\n      courses: [],\n      loading: true\n    };\n  },\n  computed: {\n    inProgressCourses() {\n      return this.courses.filter(c => (c.progress || 0) < 100);\n    },\n    completedCourses() {\n      return this.courses.filter(c => (c.progress || 0) >= 100);\n    },\n    averageProgress() {\n      if (this.courses.length === 0) return 0;\n      const total = this.courses.reduce((sum, c) => sum + (c.progress || 0), 0);\n      return Math.round(total / this.courses.length);\n    },\n    totalStudyHours() {\n      const mins = this.courses.reduce((sum, c) => sum + (c.studyDuration || 0), 0);\n      return Math.round(mins / 60 * 10) / 10;\n    },\n    completedCount() {\n      return this.completedCourses.length;\n    }\n  },\n  created() {\n    this.fetchMyCourses();\n  },\n  methods: {\n    async fetchMyCourses() {\n      this.loading = true;\n      try {\n        const res = await this.$http.get('/course/user-courses');\n        this.courses = Array.isArray(res) ? res : res?.records || [];\n      } catch (e) {\n        console.error('获取我的课程失败:', e);\n        this.$message.error('获取课程列表失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    getCover(item) {\n      return item.cover || '';\n    },\n    goToCourse(courseId) {\n      this.$router.push(`/course/${courseId}`);\n    },\n    continueLearning(courseId) {\n      this.$router.push(`/course/${courseId}/learning`);\n    },\n    async requestRefund(item) {\n      try {\n        await this.$confirm('确定要申请退款吗？', '退款申请', {\n          confirmButtonText: '确定退款',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n        await this.$http.post(`/course/refund-request/${item.id}`, {\n          reason: '用户申请退款'\n        });\n        this.$message.success('退款申请已提交，请等待管理员审核');\n        this.fetchMyCourses();\n      } catch (e) {\n        if (e !== 'cancel') this.$message.error('申请退款失败');\n      }\n    },\n    progressColor(progress) {\n      if (progress >= 80) return '#67C23A';\n      if (progress >= 40) return '#409EFF';\n      return '#E6A23C';\n    },\n    formatDuration(minutes) {\n      if (!minutes) return '0分钟';\n      const h = Math.floor(minutes / 60);\n      const m = minutes % 60;\n      return h > 0 ? `${h}小时${m}分钟` : `${m}分钟`;\n    },\n    formatDate(dateStr) {\n      if (!dateStr) return '';\n      try {\n        return new Date(dateStr).toLocaleDateString('zh-CN');\n      } catch (e) {\n        return dateStr;\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","courses","loading","computed","inProgressCourses","filter","c","progress","completedCourses","averageProgress","length","total","reduce","sum","Math","round","totalStudyHours","mins","studyDuration","completedCount","created","fetchMyCourses","methods","res","$http","get","Array","isArray","records","e","console","error","$message","getCover","item","cover","goToCourse","courseId","$router","push","continueLearning","requestRefund","$confirm","confirmButtonText","cancelButtonText","type","post","id","reason","success","progressColor","formatDuration","minutes","h","floor","m","formatDate","dateStr","Date","toLocaleDateString"],"sources":["src/views/course/MyCourses.vue"],"sourcesContent":["<template>\n  <div class=\"my-courses\">\n    <div class=\"page-header\">\n      <h2>我的课程</h2>\n      <p class=\"subtitle\">管理已购买的课程，继续你的学习之旅</p>\n    </div>\n\n    <!-- 学习概览统计 -->\n    <div class=\"overview-stats\" v-if=\"courses.length > 0\">\n      <div class=\"overview-card\">\n        <div class=\"overview-icon courses-icon\"><i class=\"el-icon-video-camera\"></i></div>\n        <div class=\"overview-body\">\n          <div class=\"overview-value\">{{ courses.length }}</div>\n          <div class=\"overview-label\">已购课程</div>\n        </div>\n      </div>\n      <div class=\"overview-card\">\n        <div class=\"overview-icon progress-icon\"><i class=\"el-icon-loading\"></i></div>\n        <div class=\"overview-body\">\n          <div class=\"overview-value\">{{ averageProgress }}%</div>\n          <div class=\"overview-label\">平均进度</div>\n        </div>\n      </div>\n      <div class=\"overview-card\">\n        <div class=\"overview-icon time-icon\"><i class=\"el-icon-time\"></i></div>\n        <div class=\"overview-body\">\n          <div class=\"overview-value\">{{ totalStudyHours }}h</div>\n          <div class=\"overview-label\">总学习时长</div>\n        </div>\n      </div>\n      <div class=\"overview-card\">\n        <div class=\"overview-icon done-icon\"><i class=\"el-icon-circle-check\"></i></div>\n        <div class=\"overview-body\">\n          <div class=\"overview-value\">{{ completedCount }}</div>\n          <div class=\"overview-label\">已完成</div>\n        </div>\n      </div>\n    </div>\n\n    <div v-if=\"loading\" class=\"loading-container\">\n      <el-skeleton :rows=\"4\" animated />\n    </div>\n\n    <div v-else-if=\"courses.length === 0\" class=\"empty-state\">\n      <el-empty description=\"还没有购买任何课程\">\n        <el-button type=\"primary\" @click=\"$router.push('/course')\">去看看课程</el-button>\n      </el-empty>\n    </div>\n\n    <div v-else class=\"courses-wrap\">\n      <!-- 进行中的课程 -->\n      <div class=\"section\" v-if=\"inProgressCourses.length > 0\">\n        <h3 class=\"section-title\"><i class=\"el-icon-s-data\"></i> 进行中 ({{ inProgressCourses.length }})</h3>\n        <div class=\"course-grid\">\n          <el-card v-for=\"item in inProgressCourses\" :key=\"item.id\" class=\"course-card\" shadow=\"hover\">\n            <div class=\"course-cover-wrap\" @click=\"goToCourse(item.id)\">\n              <img :src=\"getCover(item)\" alt=\"课程封面\" class=\"course-cover\" />\n              <div class=\"cover-overlay\">\n                <el-button type=\"primary\" size=\"small\">查看详情</el-button>\n              </div>\n              <div class=\"progress-badge\" :style=\"{ width: (item.progress || 0) + '%' }\"></div>\n            </div>\n            <div class=\"course-info\">\n              <h3 class=\"course-title\" @click=\"goToCourse(item.id)\">{{ item.title }}</h3>\n              <div class=\"course-meta\">\n                <span>{{ item.lessonCount || 0 }}课时</span>\n                <el-tag v-if=\"item.stage\" size=\"mini\">{{ item.stage }}</el-tag>\n              </div>\n              <div class=\"progress-section\">\n                <div class=\"progress-label\">\n                  <span>学习进度</span>\n                  <span class=\"progress-percent\">{{ item.progress || 0 }}%</span>\n                </div>\n                <el-progress :percentage=\"item.progress || 0\" :stroke-width=\"8\" :color=\"progressColor(item.progress)\" />\n              </div>\n              <div class=\"course-stats\">\n                <span><i class=\"el-icon-time\"></i> {{ formatDuration(item.studyDuration) }}</span>\n                <span v-if=\"item.lastStudyTime\"><i class=\"el-icon-date\"></i> {{ formatDate(item.lastStudyTime) }}</span>\n              </div>\n              <div class=\"course-actions\">\n                <el-button type=\"primary\" size=\"small\" @click=\"continueLearning(item.id)\" style=\"width:100%\">\n                  {{ item.progress > 0 ? '继续学习' : '开始学习' }}\n                </el-button>\n              </div>\n            </div>\n          </el-card>\n        </div>\n      </div>\n\n      <!-- 已完成的课程 -->\n      <div class=\"section\" v-if=\"completedCourses.length > 0\">\n        <h3 class=\"section-title completed-title\"><i class=\"el-icon-circle-check\"></i> 已完成 ({{ completedCourses.length }})</h3>\n        <div class=\"course-grid\">\n          <el-card v-for=\"item in completedCourses\" :key=\"item.id\" class=\"course-card completed-card\" shadow=\"hover\">\n            <div class=\"course-cover-wrap\" @click=\"goToCourse(item.id)\">\n              <img :src=\"getCover(item)\" alt=\"课程封面\" class=\"course-cover\" />\n              <div class=\"cover-overlay\">\n                <el-button type=\"primary\" size=\"small\">查看详情</el-button>\n              </div>\n              <div class=\"completed-tag\"><i class=\"el-icon-check\"></i> 已完成</div>\n            </div>\n            <div class=\"course-info\">\n              <h3 class=\"course-title\" @click=\"goToCourse(item.id)\">{{ item.title }}</h3>\n              <div class=\"course-meta\">\n                <span>{{ item.lessonCount || 0 }}课时</span>\n                <el-tag v-if=\"item.stage\" size=\"mini\">{{ item.stage }}</el-tag>\n              </div>\n              <div class=\"course-stats\">\n                <span><i class=\"el-icon-time\"></i> {{ formatDuration(item.studyDuration) }}</span>\n                <span v-if=\"item.lastStudyTime\"><i class=\"el-icon-date\"></i> {{ formatDate(item.lastStudyTime) }}</span>\n              </div>\n              <div class=\"course-actions\">\n                <el-button size=\"small\" @click=\"continueLearning(item.id)\" style=\"width:100%\">复习课程</el-button>\n              </div>\n            </div>\n          </el-card>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'MyCourses',\n  data() {\n    return {\n      courses: [],\n      loading: true\n    }\n  },\n  computed: {\n    inProgressCourses() {\n      return this.courses.filter(c => (c.progress || 0) < 100)\n    },\n    completedCourses() {\n      return this.courses.filter(c => (c.progress || 0) >= 100)\n    },\n    averageProgress() {\n      if (this.courses.length === 0) return 0\n      const total = this.courses.reduce((sum, c) => sum + (c.progress || 0), 0)\n      return Math.round(total / this.courses.length)\n    },\n    totalStudyHours() {\n      const mins = this.courses.reduce((sum, c) => sum + (c.studyDuration || 0), 0)\n      return Math.round(mins / 60 * 10) / 10\n    },\n    completedCount() {\n      return this.completedCourses.length\n    }\n  },\n  created() {\n    this.fetchMyCourses()\n  },\n  methods: {\n    async fetchMyCourses() {\n      this.loading = true\n      try {\n        const res = await this.$http.get('/course/user-courses')\n        this.courses = Array.isArray(res) ? res : (res?.records || [])\n      } catch (e) {\n        console.error('获取我的课程失败:', e)\n        this.$message.error('获取课程列表失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    getCover(item) {\n      return item.cover || ''\n    },\n    goToCourse(courseId) {\n      this.$router.push(`/course/${courseId}`)\n    },\n    continueLearning(courseId) {\n      this.$router.push(`/course/${courseId}/learning`)\n    },\n    async requestRefund(item) {\n      try {\n        await this.$confirm('确定要申请退款吗？', '退款申请', {\n          confirmButtonText: '确定退款', cancelButtonText: '取消', type: 'warning'\n        })\n        await this.$http.post(`/course/refund-request/${item.id}`, {\n          reason: '用户申请退款'\n        })\n        this.$message.success('退款申请已提交，请等待管理员审核')\n        this.fetchMyCourses()\n      } catch (e) {\n        if (e !== 'cancel') this.$message.error('申请退款失败')\n      }\n    },\n    progressColor(progress) {\n      if (progress >= 80) return '#67C23A'\n      if (progress >= 40) return '#409EFF'\n      return '#E6A23C'\n    },\n    formatDuration(minutes) {\n      if (!minutes) return '0分钟'\n      const h = Math.floor(minutes / 60)\n      const m = minutes % 60\n      return h > 0 ? `${h}小时${m}分钟` : `${m}分钟`\n    },\n    formatDate(dateStr) {\n      if (!dateStr) return ''\n      try {\n        return new Date(dateStr).toLocaleDateString('zh-CN')\n      } catch (e) { return dateStr }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.my-courses {\n  padding: 20px;\n  max-width: 1200px;\n  margin: 0 auto;\n\n  .page-header {\n    margin-bottom: 24px;\n    h2 { font-size: 24px; color: #303133; margin: 0 0 6px; }\n    .subtitle { color: #909399; font-size: 14px; margin: 0; }\n  }\n\n  .overview-stats {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 16px;\n    margin-bottom: 28px;\n\n    .overview-card {\n      display: flex;\n      align-items: center;\n      gap: 14px;\n      padding: 20px;\n      background: #fff;\n      border-radius: 10px;\n      box-shadow: 0 2px 12px rgba(0,0,0,.06);\n\n      .overview-icon {\n        width: 48px; height: 48px; border-radius: 10px;\n        display: flex; align-items: center; justify-content: center;\n        font-size: 22px; flex-shrink: 0;\n      }\n      .courses-icon { background: #ecf5ff; color: #409eff; }\n      .progress-icon { background: #fef0f0; color: #e6a23c; }\n      .time-icon { background: #f0f9eb; color: #67c23a; }\n      .done-icon { background: #fdf6ec; color: #e6a23c; }\n\n      .overview-body {\n        .overview-value { font-size: 24px; font-weight: 700; color: #303133; }\n        .overview-label { font-size: 13px; color: #909399; }\n      }\n    }\n  }\n\n  .loading-container { padding: 40px; }\n\n  .empty-state {\n    padding: 80px 0; text-align: center;\n  }\n\n  .courses-wrap {\n    .section {\n      margin-bottom: 32px;\n      .section-title {\n        font-size: 17px; color: #303133; margin: 0 0 16px;\n        padding-left: 12px; border-left: 3px solid #409eff;\n        i { margin-right: 6px; }\n      }\n      .completed-title { border-left-color: #67c23a; }\n    }\n  }\n\n  .course-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 20px;\n  }\n\n  .course-card {\n    transition: all 0.3s;\n    &:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.12); }\n    &.completed-card { opacity: .8; }\n\n    .course-cover-wrap {\n      position: relative; cursor: pointer; overflow: hidden;\n      border-radius: 4px; margin-bottom: 12px;\n\n      .course-cover {\n        width: 100%; height: 160px; object-fit: cover;\n        background: #f5f7fa; display: block;\n      }\n\n      .cover-overlay {\n        position: absolute; inset: 0;\n        background: rgba(0,0,0,.4);\n        display: flex; align-items: center; justify-content: center;\n        opacity: 0; transition: opacity .3s;\n      }\n      &:hover .cover-overlay { opacity: 1; }\n\n      .progress-badge {\n        position: absolute; bottom: 0; left: 0; height: 3px;\n        background: #67c23a; transition: width .5s;\n      }\n\n      .completed-tag {\n        position: absolute; top: 10px; right: 10px;\n        background: rgba(103,194,58,.9); color: #fff;\n        padding: 4px 10px; border-radius: 12px; font-size: 12px;\n      }\n    }\n\n    .course-info {\n      .course-title {\n        font-size: 15px; color: #303133; margin: 0 0 8px;\n        cursor: pointer; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;\n        &:hover { color: #409eff; }\n      }\n\n      .course-meta {\n        display: flex; gap: 10px; font-size: 13px; color: #909399; margin-bottom: 10px;\n      }\n\n      .progress-section {\n        margin-bottom: 10px;\n        .progress-label {\n          display: flex; justify-content: space-between;\n          font-size: 13px; color: #606266; margin-bottom: 4px;\n          .progress-percent { font-weight: 600; }\n        }\n      }\n\n      .course-stats {\n        display: flex; gap: 16px; font-size: 12px; color: #909399; margin-bottom: 12px;\n        i { margin-right: 2px; }\n      }\n    }\n  }\n}\n\n@media (max-width: 768px) {\n  .overview-stats { grid-template-columns: repeat(2, 1fr); }\n}\n</style>\n"],"mappings":";;;;AA2HA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACAC,kBAAA;MACA,YAAAH,OAAA,CAAAI,MAAA,CAAAC,CAAA,KAAAA,CAAA,CAAAC,QAAA;IACA;IACAC,iBAAA;MACA,YAAAP,OAAA,CAAAI,MAAA,CAAAC,CAAA,KAAAA,CAAA,CAAAC,QAAA;IACA;IACAE,gBAAA;MACA,SAAAR,OAAA,CAAAS,MAAA;MACA,MAAAC,KAAA,QAAAV,OAAA,CAAAW,MAAA,EAAAC,GAAA,EAAAP,CAAA,KAAAO,GAAA,IAAAP,CAAA,CAAAC,QAAA;MACA,OAAAO,IAAA,CAAAC,KAAA,CAAAJ,KAAA,QAAAV,OAAA,CAAAS,MAAA;IACA;IACAM,gBAAA;MACA,MAAAC,IAAA,QAAAhB,OAAA,CAAAW,MAAA,EAAAC,GAAA,EAAAP,CAAA,KAAAO,GAAA,IAAAP,CAAA,CAAAY,aAAA;MACA,OAAAJ,IAAA,CAAAC,KAAA,CAAAE,IAAA;IACA;IACAE,eAAA;MACA,YAAAX,gBAAA,CAAAE,MAAA;IACA;EACA;EACAU,QAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACA,MAAAD,eAAA;MACA,KAAAnB,OAAA;MACA;QACA,MAAAqB,GAAA,cAAAC,KAAA,CAAAC,GAAA;QACA,KAAAxB,OAAA,GAAAyB,KAAA,CAAAC,OAAA,CAAAJ,GAAA,IAAAA,GAAA,GAAAA,GAAA,EAAAK,OAAA;MACA,SAAAC,CAAA;QACAC,OAAA,CAAAC,KAAA,cAAAF,CAAA;QACA,KAAAG,QAAA,CAAAD,KAAA;MACA;QACA,KAAA7B,OAAA;MACA;IACA;IACA+B,SAAAC,IAAA;MACA,OAAAA,IAAA,CAAAC,KAAA;IACA;IACAC,WAAAC,QAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,YAAAF,QAAA;IACA;IACAG,iBAAAH,QAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,YAAAF,QAAA;IACA;IACA,MAAAI,cAAAP,IAAA;MACA;QACA,WAAAQ,QAAA;UACAC,iBAAA;UAAAC,gBAAA;UAAAC,IAAA;QACA;QACA,WAAArB,KAAA,CAAAsB,IAAA,2BAAAZ,IAAA,CAAAa,EAAA;UACAC,MAAA;QACA;QACA,KAAAhB,QAAA,CAAAiB,OAAA;QACA,KAAA5B,cAAA;MACA,SAAAQ,CAAA;QACA,IAAAA,CAAA,oBAAAG,QAAA,CAAAD,KAAA;MACA;IACA;IACAmB,cAAA3C,QAAA;MACA,IAAAA,QAAA;MACA,IAAAA,QAAA;MACA;IACA;IACA4C,eAAAC,OAAA;MACA,KAAAA,OAAA;MACA,MAAAC,CAAA,GAAAvC,IAAA,CAAAwC,KAAA,CAAAF,OAAA;MACA,MAAAG,CAAA,GAAAH,OAAA;MACA,OAAAC,CAAA,UAAAA,CAAA,KAAAE,CAAA,UAAAA,CAAA;IACA;IACAC,WAAAC,OAAA;MACA,KAAAA,OAAA;MACA;QACA,WAAAC,IAAA,CAAAD,OAAA,EAAAE,kBAAA;MACA,SAAA9B,CAAA;QAAA,OAAA4B,OAAA;MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}