{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'LiveList',\n  data() {\n    return {\n      liveList: [],\n      loading: false,\n      page: 1,\n      size: 10,\n      total: 0\n    };\n  },\n  created() {\n    this.fetch();\n  },\n  methods: {\n    async fetch() {\n      this.loading = true;\n      try {\n        const res = await this.$http.get('/live/list', {\n          params: {\n            page: this.page,\n            size: this.size\n          }\n        });\n        this.liveList = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (e) {} finally {\n        this.loading = false;\n      }\n    },\n    handlePage(p) {\n      this.page = p;\n      this.fetch();\n    },\n    enterLive(row) {\n      this.$router.push(`/live/${row.id}`);\n    },\n    viewReplay(row) {\n      if (row.courseId) this.$router.push(`/course/${row.courseId}/learning`);\n    }\n  }\n};","map":{"version":3,"names":["name","data","liveList","loading","page","size","total","created","fetch","methods","res","$http","get","params","records","e","handlePage","p","enterLive","row","$router","push","id","viewReplay","courseId"],"sources":["src/views/live/LiveList.vue"],"sourcesContent":["<template>\n  <div class=\"live-list-page\">\n    <div class=\"page-header\"><h1>考研直播</h1><p>名师直播授课，实时互动答疑</p></div>\n    <el-card>\n      <el-table :data=\"liveList\" stripe v-loading=\"loading\">\n        <el-table-column prop=\"title\" label=\"直播标题\" />\n        <el-table-column prop=\"teacherName\" label=\"讲师\" width=\"100\" />\n        <el-table-column prop=\"startTime\" label=\"开始时间\" width=\"180\" />\n        <el-table-column prop=\"viewerCount\" label=\"观看人数\" width=\"100\" />\n        <el-table-column label=\"状态\" width=\"100\"><template slot-scope=\"s\"><el-tag :type=\"s.row.status===0?'info':s.row.status===1?'danger':'info'\">{{ s.row.status===0?'未开始':s.row.status===1?'直播中':'已结束' }}</el-tag></template></el-table-column>\n        <el-table-column label=\"操作\" width=\"120\"><template slot-scope=\"s\"><el-button v-if=\"s.row.status===0\" type=\"info\" size=\"small\" disabled>未开始</el-button><el-button v-if=\"s.row.status===1\" type=\"danger\" size=\"small\" @click=\"enterLive(s.row)\">进入直播间</el-button><el-button v-if=\"s.row.status===2\" type=\"default\" size=\"small\" @click=\"viewReplay(s.row)\">回放</el-button></template></el-table-column>\n      </el-table>\n      <el-pagination style=\"margin-top:16px\" @current-change=\"handlePage\" :current-page=\"page\" :page-size=\"size\" :total=\"total\" layout=\"total,prev,pager,next\"/>\n    </el-card>\n  </div>\n</template>\n<script>\nexport default {\n  name: 'LiveList',\n  data() { return { liveList:[], loading:false, page:1, size:10, total:0 } },\n  created() { this.fetch() },\n  methods: {\n    async fetch() { this.loading=true; try { const res = await this.$http.get('/live/list',{params:{page:this.page,size:this.size}}); this.liveList=res?.records||[]; this.total=res?.total||0 } catch(e){} finally { this.loading=false } },\n    handlePage(p) { this.page=p; this.fetch() },\n    enterLive(row) { this.$router.push(`/live/${row.id}`) },\n    viewReplay(row) { if(row.courseId) this.$router.push(`/course/${row.courseId}/learning`) }\n  }\n}\n</script>\n<style scoped>\n.live-list-page { padding:20px; max-width:1200px; margin:0 auto; }\n.page-header { margin-bottom:20px; } .page-header h1 { font-size:24px; margin-bottom:8px; } .page-header p { color:#909399; }\n</style>\n"],"mappings":";AAiBA;EACAA,IAAA;EACAC,KAAA;IAAA;MAAAC,QAAA;MAAAC,OAAA;MAAAC,IAAA;MAAAC,IAAA;MAAAC,KAAA;IAAA;EAAA;EACAC,QAAA;IAAA,KAAAC,KAAA;EAAA;EACAC,OAAA;IACA,MAAAD,MAAA;MAAA,KAAAL,OAAA;MAAA;QAAA,MAAAO,GAAA,cAAAC,KAAA,CAAAC,GAAA;UAAAC,MAAA;YAAAT,IAAA,OAAAA,IAAA;YAAAC,IAAA,OAAAA;UAAA;QAAA;QAAA,KAAAH,QAAA,GAAAQ,GAAA,EAAAI,OAAA;QAAA,KAAAR,KAAA,GAAAI,GAAA,EAAAJ,KAAA;MAAA,SAAAS,CAAA;QAAA,KAAAZ,OAAA;MAAA;IAAA;IACAa,WAAAC,CAAA;MAAA,KAAAb,IAAA,GAAAa,CAAA;MAAA,KAAAT,KAAA;IAAA;IACAU,UAAAC,GAAA;MAAA,KAAAC,OAAA,CAAAC,IAAA,UAAAF,GAAA,CAAAG,EAAA;IAAA;IACAC,WAAAJ,GAAA;MAAA,IAAAA,GAAA,CAAAK,QAAA,OAAAJ,OAAA,CAAAC,IAAA,YAAAF,GAAA,CAAAK,QAAA;IAAA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}