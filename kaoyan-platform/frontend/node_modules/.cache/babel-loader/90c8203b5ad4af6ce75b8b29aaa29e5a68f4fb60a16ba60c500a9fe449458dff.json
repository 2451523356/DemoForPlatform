{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.json.parse.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport { marked } from 'marked';\nimport ShareDialog from '@/components/ShareDialog';\nexport default {\n  name: 'NewsDetail',\n  components: {\n    ShareDialog\n  },\n  data() {\n    return {\n      news: {\n        id: 0,\n        title: '',\n        category: '',\n        content: '',\n        viewCount: 0,\n        likeCount: 0,\n        createTime: ''\n      },\n      liked: false,\n      bookmarked: false,\n      relatedNews: []\n    };\n  },\n  computed: {\n    renderedContent() {\n      return this.news.content ? marked(this.news.content) : '';\n    }\n  },\n  created() {\n    const bookmarks = JSON.parse(localStorage.getItem('bookmarkedNews') || '[]');\n    const id = parseInt(this.$route.params.id);\n    this.bookmarked = bookmarks.includes(id);\n    this.getNewsDetail();\n  },\n  methods: {\n    toggleBookmark() {\n      const bookmarks = JSON.parse(localStorage.getItem('bookmarkedNews') || '[]');\n      const id = this.news.id;\n      if (this.bookmarked) {\n        const idx = bookmarks.indexOf(id);\n        if (idx > -1) bookmarks.splice(idx, 1);\n        this.$message.success('已取消收藏');\n      } else {\n        bookmarks.push(id);\n        this.$message.success('已收藏');\n      }\n      this.bookmarked = !this.bookmarked;\n      localStorage.setItem('bookmarkedNews', JSON.stringify(bookmarks));\n    },\n    formatTime(time) {\n      return new Date(time).toLocaleDateString('zh-CN');\n    },\n    async likeNews() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了');\n        return;\n      }\n      try {\n        await this.$http.post(`/news/like/${this.news.id}`);\n        this.news.likeCount++;\n        this.liked = true;\n        this.$message.success('点赞成功');\n      } catch (error) {\n        console.error('点赞失败:', error);\n        this.$message.error('点赞失败，请稍后重试');\n      }\n    },\n    shareNews() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.news.title,\n          url: window.location.href\n        });\n      }\n    },\n    async getNewsDetail() {\n      try {\n        const id = this.$route.params.id;\n        const res = await this.$http.get(`/news/detail/${id}`);\n        this.news = res || {};\n        // 加载相关资讯（同分类或备考阶段）\n        if (this.news.category || this.news.examStage) {\n          const relatedRes = await this.$http.get('/news/list', {\n            params: {\n              page: 1,\n              size: 5,\n              category: this.news.category\n            }\n          });\n          const records = relatedRes?.records || [];\n          this.relatedNews = records.filter(r => r.id !== this.news.id).slice(0, 5);\n        }\n      } catch (error) {\n        console.error('获取资讯详情失败:', error);\n        this.$message.error('获取资讯详情失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["marked","ShareDialog","name","components","data","news","id","title","category","content","viewCount","likeCount","createTime","liked","bookmarked","relatedNews","computed","renderedContent","created","bookmarks","JSON","parse","localStorage","getItem","parseInt","$route","params","includes","getNewsDetail","methods","toggleBookmark","idx","indexOf","splice","$message","success","push","setItem","stringify","formatTime","time","Date","toLocaleDateString","likeNews","warning","$http","post","error","console","shareNews","navigator","share","url","window","location","href","res","get","examStage","relatedRes","page","size","records","filter","r","slice"],"sources":["src/views/news/NewsDetail.vue"],"sourcesContent":["<template>\n  <div class=\"news-detail\">\n    <el-backtop :right=\"40\" :bottom=\"40\" />\n\n    <div class=\"news-header\">\n      <el-button type=\"primary\" @click=\"$router.back()\" plain>\n        <i class=\"el-icon-arrow-left\"></i> 返回\n      </el-button>\n      <h1>{{ news.title }}</h1>\n      <div class=\"news-meta\">\n        <span class=\"category\">{{ news.category }}</span>\n        <span class=\"time\">{{ formatTime(news.createTime) }}</span>\n        <span class=\"view-count\"><i class=\"el-icon-view\"></i> {{ news.viewCount }}</span>\n      </div>\n    </div>\n\n    <div class=\"news-content\" v-html=\"renderedContent\"></div>\n\n    <div class=\"news-actions\">\n      <el-button @click=\"likeNews\" :type=\"liked ? 'danger' : 'default'\">\n        <i :class=\"liked ? 'el-icon-star-on' : 'el-icon-star-off'\"></i> 点赞 ({{ news.likeCount }})\n      </el-button>\n      <el-button @click=\"toggleBookmark\" :type=\"bookmarked ? 'warning' : 'default'\">\n        <i :class=\"bookmarked ? 'el-icon-star-on' : 'el-icon-collection-tag'\"></i> {{ bookmarked ? '已收藏' : '收藏' }}\n      </el-button>\n      <el-button @click=\"shareDialogVisible = true\">\n        <i class=\"el-icon-share\"></i> 分享\n      </el-button>\n    </div>\n\n    <share-dialog v-model=\"shareDialogVisible\" :share-title=\"news.title\" :share-desc=\"news.summary\" />\n\n    <!-- 相关资讯推荐 -->\n    <div class=\"related-news\" v-if=\"relatedNews.length > 0\">\n      <h3>相关推荐</h3>\n      <div class=\"related-list\">\n        <div class=\"related-item\" v-for=\"item in relatedNews\" :key=\"item.id\" @click=\"$router.push(`/news/${item.id}`)\">\n          <span class=\"related-title\">{{ item.title }}</span>\n          <span class=\"related-meta\">{{ item.category }} · {{ formatTime(item.createTime) }}</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { marked } from 'marked'\nimport ShareDialog from '@/components/ShareDialog'\n\nexport default {\n  name: 'NewsDetail',\n  components: { ShareDialog },\n  data() {\n    return {\n      news: {\n        id: 0,\n        title: '',\n        category: '',\n        content: '',\n        viewCount: 0,\n        likeCount: 0,\n        createTime: ''\n      },\n      liked: false,\n      bookmarked: false,\n      relatedNews: []\n    }\n  },\n  computed: {\n    renderedContent() {\n      return this.news.content ? marked(this.news.content) : ''\n    }\n  },\n  created() {\n    const bookmarks = JSON.parse(localStorage.getItem('bookmarkedNews') || '[]')\n    const id = parseInt(this.$route.params.id)\n    this.bookmarked = bookmarks.includes(id)\n    this.getNewsDetail()\n  },\n  methods: {\n    toggleBookmark() {\n      const bookmarks = JSON.parse(localStorage.getItem('bookmarkedNews') || '[]')\n      const id = this.news.id\n      if (this.bookmarked) {\n        const idx = bookmarks.indexOf(id)\n        if (idx > -1) bookmarks.splice(idx, 1)\n        this.$message.success('已取消收藏')\n      } else {\n        bookmarks.push(id)\n        this.$message.success('已收藏')\n      }\n      this.bookmarked = !this.bookmarked\n      localStorage.setItem('bookmarkedNews', JSON.stringify(bookmarks))\n    },\n    formatTime(time) {\n      return new Date(time).toLocaleDateString('zh-CN')\n    },\n    async likeNews() {\n      if (this.liked) {\n        this.$message.warning('您已经点过赞了')\n        return\n      }\n\n      try {\n        await this.$http.post(`/news/like/${this.news.id}`)\n        this.news.likeCount++\n        this.liked = true\n        this.$message.success('点赞成功')\n      } catch (error) {\n        console.error('点赞失败:', error)\n        this.$message.error('点赞失败，请稍后重试')\n      }\n    },\n    shareNews() {\n      if (navigator.share) {\n        navigator.share({\n          title: this.news.title,\n          url: window.location.href\n        })\n      }\n    },\n    async getNewsDetail() {\n      try {\n        const id = this.$route.params.id\n        const res = await this.$http.get(`/news/detail/${id}`)\n        this.news = res || {}\n        // 加载相关资讯（同分类或备考阶段）\n        if (this.news.category || this.news.examStage) {\n          const relatedRes = await this.$http.get('/news/list', {\n            params: { page: 1, size: 5, category: this.news.category }\n          })\n          const records = relatedRes?.records || []\n          this.relatedNews = records.filter(r => r.id !== this.news.id).slice(0, 5)\n        }\n      } catch (error) {\n        console.error('获取资讯详情失败:', error)\n        this.$message.error('获取资讯详情失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.news-detail {\n  padding: 20px;\n\n  .news-header {\n    margin-bottom: 30px;\n\n    h1 {\n      font-size: 24px;\n      color: #303133;\n      margin: 20px 0;\n    }\n\n    .news-meta {\n      display: flex;\n      gap: 20px;\n      font-size: 14px;\n      color: #909399;\n\n      .category {\n        background: #ECF5FF;\n        color: #409EFF;\n        padding: 4px 12px;\n        border-radius: 4px;\n      }\n    }\n  }\n\n  .news-content {\n    background: #fff;\n    padding: 30px;\n    border-radius: 8px;\n    box-shadow: 0 2px 12px rgba(0,0,0,0.1);\n    margin-bottom: 30px;\n    line-height: 1.8;\n    color: #606266;\n\n    h1, h2, h3 {\n      color: #303133;\n      margin: 20px 0 15px;\n    }\n\n    h1 {\n      font-size: 22px;\n    }\n\n    h2 {\n      font-size: 20px;\n      border-bottom: 1px solid #EBEEF5;\n      padding-bottom: 10px;\n    }\n\n    h3 {\n      font-size: 18px;\n    }\n\n    p {\n      margin: 15px 0;\n    }\n\n    ul, ol {\n      margin: 15px 0;\n      padding-left: 30px;\n    }\n\n    li {\n      margin: 8px 0;\n    }\n\n    strong {\n      font-weight: 600;\n      color: #303133;\n    }\n\n    br {\n      margin: 5px 0;\n    }\n  }\n\n  .news-actions {\n    display: flex;\n    gap: 20px;\n    margin-bottom: 40px;\n  }\n\n  .related-news {\n    margin-top: 40px;\n    padding-top: 24px;\n    border-top: 1px solid #ebeef5;\n    h3 { font-size: 18px; color: #303133; margin: 0 0 16px; }\n    .related-list {\n      .related-item {\n        display: flex; justify-content: space-between; align-items: center;\n        padding: 12px 0; border-bottom: 1px solid #f5f7fa; cursor: pointer; transition: all .3s;\n        &:hover { color: #409eff; padding-left: 8px; }\n        .related-title { font-size: 14px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n        .related-meta { font-size: 12px; color: #c0c4cc; flex-shrink: 0; margin-left: 16px; }\n      }\n    }\n  }\n}\n</style>\n"],"mappings":";;;;;AA8CA,SAAAA,MAAA;AACA,OAAAC,WAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAF;EAAA;EACAG,KAAA;IACA;MACAC,IAAA;QACAC,EAAA;QACAC,KAAA;QACAC,QAAA;QACAC,OAAA;QACAC,SAAA;QACAC,SAAA;QACAC,UAAA;MACA;MACAC,KAAA;MACAC,UAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACAC,gBAAA;MACA,YAAAZ,IAAA,CAAAI,OAAA,GAAAT,MAAA,MAAAK,IAAA,CAAAI,OAAA;IACA;EACA;EACAS,QAAA;IACA,MAAAC,SAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;IACA,MAAAjB,EAAA,GAAAkB,QAAA,MAAAC,MAAA,CAAAC,MAAA,CAAApB,EAAA;IACA,KAAAQ,UAAA,GAAAK,SAAA,CAAAQ,QAAA,CAAArB,EAAA;IACA,KAAAsB,aAAA;EACA;EACAC,OAAA;IACAC,eAAA;MACA,MAAAX,SAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACA,MAAAjB,EAAA,QAAAD,IAAA,CAAAC,EAAA;MACA,SAAAQ,UAAA;QACA,MAAAiB,GAAA,GAAAZ,SAAA,CAAAa,OAAA,CAAA1B,EAAA;QACA,IAAAyB,GAAA,OAAAZ,SAAA,CAAAc,MAAA,CAAAF,GAAA;QACA,KAAAG,QAAA,CAAAC,OAAA;MACA;QACAhB,SAAA,CAAAiB,IAAA,CAAA9B,EAAA;QACA,KAAA4B,QAAA,CAAAC,OAAA;MACA;MACA,KAAArB,UAAA,SAAAA,UAAA;MACAQ,YAAA,CAAAe,OAAA,mBAAAjB,IAAA,CAAAkB,SAAA,CAAAnB,SAAA;IACA;IACAoB,WAAAC,IAAA;MACA,WAAAC,IAAA,CAAAD,IAAA,EAAAE,kBAAA;IACA;IACA,MAAAC,SAAA;MACA,SAAA9B,KAAA;QACA,KAAAqB,QAAA,CAAAU,OAAA;QACA;MACA;MAEA;QACA,WAAAC,KAAA,CAAAC,IAAA,oBAAAzC,IAAA,CAAAC,EAAA;QACA,KAAAD,IAAA,CAAAM,SAAA;QACA,KAAAE,KAAA;QACA,KAAAqB,QAAA,CAAAC,OAAA;MACA,SAAAY,KAAA;QACAC,OAAA,CAAAD,KAAA,UAAAA,KAAA;QACA,KAAAb,QAAA,CAAAa,KAAA;MACA;IACA;IACAE,UAAA;MACA,IAAAC,SAAA,CAAAC,KAAA;QACAD,SAAA,CAAAC,KAAA;UACA5C,KAAA,OAAAF,IAAA,CAAAE,KAAA;UACA6C,GAAA,EAAAC,MAAA,CAAAC,QAAA,CAAAC;QACA;MACA;IACA;IACA,MAAA3B,cAAA;MACA;QACA,MAAAtB,EAAA,QAAAmB,MAAA,CAAAC,MAAA,CAAApB,EAAA;QACA,MAAAkD,GAAA,cAAAX,KAAA,CAAAY,GAAA,iBAAAnD,EAAA;QACA,KAAAD,IAAA,