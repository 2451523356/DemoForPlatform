{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.json.parse.js\";\nexport default {\n  name: 'Practice',\n  data() {\n    return {\n      activeTab: 'practice',\n      filter: {\n        subject: '',\n        questionType: '',\n        year: null,\n        difficulty: null,\n        page: 1\n      },\n      years: [2024, 2023, 2022, 2021, 2020],\n      questions: [],\n      total: 0,\n      currentQuestion: null,\n      parsedOptions: [],\n      selectedAnswer: '',\n      selectedMultiAnswers: [],\n      answered: false,\n      resultCorrect: false,\n      resultTitle: '',\n      wrongQuestions: [],\n      stats: null,\n      examDialogVisible: false,\n      examActive: false,\n      examResultVisible: false,\n      examConfig: {\n        title: '模拟考试',\n        subject: '政治',\n        questionCount: 20,\n        totalDuration: 3600\n      },\n      examQuestions: [],\n      examAnswers: [],\n      currentExamIdx: 0,\n      examResult: null,\n      remainingSeconds: 0,\n      examTimer: null,\n      showDaily: false\n    };\n  },\n  computed: {\n    canSubmit() {\n      if (this.currentQuestion && this.currentQuestion.questionType === '多选') return this.selectedMultiAnswers.length > 0;\n      return !!this.selectedAnswer;\n    }\n  },\n  mounted() {\n    this.fetchQuestions();\n    this.fetchStats();\n    this.fetchWrongQuestions();\n  },\n  beforeDestroy() {\n    this.clearExamTimer();\n  },\n  methods: {\n    async fetchQuestions() {\n      try {\n        const p = {\n          page: this.filter.page,\n          size: 20\n        };\n        if (this.filter.subject) p.subject = this.filter.subject;\n        if (this.filter.questionType) p.questionType = this.filter.questionType;\n        if (this.filter.year) p.year = this.filter.year;\n        if (this.filter.difficulty) p.difficulty = this.filter.difficulty;\n        const res = await this.$http.get('/practice/questions', {\n          params: p\n        });\n        this.questions = res?.records || [];\n        this.total = res?.total || 0;\n        if (this.questions.length > 0) this.selectQuestion(this.questions[0]);\n      } catch (e) {\n        console.error(e);\n      }\n    },\n    selectQuestion(q) {\n      this.currentQuestion = q;\n      this.answered = false;\n      this.selectedAnswer = '';\n      this.selectedMultiAnswers = [];\n      this.parsedOptions = this.parseOptions(q.options);\n    },\n    parseOptions(opts) {\n      if (!opts) return [];\n      if (typeof opts === 'string') {\n        try {\n          return JSON.parse(opts);\n        } catch (e) {\n          return [];\n        }\n      }\n      return opts;\n    },\n    async submitAnswer() {\n      if (!this.currentQuestion) return;\n      const answer = this.currentQuestion.questionType === '多选' ? this.selectedMultiAnswers.sort().join('') : this.selectedAnswer;\n      try {\n        const res = await this.$http.post('/practice/answer', {\n          questionId: this.currentQuestion.id,\n          answer,\n          duration: 0,\n          sessionId: 'practice'\n        });\n        this.answered = true;\n        this.resultCorrect = res.isCorrect;\n        this.resultTitle = res.isCorrect ? '回答正确！' : `回答错误，正确答案是: ${res.correctAnswer}`;\n        // Enrich the current question with analysis\n        if (res.analysis) this.currentQuestion.analysis = res.analysis;\n        if (res.correctAnswer) this.currentQuestion.answer = res.correctAnswer;\n        this.fetchStats();\n      } catch (e) {\n        this.$message.error('提交失败');\n      }\n    },\n    skipQuestion() {\n      const idx = this.questions.findIndex(q => q.id === this.currentQuestion?.id);\n      if (idx >= 0 && idx < this.questions.length - 1) this.selectQuestion(this.questions[idx + 1]);else this.fetchQuestions();\n    },\n    nextQuestion() {\n      const idx = this.questions.findIndex(q => q.id === this.currentQuestion?.id);\n      if (idx >= 0 && idx < this.questions.length - 1) this.selectQuestion(this.questions[idx + 1]);else {\n        this.filter.page++;\n        this.fetchQuestions();\n      }\n    },\n    async fetchWrongQuestions() {\n      try {\n        const res = await this.$http.get('/practice/wrong-questions', {\n          params: {\n            limit: 50\n          }\n        });\n        this.wrongQuestions = res || [];\n      } catch (e) {}\n    },\n    async fetchStats() {\n      try {\n        this.stats = await this.$http.get('/practice/stats');\n      } catch (e) {}\n    },\n    startExam() {\n      this.examDialogVisible = true;\n    },\n    async beginExam() {\n      try {\n        const res = await this.$http.post('/practice/exam/start', this.examConfig);\n        const sessionId = res.id;\n        this.examSessionId = sessionId;\n        this.examDialogVisible = false;\n        // Fetch questions separately\n        const qRes = await this.$http.get('/practice/questions', {\n          params: {\n            subject: this.examConfig.subject,\n            size: this.examConfig.questionCount\n          }\n        });\n        this.examQuestions = qRes?.records || [];\n        this.examAnswers = new Array(this.examQuestions.length).fill('');\n        this.currentExamIdx = 0;\n        this.examActive = true;\n        this.remainingSeconds = this.examConfig.totalDuration;\n        this.startExamTimer();\n      } catch (e) {\n        this.$message.error('开始考试失败');\n      }\n    },\n    startExamTimer() {\n      this.clearExamTimer();\n      this.examTimer = setInterval(() => {\n        this.remainingSeconds--;\n        if (this.remainingSeconds <= 0) {\n          this.submitExam();\n          this.$message.warning('考试时间到，已自动交卷');\n        }\n      }, 1000);\n    },\n    clearExamTimer() {\n      if (this.examTimer) {\n        clearInterval(this.examTimer);\n        this.examTimer = null;\n      }\n    },\n    async submitExam() {\n      this.clearExamTimer();\n      const answers = this.examQuestions.map((q, i) => ({\n        questionId: q.id,\n        answer: this.examAnswers[i] || ''\n      }));\n      try {\n        this.examResult = await this.$http.post('/practice/exam/submit', {\n          sessionId: this.examSessionId,\n          answers\n        });\n        this.examActive = false;\n        this.examResultVisible = true;\n      } catch (e) {\n        this.$message.error('交卷失败');\n      }\n    },\n    formatDuration(seconds) {\n      if (!seconds) return '00:00';\n      const m = Math.floor(seconds / 60),\n        s = seconds % 60;\n      return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;\n    },\n    subjectTag(s) {\n      const m = {\n        '政治': 'danger',\n        '英语': 'success',\n        '数学': 'warning'\n      };\n      return m[s] || 'info';\n    },\n    showAnalysis(detail) {\n      this.$alert(detail.analysis || '暂无解析', `答案: ${detail.correctAnswer}`, {\n        confirmButtonText: '知道了'\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","activeTab","filter","subject","questionType","year","difficulty","page","years","questions","total","currentQuestion","parsedOptions","selectedAnswer","selectedMultiAnswers","answered","resultCorrect","resultTitle","wrongQuestions","stats","examDialogVisible","examActive","examResultVisible","examConfig","title","questionCount","totalDuration","examQuestions","examAnswers","currentExamIdx","examResult","remainingSeconds","examTimer","showDaily","computed","canSubmit","length","mounted","fetchQuestions","fetchStats","fetchWrongQuestions","beforeDestroy","clearExamTimer","methods","p","size","res","$http","get","params","records","selectQuestion","e","console","error","q","parseOptions","options","opts","JSON","parse","submitAnswer","answer","sort","join","post","questionId","id","duration","sessionId","isCorrect","correctAnswer","analysis","$message","skipQuestion","idx","findIndex","nextQuestion","limit","startExam","beginExam","examSessionId","qRes","Array","fill","startExamTimer","setInterval","submitExam","warning","clearInterval","answers","map","i","formatDuration","seconds","m","Math","floor","s","String","padStart","subjectTag","showAnalysis","detail","$alert","confirmButtonText"],"sources":["src/views/study/Practice.vue"],"sourcesContent":["<template>\n  <div class=\"practice-page\">\n    <div class=\"practice-header\">\n      <h2><i class=\"el-icon-edit-outline\"></i> 在线刷题</h2>\n      <div class=\"header-actions\">\n        <el-button type=\"primary\" size=\"small\" icon=\"el-icon-timer\" @click=\"startExam\">模拟考试</el-button>\n        <el-button size=\"small\" icon=\"el-icon-date\" @click=\"showDaily = true\">每日一题</el-button>\n      </div>\n    </div>\n\n    <el-tabs v-model=\"activeTab\" class=\"practice-tabs\">\n      <!-- ===== 练习模式 ===== -->\n      <el-tab-pane label=\"分类练习\" name=\"practice\">\n        <div class=\"filter-bar\">\n          <el-select v-model=\"filter.subject\" placeholder=\"科目\" size=\"small\" clearable @change=\"fetchQuestions\">\n            <el-option label=\"政治\" value=\"政治\"/><el-option label=\"英语\" value=\"英语\"/>\n            <el-option label=\"数学\" value=\"数学\"/>\n          </el-select>\n          <el-select v-model=\"filter.questionType\" placeholder=\"题型\" size=\"small\" clearable @change=\"fetchQuestions\">\n            <el-option label=\"单选\" value=\"单选\"/><el-option label=\"多选\" value=\"多选\"/>\n            <el-option label=\"判断\" value=\"判断\"/>\n          </el-select>\n          <el-select v-model=\"filter.year\" placeholder=\"年份\" size=\"small\" clearable @change=\"fetchQuestions\">\n            <el-option v-for=\"y in years\" :key=\"y\" :label=\"y+'年'\" :value=\"y\"/>\n          </el-select>\n          <el-select v-model=\"filter.difficulty\" placeholder=\"难度\" size=\"small\" clearable @change=\"fetchQuestions\">\n            <el-option label=\"★ 简单\" :value=\"1\"/><el-option label=\"★★ 较易\" :value=\"2\"/>\n            <el-option label=\"★★★ 中等\" :value=\"3\"/><el-option label=\"★★★★ 较难\" :value=\"4\"/>\n            <el-option label=\"★★★★★ 困难\" :value=\"5\"/>\n          </el-select>\n          <el-button type=\"text\" @click=\"fetchQuestions\" icon=\"el-icon-refresh\">刷新</el-button>\n        </div>\n\n        <div v-if=\"currentQuestion\" class=\"question-area\">\n          <div class=\"question-card\">\n            <div class=\"question-meta\">\n              <el-tag :type=\"subjectTag(currentQuestion.subject)\" size=\"small\">{{ currentQuestion.subject }}</el-tag>\n              <el-tag size=\"small\">{{ currentQuestion.questionType || '单选' }}</el-tag>\n              <el-tag v-if=\"currentQuestion.year\" size=\"small\" type=\"info\">{{ currentQuestion.year }}年</el-tag>\n              <el-tag size=\"small\" type=\"warning\">{{ '★'.repeat(currentQuestion.difficulty || 3) }}</el-tag>\n              <span class=\"knowledge-point\">{{ currentQuestion.knowledgePoint }}</span>\n            </div>\n            <div class=\"question-content\" v-html=\"currentQuestion.content\"></div>\n            <div class=\"options-area\" v-if=\"parsedOptions.length\">\n              <el-radio-group v-if=\"currentQuestion.questionType !== '多选'\" v-model=\"selectedAnswer\">\n                <el-radio v-for=\"opt in parsedOptions\" :key=\"opt.key\" :label=\"opt.key\" class=\"option-item\">\n                  <span class=\"option-key\">{{ opt.key }}.</span> {{ opt.value }}\n                </el-radio>\n              </el-radio-group>\n              <el-checkbox-group v-else v-model=\"selectedMultiAnswers\">\n                <el-checkbox v-for=\"opt in parsedOptions\" :key=\"opt.key\" :label=\"opt.key\" class=\"option-item\">\n                  <span class=\"option-key\">{{ opt.key }}.</span> {{ opt.value }}\n                </el-checkbox>\n              </el-checkbox-group>\n            </div>\n            <div class=\"question-actions\" v-if=\"!answered\">\n              <el-button type=\"primary\" @click=\"submitAnswer\" :disabled=\"!canSubmit\">提交答案</el-button>\n              <el-button @click=\"skipQuestion\">跳过</el-button>\n            </div>\n            <div v-else class=\"answer-result\">\n              <el-alert :title=\"resultTitle\" :type=\"resultCorrect ? 'success' : 'error'\" :closable=\"false\" show-icon/>\n              <div class=\"analysis-box\" v-if=\"currentQuestion.analysis\">\n                <h4>解析</h4>\n                <p>{{ currentQuestion.analysis }}</p>\n              </div>\n              <el-button type=\"primary\" size=\"small\" @click=\"nextQuestion\" style=\"margin-top:12px\">下一题</el-button>\n            </div>\n          </div>\n        </div>\n\n        <div v-else-if=\"questions.length > 0\" class=\"question-list\">\n          <el-card v-for=\"(q, idx) in questions\" :key=\"q.id\" class=\"q-item\" @click.native=\"selectQuestion(q)\">\n            <span class=\"q-index\">{{ idx + 1 }}</span>\n            <span class=\"q-text\">{{ q.content }}</span>\n            <div class=\"q-tags\">\n              <el-tag size=\"mini\">{{ q.subject }}</el-tag>\n              <el-tag size=\"mini\" type=\"info\">{{ '★'.repeat(q.difficulty||3) }}</el-tag>\n            </div>\n          </el-card>\n          <el-pagination :current-page=\"filter.page\" :page-size=\"20\" :total=\"total\" layout=\"prev,next\"\n            @current-change=\"(p) => { filter.page = p; fetchQuestions() }\" style=\"text-align:center;margin-top:20px\"/>\n        </div>\n\n        <div v-else class=\"empty-practice\">\n          <el-empty description=\"暂无匹配题目\"/>\n        </div>\n      </el-tab-pane>\n\n      <!-- ===== 错题本 ===== -->\n      <el-tab-pane label=\"错题回顾\" name=\"wrong\">\n        <div v-if=\"wrongQuestions.length > 0\" class=\"question-list\">\n          <el-card v-for=\"(q, idx) in wrongQuestions\" :key=\"q.id\" class=\"q-item\" @click.native=\"selectQuestion(q)\">\n            <span class=\"q-index\">{{ idx + 1 }}</span>\n            <span class=\"q-text\">{{ q.content }}</span>\n            <el-tag size=\"mini\">{{ q.subject }}</el-tag>\n          </el-card>\n        </div>\n        <el-empty v-else description=\"暂无错题，继续保持！\"/>\n      </el-tab-pane>\n\n      <!-- ===== 答题统计 ===== -->\n      <el-tab-pane label=\"答题统计\" name=\"stats\">\n        <div class=\"stats-grid\" v-if=\"stats\">\n          <el-card class=\"stat-item\"><div class=\"stat-num\">{{ stats.totalQuestions || 0 }}</div><div class=\"stat-label\">总答题数</div></el-card>\n          <el-card class=\"stat-item\"><div class=\"stat-num\" style=\"color:#67C23A\">{{ stats.correctCount || 0 }}</div><div class=\"stat-label\">正确</div></el-card>\n          <el-card class=\"stat-item\"><div class=\"stat-num\" style=\"color:#F56C6C\">{{ stats.wrongCount || 0 }}</div><div class=\"stat-label\">错误</div></el-card>\n          <el-card class=\"stat-item\"><div class=\"stat-num\" style=\"color:#409EFF\">{{ stats.accuracy || 0 }}%</div><div class=\"stat-label\">正确率</div></el-card>\n        </div>\n        <div v-if=\"stats && stats.knowledgePointStats\" class=\"kp-stats\">\n          <h4>知识点掌握情况</h4>\n          <div v-for=\"kp in (stats.knowledgePointStats || [])\" :key=\"kp.knowledgePoint\" class=\"kp-row\">\n            <span class=\"kp-name\">{{ kp.knowledgePoint }}</span>\n            <el-progress :percentage=\"parseFloat(kp.accuracy)\" :stroke-width=\"8\" :color=\"kp.accuracy >= 60 ? '#67C23A' : '#F56C6C'\"/>\n            <span class=\"kp-detail\">{{ kp.correct }}/{{ kp.total }}</span>\n          </div>\n        </div>\n      </el-tab-pane>\n    </el-tabs>\n\n    <!-- 模拟考试弹窗 -->\n    <el-dialog title=\"模拟考试设置\" :visible.sync=\"examDialogVisible\" width=\"450px\">\n      <el-form label-width=\"80px\">\n        <el-form-item label=\"考试名称\"><el-input v-model=\"examConfig.title\"/></el-form-item>\n        <el-form-item label=\"科目\">\n          <el-select v-model=\"examConfig.subject\" style=\"width:100%\">\n            <el-option label=\"政治\" value=\"政治\"/><el-option label=\"英语\" value=\"英语\"/><el-option label=\"数学\" value=\"数学\"/>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"题目数量\"><el-input-number v-model=\"examConfig.questionCount\" :min=\"5\" :max=\"50\"/></el-form-item>\n        <el-form-item label=\"考试时长\"><el-input-number v-model=\"examConfig.totalDuration\" :min=\"600\" :max=\"10800\" :step=\"600\"/> 秒</el-form-item>\n      </el-form>\n      <span slot=\"footer\"><el-button @click=\"examDialogVisible=false\">取消</el-button><el-button type=\"primary\" @click=\"beginExam\">开始考试</el-button></span>\n    </el-dialog>\n\n    <!-- 考试进行中 -->\n    <el-dialog :visible.sync=\"examActive\" fullscreen :close-on-click-modal=\"false\" :show-close=\"false\" class=\"exam-dialog\">\n      <div class=\"exam-room\" v-if=\"examActive\">\n        <div class=\"exam-header\">\n          <h3>{{ examConfig.title || '模拟考试' }}</h3>\n          <div class=\"exam-timer\">\n            <i class=\"el-icon-time\"></i>\n            <span :class=\"{ 'time-warning': remainingSeconds < 300 }\">{{ formatDuration(remainingSeconds) }}</span>\n          </div>\n          <el-button type=\"danger\" size=\"small\" @click=\"submitExam\">交卷</el-button>\n        </div>\n        <div class=\"exam-body\">\n          <div class=\"exam-sidebar\">\n            <div class=\"answer-grid\">\n              <div v-for=\"(q, idx) in examQuestions\" :key=\"q.id\" class=\"answer-dot\"\n                :class=\"{ 'answered': examAnswers[idx], 'current': currentExamIdx === idx }\"\n                @click=\"currentExamIdx = idx\">{{ idx + 1 }}</div>\n            </div>\n          </div>\n          <div class=\"exam-main\" v-if=\"examQuestions[currentExamIdx]\">\n            <div class=\"exam-question\">\n              <h4>第 {{ currentExamIdx + 1 }} 题 (共 {{ examQuestions.length }} 题)</h4>\n              <p>{{ examQuestions[currentExamIdx].content }}</p>\n              <el-radio-group v-model=\"examAnswers[currentExamIdx]\" class=\"exam-options\">\n                <el-radio v-for=\"opt in parseOptions(examQuestions[currentExamIdx].options)\" :key=\"opt.key\" :label=\"opt.key\">\n                  {{ opt.key }}. {{ opt.value }}\n                </el-radio>\n              </el-radio-group>\n            </div>\n            <div class=\"exam-nav\">\n              <el-button @click=\"currentExamIdx--\" :disabled=\"currentExamIdx === 0\">上一题</el-button>\n              <el-button type=\"primary\" @click=\"currentExamIdx++\" :disabled=\"currentExamIdx >= examQuestions.length - 1\">下一题</el-button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </el-dialog>\n\n    <!-- 考试结果 -->\n    <el-dialog title=\"考试结果\" :visible.sync=\"examResultVisible\" width=\"600px\">\n      <div v-if=\"examResult\" class=\"exam-result\">\n        <div class=\"result-score\">\n          <el-progress type=\"circle\" :percentage=\"parseFloat(examResult.accuracy)\" :color=\"examResult.accuracy >= 60 ? '#67C23A' : '#F56C6C'\"/>\n          <h3>得分: {{ examResult.totalScore }}/{{ examResult.maxScore }}</h3>\n          <p>正确 {{ examResult.correctCount }} 题，错误 {{ examResult.wrongCount }} 题</p>\n          <p>用时: {{ formatDuration(examResult.duration) }}</p>\n        </div>\n        <div class=\"result-details\">\n          <h4>答题详情</h4>\n          <div v-for=\"(d, idx) in (examResult.details||[])\" :key=\"idx\" class=\"result-item\" :class=\"{ correct: d.isCorrect, wrong: !d.isCorrect }\">\n            <span class=\"r-idx\">{{ idx + 1 }}</span>\n            <span class=\"r-status\">{{ d.isCorrect ? '✓' : '✗' }}</span>\n            <span class=\"r-kp\">{{ d.knowledgePoint }}</span>\n            <el-button v-if=\"!d.isCorrect\" type=\"text\" size=\"mini\" @click=\"showAnalysis(d)\">查看解析</el-button>\n          </div>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Practice',\n  data() {\n    return {\n      activeTab: 'practice',\n      filter: { subject: '', questionType: '', year: null, difficulty: null, page: 1 },\n      years: [2024, 2023, 2022, 2021, 2020],\n      questions: [], total: 0, currentQuestion: null,\n      parsedOptions: [], selectedAnswer: '', selectedMultiAnswers: [],\n      answered: false, resultCorrect: false, resultTitle: '',\n      wrongQuestions: [], stats: null,\n      examDialogVisible: false, examActive: false, examResultVisible: false,\n      examConfig: { title: '模拟考试', subject: '政治', questionCount: 20, totalDuration: 3600 },\n      examQuestions: [], examAnswers: [], currentExamIdx: 0, examResult: null,\n      remainingSeconds: 0, examTimer: null,\n      showDaily: false\n    }\n  },\n  computed: {\n    canSubmit() {\n      if (this.currentQuestion && this.currentQuestion.questionType === '多选') return this.selectedMultiAnswers.length > 0\n      return !!this.selectedAnswer\n    }\n  },\n  mounted() { this.fetchQuestions(); this.fetchStats(); this.fetchWrongQuestions() },\n  beforeDestroy() { this.clearExamTimer() },\n  methods: {\n    async fetchQuestions() {\n      try {\n        const p = { page: this.filter.page, size: 20 }\n        if (this.filter.subject) p.subject = this.filter.subject\n        if (this.filter.questionType) p.questionType = this.filter.questionType\n        if (this.filter.year) p.year = this.filter.year\n        if (this.filter.difficulty) p.difficulty = this.filter.difficulty\n        const res = await this.$http.get('/practice/questions', { params: p })\n        this.questions = res?.records || []\n        this.total = res?.total || 0\n        if (this.questions.length > 0) this.selectQuestion(this.questions[0])\n      } catch (e) { console.error(e) }\n    },\n    selectQuestion(q) {\n      this.currentQuestion = q\n      this.answered = false\n      this.selectedAnswer = ''\n      this.selectedMultiAnswers = []\n      this.parsedOptions = this.parseOptions(q.options)\n    },\n    parseOptions(opts) {\n      if (!opts) return []\n      if (typeof opts === 'string') {\n        try { return JSON.parse(opts) } catch (e) { return [] }\n      }\n      return opts\n    },\n    async submitAnswer() {\n      if (!this.currentQuestion) return\n      const answer = this.currentQuestion.questionType === '多选'\n        ? this.selectedMultiAnswers.sort().join('') : this.selectedAnswer\n      try {\n        const res = await this.$http.post('/practice/answer', {\n          questionId: this.currentQuestion.id, answer, duration: 0, sessionId: 'practice'\n        })\n        this.answered = true\n        this.resultCorrect = res.isCorrect\n        this.resultTitle = res.isCorrect ? '回答正确！' : `回答错误，正确答案是: ${res.correctAnswer}`\n        // Enrich the current question with analysis\n        if (res.analysis) this.currentQuestion.analysis = res.analysis\n        if (res.correctAnswer) this.currentQuestion.answer = res.correctAnswer\n        this.fetchStats()\n      } catch (e) { this.$message.error('提交失败') }\n    },\n    skipQuestion() {\n      const idx = this.questions.findIndex(q => q.id === this.currentQuestion?.id)\n      if (idx >= 0 && idx < this.questions.length - 1) this.selectQuestion(this.questions[idx + 1])\n      else this.fetchQuestions()\n    },\n    nextQuestion() {\n      const idx = this.questions.findIndex(q => q.id === this.currentQuestion?.id)\n      if (idx >= 0 && idx < this.questions.length - 1) this.selectQuestion(this.questions[idx + 1])\n      else { this.filter.page++; this.fetchQuestions() }\n    },\n    async fetchWrongQuestions() {\n      try { const res = await this.$http.get('/practice/wrong-questions', { params: { limit: 50 } }); this.wrongQuestions = res || [] } catch (e) {}\n    },\n    async fetchStats() {\n      try { this.stats = await this.$http.get('/practice/stats') } catch (e) {}\n    },\n    startExam() { this.examDialogVisible = true },\n    async beginExam() {\n      try {\n        const res = await this.$http.post('/practice/exam/start', this.examConfig)\n        const sessionId = res.id\n        this.examSessionId = sessionId\n 