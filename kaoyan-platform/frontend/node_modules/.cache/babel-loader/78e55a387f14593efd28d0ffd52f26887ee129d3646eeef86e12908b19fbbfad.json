{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'News',\n  data() {\n    return {\n      searchKeyword: '',\n      selectedCategory: '',\n      selectedStage: '',\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      notificationVisible: false,\n      notifications: [],\n      unreadCount: 0,\n      subscriptionVisible: false,\n      availableTags: ['报考信息', '招生简章', '备考指南', '经验分享', '政策解读', '院校动态', '复试调剂', '大纲变化', '数学', '英语', '政治', '专业课', '院校排名', '报录比'],\n      selectedTags: []\n    };\n  },\n  created() {\n    this.getNewsList();\n    this.getUnreadCount();\n  },\n  mounted() {\n    if (this.$route.query.showNotifications === '1') {\n      this.$nextTick(() => {\n        this.showNotifications();\n      });\n    }\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return '';\n      return new Date(time).toLocaleDateString('zh-CN');\n    },\n    goToDetail(id) {\n      this.$router.push(`/news/${id}`);\n    },\n    search() {\n      this.currentPage = 1;\n      this.getNewsList();\n    },\n    resetFilters() {\n      this.currentPage = 1;\n      this.searchKeyword = '';\n      this.selectedCategory = '';\n      this.selectedStage = '';\n      this.getNewsList();\n    },\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getNewsList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getNewsList();\n    },\n    async getNewsList() {\n      try {\n        const res = await this.$http.get('/news/list', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize,\n            category: this.selectedCategory || undefined,\n            examStage: this.selectedStage || undefined,\n            keyword: this.searchKeyword || undefined\n          }\n        });\n        this.newsList = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (error) {\n        console.error('获取资讯列表失败:', error);\n      }\n    },\n    async showNotifications() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token;\n      if (!token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      this.notificationVisible = true;\n      await this.getNotifications();\n    },\n    async getNotifications() {\n      try {\n        const res = await this.$http.get('/notification/list', {\n          params: {\n            page: 1,\n            size: 50\n          }\n        });\n        this.notifications = res?.records || [];\n      } catch (error) {\n        console.error(error);\n        if (error.response && error.response.status === 401) {\n          this.$message.warning('登录已过期，请重新登录');\n          this.$router.push('/login');\n        }\n      }\n    },\n    async getUnreadCount() {\n      try {\n        const res = await this.$http.get('/notification/unread-count');\n        this.unreadCount = res || 0;\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    async markAsRead(id) {\n      try {\n        await this.$http.post(`/notification/read/${id}`);\n        await this.getNotifications();\n        await this.getUnreadCount();\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    async markAllAsRead() {\n      try {\n        await this.$http.post('/notification/read-all');\n        await this.getNotifications();\n        await this.getUnreadCount();\n      } catch (error) {\n        console.error(error);\n      }\n    },\n    showSubscriptionDialog() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token;\n      if (!token) {\n        this.$message.warning('请先登录');\n        this.$router.push('/login');\n        return;\n      }\n      this.subscriptionVisible = true;\n      this.getSubscriptions();\n    },\n    async getSubscriptions() {\n      try {\n        const res = await this.$http.get('/news/subscriptions');\n        this.selectedTags = Array.isArray(res) ? res : [];\n      } catch (error) {\n        console.error('获取订阅标签失败:', error);\n      }\n    },\n    async saveSubscriptions() {\n      try {\n        // 取消所有现有订阅，然后重新订阅\n        for (const tag of this.availableTags) {\n          try {\n            await this.$http.post(`/news/unsubscribe/${tag}`);\n          } catch (e) {/* 忽略取消订阅失败 */}\n        }\n        for (const tag of this.selectedTags) {\n          try {\n            await this.$http.post(`/news/subscribe/${tag}`);\n          } catch (e) {/* 忽略订阅失败 */}\n        }\n        this.$message.success('订阅保存成功');\n        this.subscriptionVisible = false;\n      } catch (error) {\n        console.error('保存订阅标签失败:', error);\n        this.$message.error('保存订阅失败');\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchKeyword","selectedCategory","selectedStage","newsList","currentPage","pageSize","total","notificationVisible","notifications","unreadCount","subscriptionVisible","availableTags","selectedTags","created","getNewsList","getUnreadCount","mounted","$route","query","showNotifications","$nextTick","methods","formatTime","time","Date","toLocaleDateString","goToDetail","id","$router","push","search","resetFilters","handleSizeChange","size","handleCurrentChange","current","res","$http","get","params","page","category","undefined","examStage","keyword","records","error","console","token","$store","state","user","$message","warning","getNotifications","response","status","markAsRead","post","markAllAsRead","showSubscriptionDialog","getSubscriptions","Array","isArray","saveSubscriptions","tag","e","success"],"sources":["src/views/news/News.vue"],"sourcesContent":["<template>\n  <div class=\"news\">\n    <el-card>\n      <div class=\"news-header\">\n        <h1>考研资讯</h1>\n        <el-badge :value=\"unreadCount\" :hidden=\"unreadCount === 0\" class=\"notification-badge\">\n          <el-button type=\"primary\" @click=\"showNotifications\" icon=\"el-icon-bell\">通知</el-button>\n        </el-badge>\n      </div>\n\n      <div class=\"news-filter\">\n        <el-input\n          v-model=\"searchKeyword\"\n          placeholder=\"搜索资讯标题\"\n          clearable\n          style=\"width: 200px; margin-right: 15px;\"\n          @keyup.enter.native=\"search\"\n        >\n          <i slot=\"prefix\" class=\"el-icon-search\"></i>\n        </el-input>\n        <el-select v-model=\"selectedCategory\" placeholder=\"资讯分类\" clearable @change=\"search\" style=\"width:150px; margin-right:10px\">\n          <el-option label=\"全部\" value=\"\"></el-option>\n          <el-option-group label=\"政策公告\">\n            <el-option label=\"国家政策\" value=\"国家政策\"></el-option>\n            <el-option label=\"教育部文件\" value=\"教育部文件\"></el-option>\n            <el-option label=\"院校政策\" value=\"院校政策\"></el-option>\n          </el-option-group>\n          <el-option-group label=\"招生信息\">\n            <el-option label=\"招生简章\" value=\"招生简章\"></el-option>\n            <el-option label=\"专业目录\" value=\"专业目录\"></el-option>\n            <el-option label=\"报名通知\" value=\"报名通知\"></el-option>\n            <el-option label=\"网报公告\" value=\"网报公告\"></el-option>\n          </el-option-group>\n          <el-option-group label=\"考试资讯\">\n            <el-option label=\"考试大纲\" value=\"考试大纲\"></el-option>\n            <el-option label=\"初试信息\" value=\"初试信息\"></el-option>\n            <el-option label=\"成绩查询\" value=\"成绩查询\"></el-option>\n            <el-option label=\"国家线/复试线\" value=\"国家线/复试线\"></el-option>\n          </el-option-group>\n          <el-option-group label=\"复试调剂\">\n            <el-option label=\"复试通知\" value=\"复试通知\"></el-option>\n            <el-option label=\"复试经验\" value=\"复试经验\"></el-option>\n            <el-option label=\"调剂信息\" value=\"调剂信息\"></el-option>\n            <el-option label=\"录取公示\" value=\"录取公示\"></el-option>\n          </el-option-group>\n          <el-option-group label=\"备考指导\">\n            <el-option label=\"备考指南\" value=\"备考指南\"></el-option>\n            <el-option label=\"经验分享\" value=\"经验分享\"></el-option>\n            <el-option label=\"复习方法\" value=\"复习方法\"></el-option>\n            <el-option label=\"考研常识\" value=\"考研常识\"></el-option>\n          </el-option-group>\n          <el-option-group label=\"院校动态\">\n            <el-option label=\"院校新闻\" value=\"院校新闻\"></el-option>\n            <el-option label=\"学科排名\" value=\"学科排名\"></el-option>\n            <el-option label=\"招生宣讲\" value=\"招生宣讲\"></el-option>\n          </el-option-group>\n        </el-select>\n        <el-select v-model=\"selectedStage\" placeholder=\"备考阶段\" clearable @change=\"search\" style=\"width:130px\">\n          <el-option label=\"全部\" value=\"\"></el-option>\n          <el-option label=\"择校评估\" value=\"择校评估\"></el-option>\n          <el-option label=\"基础复习\" value=\"基础复习\"></el-option>\n          <el-option label=\"强化提升\" value=\"强化提升\"></el-option>\n          <el-option label=\"报名报考\" value=\"报名报考\"></el-option>\n          <el-option label=\"冲刺模考\" value=\"冲刺模考\"></el-option>\n          <el-option label=\"复试准备\" value=\"复试准备\"></el-option>\n          <el-option label=\"调剂录取\" value=\"调剂录取\"></el-option>\n        </el-select>\n        <el-button @click=\"resetFilters\" style=\"margin-left: 10px;\">重置</el-button>\n        <el-button type=\"info\" @click=\"showSubscriptionDialog\" style=\"margin-left: 20px;\">\n          <i class=\"el-icon-star-off\"></i> 订阅管理\n        </el-button>\n      </div>\n\n      <div class=\"news-list\">\n        <el-card v-for=\"news in newsList\" :key=\"news.id\" class=\"news-card\" @click.native=\"goToDetail(news.id)\">\n          <div class=\"news-content\">\n            <h3 class=\"news-title\">{{ news.title }}</h3>\n            <p class=\"news-summary\">{{ news.summary }}</p>\n            <div class=\"news-meta\">\n              <span class=\"category\">{{ news.category }}</span>\n              <span class=\"view-count\"><i class=\"el-icon-view\"></i> {{ news.viewCount }}</span>\n              <span class=\"time\">{{ formatTime(news.createTime) }}</span>\n            </div>\n          </div>\n          <img v-if=\"news.cover\" :src=\"news.cover\" alt=\"封面\" class=\"news-cover\" />\n        </el-card>\n      </div>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n\n    <el-dialog title=\"通知\" :visible.sync=\"notificationVisible\" width=\"600px\">\n      <div class=\"notification-list\">\n        <el-card v-for=\"notification in notifications\" :key=\"notification.id\" class=\"notification-item\" :class=\"{ 'unread': !notification.isRead }\">\n          <div class=\"notification-header\">\n            <h4>{{ notification.title }}</h4>\n            <el-tag size=\"small\" :type=\"notification.isRead ? 'info' : 'danger'\">{{ notification.isRead ? '已读' : '未读' }}</el-tag>\n          </div>\n          <p class=\"notification-content\">{{ notification.content }}</p>\n          <div class=\"notification-footer\">\n            <span class=\"time\">{{ formatTime(notification.createTime) }}</span>\n            <el-button v-if=\"!notification.isRead\" type=\"text\" size=\"small\" @click=\"markAsRead(notification.id)\">标记为已读</el-button>\n          </div>\n        </el-card>\n        <div v-if=\"notifications.length === 0\" class=\"empty-notifications\">\n          <el-empty description=\"暂无通知\" />\n        </div>\n      </div>\n      <div slot=\"footer\">\n        <el-button @click=\"notificationVisible = false\">关闭</el-button>\n        <el-button type=\"primary\" @click=\"markAllAsRead\">全部标记为已读</el-button>\n      </div>\n    </el-dialog>\n\n    <el-dialog title=\"订阅管理\" :visible.sync=\"subscriptionVisible\" width=\"500px\">\n      <div class=\"subscription-container\">\n        <p class=\"subscription-hint\">选择你感兴趣的资讯标签，当有新资讯时会收到通知</p>\n        <el-checkbox-group v-model=\"selectedTags\">\n          <el-checkbox v-for=\"tag in availableTags\" :key=\"tag\" :label=\"tag\" class=\"subscription-tag\">\n            {{ tag }}\n          </el-checkbox>\n        </el-checkbox-group>\n      </div>\n      <div slot=\"footer\">\n        <el-button @click=\"subscriptionVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"saveSubscriptions\">保存订阅</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'News',\n  data() {\n    return {\n      searchKeyword: '',\n      selectedCategory: '',\n      selectedStage: '',\n      newsList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      notificationVisible: false,\n      notifications: [],\n      unreadCount: 0,\n      subscriptionVisible: false,\n      availableTags: ['报考信息', '招生简章', '备考指南', '经验分享', '政策解读', '院校动态', '复试调剂', '大纲变化', '数学', '英语', '政治', '专业课', '院校排名', '报录比'],\n      selectedTags: []\n    }\n  },\n  created() {\n    this.getNewsList()\n    this.getUnreadCount()\n  },\n  mounted() {\n    if (this.$route.query.showNotifications === '1') {\n      this.$nextTick(() => { this.showNotifications() })\n    }\n  },\n  methods: {\n    formatTime(time) {\n      if (!time) return ''\n      return new Date(time).toLocaleDateString('zh-CN')\n    },\n    goToDetail(id) {\n      this.$router.push(`/news/${id}`)\n    },\n    search() {\n      this.currentPage = 1\n      this.getNewsList()\n    },\n    resetFilters() {\n      this.currentPage = 1\n      this.searchKeyword = ''\n      this.selectedCategory = ''\n      this.selectedStage = ''\n      this.getNewsList()\n    },\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getNewsList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getNewsList()\n    },\n    async getNewsList() {\n      try {\n        const res = await this.$http.get('/news/list', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize,\n            category: this.selectedCategory || undefined,\n            examStage: this.selectedStage || undefined,\n            keyword: this.searchKeyword || undefined\n          }\n        })\n        this.newsList = res?.records || []\n        this.total = res?.total || 0\n      } catch (error) {\n        console.error('获取资讯列表失败:', error)\n      }\n    },\n    async showNotifications() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token\n      if (!token) {\n        this.$message.warning('请先登录')\n        this.$router.push('/login')\n        return\n      }\n      this.notificationVisible = true\n      await this.getNotifications()\n    },\n    async getNotifications() {\n      try {\n        const res = await this.$http.get('/notification/list', {\n          params: {\n            page: 1,\n            size: 50\n          }\n        })\n        this.notifications = res?.records || []\n      } catch (error) {\n        console.error(error)\n        if (error.response && error.response.status === 401) {\n          this.$message.warning('登录已过期，请重新登录')\n          this.$router.push('/login')\n        }\n      }\n    },\n    async getUnreadCount() {\n      try {\n        const res = await this.$http.get('/notification/unread-count')\n        this.unreadCount = res || 0\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    async markAsRead(id) {\n      try {\n        await this.$http.post(`/notification/read/${id}`)\n        await this.getNotifications()\n        await this.getUnreadCount()\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    async markAllAsRead() {\n      try {\n        await this.$http.post('/notification/read-all')\n        await this.getNotifications()\n        await this.getUnreadCount()\n      } catch (error) {\n        console.error(error)\n      }\n    },\n    showSubscriptionDialog() {\n      // 检查用户是否已登录\n      const token = this.$store.state.user.token\n      if (!token) {\n        this.$message.warning('请先登录')\n        this.$router.push('/login')\n        return\n      }\n      this.subscriptionVisible = true\n      this.getSubscriptions()\n    },\n    async getSubscriptions() {\n      try {\n        const res = await this.$http.get('/news/subscriptions')\n        this.selectedTags = Array.isArray(res) ? res : []\n      } catch (error) {\n        console.error('获取订阅标签失败:', error)\n      }\n    },\n    async saveSubscriptions() {\n      try {\n        // 取消所有现有订阅，然后重新订阅\n        for (const tag of this.availableTags) {\n          try {\n            await this.$http.post(`/news/unsubscribe/${tag}`)\n          } catch (e) { /* 忽略取消订阅失败 */ }\n        }\n        for (const tag of this.selectedTags) {\n          try {\n            await this.$http.post(`/news/subscribe/${tag}`)\n          } catch (e) { /* 忽略订阅失败 */ }\n        }\n        this.$message.success('订阅保存成功')\n        this.subscriptionVisible = false\n      } catch (error) {\n        console.error('保存订阅标签失败:', error)\n        this.$message.error('保存订阅失败')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.news {\n  .news-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 20px;\n\n    h1 {\n      font-size: 24px;\n      color: #303133;\n    }\n\n    .notification-badge {\n      margin-left: auto;\n    }\n  }\n\n  .news-filter {\n    margin-bottom: 20px;\n  }\n\n  .news-list {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));\n    gap: 20px;\n    margin-bottom: 30px;\n\n    .news-card {\n      cursor: pointer;\n      transition: transform 0.3s;\n      display: flex;\n      gap: 20px;\n\n      &:hover {\n        transform: translateY(-5px);\n        box-shadow: 0 10px 20px rgba(0