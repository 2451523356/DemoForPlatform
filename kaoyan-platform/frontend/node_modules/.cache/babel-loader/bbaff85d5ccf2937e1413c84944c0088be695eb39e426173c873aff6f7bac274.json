{"ast":null,"code":"export default {\n  name: 'PostsManage',\n  data() {\n    return {\n      postList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      statusTypeMap: {\n        0: 'warning',\n        1: 'success',\n        2: 'danger'\n      },\n      statusTextMap: {\n        0: '待审核',\n        1: '已通过',\n        2: '已拒绝'\n      }\n    };\n  },\n  created() {\n    this.getPostList();\n  },\n  methods: {\n    handleSizeChange(size) {\n      this.pageSize = size;\n      this.getPostList();\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current;\n      this.getPostList();\n    },\n    async auditPost(post, status) {\n      const action = status === 1 ? '通过' : '拒绝';\n      try {\n        await this.$confirm(`确定要${action}该帖子吗？`, '审核确认', {\n          type: 'warning'\n        });\n        await this.$http.put(`/admin/post/${post.id}/status`, null, {\n          params: {\n            status\n          }\n        });\n        this.$message.success(`审核${action}`);\n        this.getPostList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error);\n        }\n      }\n    },\n    async deletePost(post) {\n      try {\n        await this.$confirm('确定要删除该帖子吗？', '提示', {\n          type: 'warning'\n        });\n        await this.$http.delete(`/admin/post/${post.id}`);\n        this.$message.success('删除成功');\n        this.getPostList();\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error);\n        }\n      }\n    },\n    async getPostList() {\n      try {\n        const res = await this.$http.get('/admin/posts', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        });\n        this.postList = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (error) {\n        console.error(error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","postList","currentPage","pageSize","total","statusTypeMap","statusTextMap","created","getPostList","methods","handleSizeChange","size","handleCurrentChange","current","auditPost","post","status","action","$confirm","type","$http","put","id","params","$message","success","error","console","deletePost","delete","res","get","page","records"],"sources":["src/views/admin/Posts.vue"],"sourcesContent":["<template>\n  <div class=\"posts-manage\">\n    <el-card>\n      <el-table :data=\"postList\" style=\"width: 100%\" :row-key=\"(row) => row.id\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"title\" label=\"标题\" min-width=\"150\" show-overflow-tooltip></el-table-column>\n        <el-table-column prop=\"authorName\" label=\"作者\" width=\"100\"></el-table-column>\n        <el-table-column prop=\"topic\" label=\"话题\" width=\"120\"></el-table-column>\n        <el-table-column prop=\"likeCount\" label=\"点赞\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"commentCount\" label=\"评论\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"statusTypeMap[scope.row.status] || 'info'\">\n              {{ statusTextMap[scope.row.status] || '未知' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"160\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"250\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button\n              v-if=\"scope.row.status === 0\"\n              size=\"mini\"\n              type=\"success\"\n              @click=\"auditPost(scope.row, 1)\"\n            >\n              通过\n            </el-button>\n            <el-button\n              v-if=\"scope.row.status === 0\"\n              size=\"mini\"\n              type=\"danger\"\n              @click=\"auditPost(scope.row, 2)\"\n            >\n              拒绝\n            </el-button>\n            <el-button size=\"mini\" type=\"danger\" @click=\"deletePost(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <div class=\"pagination\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[10, 20, 50]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\"\n        />\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'PostsManage',\n  data() {\n    return {\n      postList: [],\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      statusTypeMap: { 0: 'warning', 1: 'success', 2: 'danger' },\n      statusTextMap: { 0: '待审核', 1: '已通过', 2: '已拒绝' }\n    }\n  },\n  created() {\n    this.getPostList()\n  },\n  methods: {\n    handleSizeChange(size) {\n      this.pageSize = size\n      this.getPostList()\n    },\n    handleCurrentChange(current) {\n      this.currentPage = current\n      this.getPostList()\n    },\n    async auditPost(post, status) {\n      const action = status === 1 ? '通过' : '拒绝'\n      try {\n        await this.$confirm(`确定要${action}该帖子吗？`, '审核确认', {\n          type: 'warning'\n        })\n        await this.$http.put(`/admin/post/${post.id}/status`, null, {\n          params: { status }\n        })\n        this.$message.success(`审核${action}`)\n        this.getPostList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error)\n        }\n      }\n    },\n    async deletePost(post) {\n      try {\n        await this.$confirm('确定要删除该帖子吗？', '提示', {\n          type: 'warning'\n        })\n        await this.$http.delete(`/admin/post/${post.id}`)\n        this.$message.success('删除成功')\n        this.getPostList()\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error(error)\n        }\n      }\n    },\n    async getPostList() {\n      try {\n        const res = await this.$http.get('/admin/posts', {\n          params: {\n            page: this.currentPage,\n            size: this.pageSize\n          }\n        })\n        this.postList = res?.records || []\n        this.total = res?.total || 0\n      } catch (error) {\n        console.error(error)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped lang=\"scss\">\n.posts-manage {\n  .pagination {\n    margin-top: 20px;\n    text-align: center;\n  }\n}\n</style>\n"],"mappings":"AAyDA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;MACAC,aAAA;QAAA;QAAA;QAAA;MAAA;MACAC,aAAA;QAAA;QAAA;QAAA;MAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAC,iBAAAC,IAAA;MACA,KAAAR,QAAA,GAAAQ,IAAA;MACA,KAAAH,WAAA;IACA;IACAI,oBAAAC,OAAA;MACA,KAAAX,WAAA,GAAAW,OAAA;MACA,KAAAL,WAAA;IACA;IACA,MAAAM,UAAAC,IAAA,EAAAC,MAAA;MACA,MAAAC,MAAA,GAAAD,MAAA;MACA;QACA,WAAAE,QAAA,OAAAD,MAAA;UACAE,IAAA;QACA;QACA,WAAAC,KAAA,CAAAC,GAAA,gBAAAN,IAAA,CAAAO,EAAA;UACAC,MAAA;YAAAP;UAAA;QACA;QACA,KAAAQ,QAAA,CAAAC,OAAA,MAAAR,MAAA;QACA,KAAAT,WAAA;MACA,SAAAkB,KAAA;QACA,IAAAA,KAAA;UACAC,OAAA,CAAAD,KAAA,CAAAA,KAAA;QACA;MACA;IACA;IACA,MAAAE,WAAAb,IAAA;MACA;QACA,WAAAG,QAAA;UACAC,IAAA;QACA;QACA,WAAAC,KAAA,CAAAS,MAAA,gBAAAd,IAAA,CAAAO,EAAA;QACA,KAAAE,QAAA,CAAAC,OAAA;QACA,KAAAjB,WAAA;MACA,SAAAkB,KAAA;QACA,IAAAA,KAAA;UACAC,OAAA,CAAAD,KAAA,CAAAA,KAAA;QACA;MACA;IACA;IACA,MAAAlB,YAAA;MACA;QACA,MAAAsB,GAAA,cAAAV,KAAA,CAAAW,GAAA;UACAR,MAAA;YACAS,IAAA,OAAA9B,WAAA;YACAS,IAAA,OAAAR;UACA;QACA;QACA,KAAAF,QAAA,GAAA6B,GAAA,EAAAG,OAAA;QACA,KAAA7B,KAAA,GAAA0B,GAAA,EAAA1B,KAAA;MACA,SAAAsB,KAAA;QACAC,OAAA,CAAAD,KAAA,CAAAA,KAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}