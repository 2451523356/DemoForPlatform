{"ast":null,"code":"export default {\n  name: 'WrongQuestions',\n  data() {\n    return {\n      stats: {},\n      list: [],\n      page: 1,\n      size: 10,\n      total: 0,\n      filterSubject: '',\n      dialogVisible: false,\n      reviewVisible: false,\n      editId: null,\n      reviewItem: null,\n      form: {\n        subject: '',\n        questionContent: '',\n        answer: '',\n        userAnswer: '',\n        analysis: '',\n        source: '',\n        tags: ''\n      }\n    };\n  },\n  created() {\n    this.fetchStats();\n    this.fetch();\n  },\n  methods: {\n    async fetchStats() {\n      try {\n        this.stats = (await this.$http.get('/wrong-question/stats')) || {};\n      } catch (e) {}\n    },\n    async fetch() {\n      try {\n        const res = await this.$http.get('/wrong-question/list', {\n          params: {\n            page: this.page,\n            size: this.size,\n            subject: this.filterSubject || undefined\n          }\n        });\n        this.list = res?.records || [];\n        this.total = res?.total || 0;\n      } catch (e) {}\n    },\n    handlePage(p) {\n      this.page = p;\n      this.fetch();\n    },\n    openAddDialog() {\n      this.editId = null;\n      this.form = {\n        subject: '',\n        questionContent: '',\n        answer: '',\n        userAnswer: '',\n        analysis: '',\n        source: '',\n        tags: ''\n      };\n      this.dialogVisible = true;\n    },\n    openDetail(row) {\n      this.editId = row.id;\n      this.form = {\n        ...row\n      };\n      this.dialogVisible = true;\n    },\n    async save() {\n      try {\n        if (this.editId) {\n          await this.$http.put(`/wrong-question/${this.editId}`, this.form);\n        } else {\n          await this.$http.post('/wrong-question/add', this.form);\n        }\n        ;\n        this.dialogVisible = false;\n        this.fetch();\n        this.fetchStats();\n        this.$message.success('保存成功');\n      } catch (e) {}\n    },\n    async del(id) {\n      try {\n        await this.$confirm('确定删除?', '提示', {\n          type: 'warning'\n        });\n        await this.$http.delete(`/wrong-question/${id}`);\n        this.fetch();\n        this.fetchStats();\n      } catch (e) {}\n    },\n    reviewMode(row) {\n      this.reviewItem = row;\n      this.reviewVisible = true;\n    },\n    async markMastered(row) {\n      try {\n        await this.$http.put(`/wrong-question/${row.id}/master`);\n        this.$message.success('已标记为掌握');\n        this.fetch();\n        this.fetchStats();\n      } catch (e) {}\n    }\n  }\n};","map":{"version":3,"names":["name","data","stats","list","page","size","total","filterSubject","dialogVisible","reviewVisible","editId","reviewItem","form","subject","questionContent","answer","userAnswer","analysis","source","tags","created","fetchStats","fetch","methods","$http","get","e","res","params","undefined","records","handlePage","p","openAddDialog","openDetail","row","id","save","put","post","$message","success","del","$confirm","type","delete","reviewMode","markMastered"],"sources":["src/views/study/WrongQuestions.vue"],"sourcesContent":["<template>\n  <div class=\"wq-page\">\n    <div class=\"page-header\"><h1>错题本</h1><p>记录错题，反复复习，攻克薄弱环节</p></div>\n    <div class=\"stats-row\">\n      <el-card class=\"stat-card\"><div class=\"stat-val\">{{ stats.total || 0 }}</div><div class=\"stat-label\">总错题</div></el-card>\n      <el-card class=\"stat-card\"><div class=\"stat-val\" style=\"color:#E6A23C\">{{ stats.unmastered || 0 }}</div><div class=\"stat-label\">未掌握</div></el-card>\n      <el-card class=\"stat-card\"><div class=\"stat-val\" style=\"color:#67C23A\">{{ stats.mastered || 0 }}</div><div class=\"stat-label\">已掌握</div></el-card>\n    </div>\n    <el-card>\n      <div class=\"toolbar\">\n        <el-select v-model=\"filterSubject\" @change=\"fetch\" placeholder=\"按科目筛选\" clearable><el-option label=\"数学\" value=\"数学\"/><el-option label=\"英语\" value=\"英语\"/><el-option label=\"政治\" value=\"政治\"/><el-option label=\"专业课\" value=\"专业课\"/></el-select>\n        <el-button type=\"primary\" @click=\"openAddDialog\" icon=\"el-icon-plus\">录入错题</el-button>\n      </div>\n      <el-table :data=\"list\" stripe>\n        <el-table-column prop=\"subject\" label=\"科目\" width=\"80\"><template slot-scope=\"s\"><el-tag size=\"mini\">{{ s.row.subject }}</el-tag></template></el-table-column>\n        <el-table-column prop=\"questionContent\" label=\"题目\" show-overflow-tooltip />\n        <el-table-column prop=\"source\" label=\"来源\" width=\"120\" />\n        <el-table-column prop=\"reviewCount\" label=\"复习次数\" width=\"80\" />\n        <el-table-column prop=\"status\" label=\"状态\" width=\"80\"><template slot-scope=\"s\"><el-tag :type=\"s.row.status===1?'success':'warning'\" size=\"mini\">{{ s.row.status===1?'已掌握':'未掌握' }}</el-tag></template></el-table-column>\n        <el-table-column label=\"操作\" width=\"200\"><template slot-scope=\"s\"><el-button type=\"text\" @click=\"openDetail(s.row)\">查看</el-button><el-button type=\"text\" @click=\"reviewMode(s.row)\" :disabled=\"s.row.status===1\">复习</el-button><el-button type=\"text\" @click=\"markMastered(s.row)\" v-if=\"s.row.status===0\">标记掌握</el-button><el-button type=\"text\" style=\"color:#F56C6C\" @click=\"del(s.row.id)\">删除</el-button></template></el-table-column>\n      </el-table>\n      <el-pagination style=\"margin-top:16px\" @current-change=\"handlePage\" :current-page=\"page\" :page-size=\"size\" :total=\"total\" layout=\"total,prev,pager,next\"/>\n    </el-card>\n    <!-- 录入/编辑对话框 -->\n    <el-dialog :title=\"editId?'编辑错题':'录入错题'\" :visible.sync=\"dialogVisible\" width=\"600px\">\n      <el-form :model=\"form\" label-width=\"80px\">\n        <el-form-item label=\"科目\"><el-select v-model=\"form.subject\" style=\"width:100%\"><el-option label=\"数学\" value=\"数学\"/><el-option label=\"英语\" value=\"英语\"/><el-option label=\"政治\" value=\"政治\"/><el-option label=\"专业课\" value=\"专业课\"/></el-select></el-form-item>\n        <el-form-item label=\"题目内容\"><el-input v-model=\"form.questionContent\" type=\"textarea\" :rows=\"3\"/></el-form-item>\n        <el-form-item label=\"正确答案\"><el-input v-model=\"form.answer\" type=\"textarea\" :rows=\"2\"/></el-form-item>\n        <el-form-item label=\"你的答案\"><el-input v-model=\"form.userAnswer\" type=\"textarea\" :rows=\"2\"/></el-form-item>\n        <el-form-item label=\"解析\"><el-input v-model=\"form.analysis\" type=\"textarea\" :rows=\"2\"/></el-form-item>\n        <el-form-item label=\"来源\"><el-input v-model=\"form.source\" placeholder=\"如：2024年真题\"/></el-form-item>\n        <el-form-item label=\"标签\"><el-input v-model=\"form.tags\" placeholder=\"多个标签用逗号分隔\"/></el-form-item>\n      </el-form>\n      <span slot=\"footer\"><el-button @click=\"dialogVisible=false\">取消</el-button><el-button type=\"primary\" @click=\"save\">保存</el-button></span>\n    </el-dialog>\n    <!-- 复习模式对话框 -->\n    <el-dialog title=\"复习模式\" :visible.sync=\"reviewVisible\" width=\"500px\">\n      <div v-if=\"reviewItem\"><p class=\"review-q\"><strong>题目：</strong>{{ reviewItem.questionContent }}</p><div class=\"answer-reveal\"><p><strong>你的答案：</strong><span style=\"color:#F56C6C\">{{ reviewItem.userAnswer }}</span></p><p><strong>正确答案：</strong><span style=\"color:#67C23A\">{{ reviewItem.answer }}</span></p><p v-if=\"reviewItem.analysis\"><strong>解析：</strong>{{ reviewItem.analysis }}</p></div></div>\n      <span slot=\"footer\"><el-button type=\"primary\" @click=\"reviewVisible=false;fetch()\">复习完成</el-button></span>\n    </el-dialog>\n  </div>\n</template>\n<script>\nexport default {\n  name: 'WrongQuestions',\n  data() { return { stats:{}, list:[], page:1, size:10, total:0, filterSubject:'', dialogVisible:false, reviewVisible:false, editId:null, reviewItem:null, form:{subject:'',questionContent:'',answer:'',userAnswer:'',analysis:'',source:'',tags:''} } },\n  created() { this.fetchStats(); this.fetch() },\n  methods: {\n    async fetchStats() { try { this.stats = await this.$http.get('/wrong-question/stats') || {} } catch(e) {} },\n    async fetch() { try { const res = await this.$http.get('/wrong-question/list',{params:{page:this.page,size:this.size,subject:this.filterSubject||undefined}}); this.list=res?.records||[]; this.total=res?.total||0 } catch(e) {} },\n    handlePage(p) { this.page=p; this.fetch() },\n    openAddDialog() { this.editId=null; this.form={subject:'',questionContent:'',answer:'',userAnswer:'',analysis:'',source:'',tags:''}; this.dialogVisible=true },\n    openDetail(row) { this.editId=row.id; this.form={...row}; this.dialogVisible=true },\n    async save() { try { if(this.editId) { await this.$http.put(`/wrong-question/${this.editId}`, this.form) } else { await this.$http.post('/wrong-question/add', this.form) }; this.dialogVisible=false; this.fetch(); this.fetchStats(); this.$message.success('保存成功') } catch(e) {} },\n    async del(id) { try { await this.$confirm('确定删除?','提示',{type:'warning'}); await this.$http.delete(`/wrong-question/${id}`); this.fetch(); this.fetchStats() } catch(e) {} },\n    reviewMode(row) { this.reviewItem=row; this.reviewVisible=true },\n    async markMastered(row) { try { await this.$http.put(`/wrong-question/${row.id}/master`); this.$message.success('已标记为掌握'); this.fetch(); this.fetchStats() } catch(e) {} }\n  }\n}\n</script>\n<style scoped>\n.wq-page { padding:20px; max-width:1200px; margin:0 auto; }\n.page-header { margin-bottom:20px; } .page-header h1 { font-size:24px; margin-bottom:8px; } .page-header p { color:#909399; }\n.stats-row { display:flex; gap:16px; margin-bottom:20px; } .stat-card { flex:1; text-align:center; } .stat-val { font-size:32px; font-weight:700; } .stat-label { color:#909399; margin-top:8px; }\n.toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }\n.review-q { margin-bottom:16px; line-height:1.8; } .answer-reveal p { margin-bottom:8px; }\n</style>\n"],"mappings":"AA4CA;EACAA,IAAA;EACAC,KAAA;IAAA;MAAAC,KAAA;MAA